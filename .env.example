# Local development example. Copy to .env and fill real values locally.
# Do not commit real secrets.

RAILS_ENV=development
APP_HOST=localhost:3000
APP_PROTOCOL=http

# Production/Railway must set this with a real value from:
# bin/rails secret
SECRET_KEY_BASE=

# Optional if you use Rails encrypted credentials in production.
RAILS_MASTER_KEY=

# Railway PostgreSQL usually injects DATABASE_URL automatically.
DATABASE_URL=

# Seed account for production setup.
SEED_SUPER_ADMIN_EMAIL=president@msj.local
SEED_SUPER_ADMIN_ROLE=president
SEED_SUPER_ADMIN_PASSWORD=change-this-password
RESET_SEED_SUPER_ADMIN_PASSWORD=false
RUN_DB_SEED_ON_BOOT=false

# Google OAuth, if enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Brevo HTTPS API delivery for password reset and payment emails.
# This works on Railway Hobby because it does not use blocked SMTP ports.
MAILER_SENDER=mizosocietyjapan@gmail.com
MAILER_SENDER_NAME=Mizo Society of Japan
BREVO_API_KEY=

# Optional SMTP fallback for platforms/plans that allow outbound SMTP.
SMTP_ADDRESS=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_DOMAIN=mizosocietyjapan.up.railway.app
BREVO_LOGIN=
BREVO_SMTP_KEY=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer

# Production file uploads. Recommended for Railway deploys so images/files do
# not disappear when a new container is deployed.
ACTIVE_STORAGE_SERVICE=cloudflare_r2
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# Example:
# https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=
