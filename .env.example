# Local development example. Copy to .env and fill real values locally.
# Do not commit real secrets.

RAILS_ENV=development
APP_HOST=localhost:3000
APP_PROTOCOL=http

# Production/Railway must set this with a real value from:
# bin/rails secret
SECRET_KEY_BASE=

# Optional if you use Rails encrypted credentials in production.
RAILS_MASTER_KEY=

# Railway PostgreSQL usually injects DATABASE_URL automatically.
DATABASE_URL=

# Seed account for production setup.
SEED_SUPER_ADMIN_EMAIL=president@msj.local
SEED_SUPER_ADMIN_ROLE=president
SEED_SUPER_ADMIN_PASSWORD=change-this-password
RESET_SEED_SUPER_ADMIN_PASSWORD=false
RUN_DB_SEED_ON_BOOT=false

# Google OAuth, if enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
