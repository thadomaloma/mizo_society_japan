<% content_for :page_title, "AI Assistant" %>

<div class="space-y-5">
  <%= render "shared/page_header",
    eyebrow: "MSJ Help",
    title: "AI Assistant",
    subtitle: "Mizo tawngin portal hman dan zawt rawh." %>

  <section class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <div class="space-y-4">
      <article class="overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <div class="border-b border-[#E2E8F0] bg-[#F8FAFC] px-4 py-3 dark:border-[#334155] dark:bg-[#0F172A] sm:px-5">
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-300">
              <%= icon_svg(:chat, classes: "h-5 w-5") %>
            </span>
            <div>
              <h3 class="text-sm font-black text-[#0F172A] dark:text-white sm:text-base">MSJ Portal Guide</h3>
              <p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Payments, profile, welfare, events, minutes, leh letters chungchang i zawt thei.</p>
            </div>
          </div>
        </div>

        <div class="space-y-4 p-4 sm:p-5">
          <%= form_with url: ai_assistant_path, method: :post, class: "space-y-3", data: { turbo: false } do |form| %>
            <div>
              <%= form.label :question, "Your question", class: "text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]" %>
              <%= form.text_area :question,
                value: @question,
                rows: 4,
                placeholder: "Membership fee engtin nge ka pek ang?",
                class: "mt-2 w-full resize-none rounded-2xl border border-[#E2E8F0] bg-white px-4 py-3 text-sm font-semibold text-[#0F172A] shadow-sm outline-none transition placeholder:text-slate-400 focus:border-red-500 focus:ring-4 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white dark:placeholder:text-slate-500 dark:focus:border-red-400 dark:focus:ring-red-500/15" %>
            </div>

            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-xs font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1]">AI chuan portal context hmangin a chhang. Official confirmation ngai chu Office Bearer contact rawh.</p>
              <%= form.button class: action_button_classes(:primary, size: :sm, extra: "justify-center") do %>
                <%= icon_svg(:chat, classes: "h-4 w-4") %>
                <span>Ask AI</span>
              <% end %>
            </div>
          <% end %>

          <% if @answer.present? %>
            <div class="rounded-2xl border border-red-100 bg-red-50/70 p-4 dark:border-red-500/20 dark:bg-red-500/10">
              <div class="mb-3 flex items-center gap-2">
                <span class="grid h-8 w-8 place-items-center rounded-lg bg-red-600 text-white dark:bg-red-500">
                  <%= icon_svg(:chat, classes: "h-4 w-4") %>
                </span>
                <p class="text-sm font-black text-red-800 dark:text-red-100">AI Answer</p>
              </div>
              <div class="prose prose-sm max-w-none font-semibold leading-6 text-[#0F172A] prose-p:my-2 prose-ul:my-2 dark:prose-invert dark:text-white">
                <%= simple_format(@answer) %>
              </div>
            </div>
          <% else %>
            <div class="rounded-2xl border border-[#E2E8F0] bg-[#F8FAFC] p-4 dark:border-[#334155] dark:bg-[#0F172A]">
              <p class="text-sm font-black text-[#0F172A] dark:text-white">I zawhna ka lo nghak e.</p>
              <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Example: “Payment together engtin nge ka tih ang?”</p>
            </div>
          <% end %>
        </div>
      </article>
    </div>

    <aside class="space-y-4">
      <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <h3 class="text-sm font-black text-[#0F172A] dark:text-white">Suggested Questions</h3>
        <div class="mt-3 space-y-2">
          <% @suggested_questions.each do |suggested_question| %>
            <%= button_to ai_assistant_path,
              method: :post,
              params: { question: suggested_question },
              form: { data: { turbo: false } },
              class: "group flex w-full items-center justify-between gap-3 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] px-3 py-2.5 text-left text-xs font-black text-[#0F172A] transition hover:border-red-200 hover:bg-red-50 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white dark:hover:bg-[#334155]" do %>
              <span class="leading-5"><%= suggested_question %></span>
              <%= icon_svg(:arrow_right, classes: "h-3.5 w-3.5 shrink-0 text-slate-400 group-hover:text-red-600 dark:group-hover:text-red-300") %>
            <% end %>
          <% end %>
        </div>
      </section>

      <section class="rounded-2xl border border-red-100 bg-red-50 p-4 dark:border-red-500/20 dark:bg-red-500/10">
        <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">Safe Use</p>
        <p class="mt-2 text-sm font-semibold leading-6 text-red-900 dark:text-red-100">
          AI answer chu help guide a ni. Payment paid confirmation, private welfare decision, leh official approval chu portal record leh Office Bearer confirmation hmang chauh tur a ni.
        </p>
      </section>
    </aside>
  </section>
</div>
