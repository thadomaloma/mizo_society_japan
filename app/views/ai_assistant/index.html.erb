<% content_for :page_title, "AI Assistant" %>

<div class="min-w-0 max-w-full overflow-x-hidden space-y-5">
  <%= render "shared/page_header",
    eyebrow: "MSJ Help",
    title: "AI Assistant",
    subtitle: "Question click mai la, Mizo tawngin step-by-step answer i hmu ang." %>

  <section class="grid min-w-0 max-w-full gap-5 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <div class="min-w-0 max-w-full space-y-4">
      <article class="min-w-0 max-w-full overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <div class="border-b border-[#E2E8F0] bg-gradient-to-r from-slate-50 to-white px-4 py-3 dark:border-[#334155] dark:from-[#0F172A] dark:to-[#1E293B] sm:px-5">
          <div class="flex min-w-0 items-center gap-3">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-600 text-white shadow-sm shadow-red-950/10 dark:bg-red-500">
              <%= icon_svg(:chat, classes: "h-5 w-5") %>
            </span>
            <div class="min-w-0">
              <h3 class="text-sm font-black text-[#0F172A] dark:text-white sm:text-base">MSJ Portal Guide</h3>
              <p class="mt-0.5 break-words text-xs font-semibold text-[#64748B] [overflow-wrap:anywhere] [word-break:break-word] dark:text-[#CBD5E1]">Typing ngai lo. Question i mamawh ber kha click mai rawh.</p>
            </div>
          </div>
        </div>

        <div class="min-w-0 max-w-full space-y-4 p-4 sm:p-5">
          <% if @answer.present? %>
            <div class="min-w-0 max-w-full overflow-hidden rounded-2xl border border-red-100 bg-white shadow-sm shadow-red-950/5 dark:border-red-500/20 dark:bg-[#1E293B]">
              <div class="border-b border-red-100 bg-red-50/70 px-4 py-3 dark:border-red-500/20 dark:bg-red-500/10 sm:px-5">
                <div class="flex min-w-0 items-center gap-3">
                  <span class="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-white text-red-700 shadow-sm ring-1 ring-red-100 dark:bg-[#0F172A] dark:text-red-300 dark:ring-red-500/20">
                    <%= icon_svg(:chat, classes: "h-4 w-4") %>
                  </span>
                  <div class="min-w-0">
                    <p class="text-sm font-black text-red-800 dark:text-red-100">Answer</p>
                    <p class="mt-0.5 truncate text-xs font-bold text-red-700/75 dark:text-red-200/80"><%= @question %></p>
                  </div>
                </div>
              </div>
              <div class="min-w-0 max-w-full space-y-2 overflow-hidden bg-white p-4 dark:bg-[#1E293B] sm:p-5">
                <%= ai_answer_content(@answer) %>
              </div>
            </div>
          <% end %>

          <section class="min-w-0 max-w-full overflow-hidden">
            <div class="mb-3 flex items-center justify-between gap-3">
              <div class="min-w-0">
                <h3 class="text-sm font-black text-[#0F172A] dark:text-white">Role-based Questions</h3>
                <p class="mt-1 break-words text-xs font-semibold text-[#64748B] [overflow-wrap:anywhere] [word-break:break-word] dark:text-[#CBD5E1]"><%= User.role_label(current_user.role) %> tan question remchang te.</p>
              </div>
              <span class="hidden rounded-full bg-slate-100 px-3 py-1 text-xs font-black text-slate-600 dark:bg-slate-700 dark:text-slate-200 sm:inline-flex"><%= @suggested_questions.size %> topics</span>
            </div>

            <div class="grid min-w-0 max-w-full gap-2 sm:grid-cols-2">
              <% @suggested_questions.each_with_index do |suggested_question, index| %>
                <%= button_to ai_assistant_path,
                  method: :post,
                  params: { question: suggested_question },
                  form: { class: "min-w-0 max-w-full", data: { turbo: false } },
                  class: "group flex min-h-14 min-w-0 max-w-full items-center justify-between gap-3 overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white px-3 py-3 text-left text-xs font-black text-[#0F172A] shadow-sm transition hover:-translate-y-0.5 hover:border-red-200 hover:bg-red-50 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-red-500 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white dark:hover:bg-[#334155] sm:px-4" do %>
                  <span class="grid h-8 w-8 shrink-0 place-items-center rounded-xl bg-slate-100 text-[11px] font-black text-slate-600 transition group-hover:bg-red-600 group-hover:text-white dark:bg-slate-800 dark:text-slate-300 dark:group-hover:bg-red-500">
                    <%= index + 1 %>
                  </span>
                  <span class="min-w-0 flex-1 break-words leading-5 [overflow-wrap:anywhere] [word-break:break-word]"><%= suggested_question %></span>
                  <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-white text-slate-400 ring-1 ring-slate-200 transition group-hover:bg-red-600 group-hover:text-white group-hover:ring-red-600 dark:bg-slate-900 dark:ring-slate-700 dark:group-hover:bg-red-500 dark:group-hover:ring-red-500">
                    <%= icon_svg(:arrow_right, classes: "h-3.5 w-3.5") %>
                  </span>
                <% end %>
              <% end %>
            </div>
          </section>
        </div>
      </article>
    </div>

    <aside class="min-w-0 max-w-full space-y-4">
      <section class="min-w-0 max-w-full overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <h3 class="text-sm font-black text-[#0F172A] dark:text-white">How it works</h3>
        <div class="mt-3 space-y-3">
          <div class="flex gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-300">1</span>
            <p class="min-w-0 break-words text-sm font-semibold leading-6 text-[#64748B] [overflow-wrap:anywhere] [word-break:break-word] dark:text-[#CBD5E1]">Question card click rawh.</p>
          </div>
          <div class="flex gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-300">2</span>
            <p class="min-w-0 break-words text-sm font-semibold leading-6 text-[#64748B] [overflow-wrap:anywhere] [word-break:break-word] dark:text-[#CBD5E1]">AI chuan i role leh portal context a en ang.</p>
          </div>
          <div class="flex gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-300">3</span>
            <p class="min-w-0 break-words text-sm font-semibold leading-6 text-[#64748B] [overflow-wrap:anywhere] [word-break:break-word] dark:text-[#CBD5E1]">Step-by-step answer i hmu ang.</p>
          </div>
        </div>
      </section>

      <section class="min-w-0 max-w-full overflow-hidden rounded-2xl border border-red-100 bg-red-50 p-4 dark:border-red-500/20 dark:bg-red-500/10">
        <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">Safe Use</p>
        <p class="mt-2 break-words text-sm font-semibold leading-6 text-red-900 [overflow-wrap:anywhere] [word-break:break-word] dark:text-red-100">
          AI answer chu help guide a ni. Payment paid confirmation, private welfare decision, leh official approval chu portal record leh Office Bearer confirmation hmang chauh tur a ni.
        </p>
      </section>
    </aside>
  </section>
</div>
