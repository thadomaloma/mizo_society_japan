<% content_for :page_title, "AI Assistant" %>

<div class="space-y-5">
  <%= render "shared/page_header",
    eyebrow: "MSJ Help",
    title: "AI Assistant",
    subtitle: "Question click mai la, Mizo tawngin step-by-step answer i hmu ang." %>

  <section class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <div class="space-y-4">
      <article class="overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <div class="border-b border-[#E2E8F0] bg-[#F8FAFC] px-4 py-3 dark:border-[#334155] dark:bg-[#0F172A] sm:px-5">
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-300">
              <%= icon_svg(:chat, classes: "h-5 w-5") %>
            </span>
            <div>
              <h3 class="text-sm font-black text-[#0F172A] dark:text-white sm:text-base">MSJ Portal Guide</h3>
              <p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Typing ngai lo. Question i mamawh ber kha click mai rawh.</p>
            </div>
          </div>
        </div>

        <div class="space-y-4 p-4 sm:p-5">
          <% if @answer.present? %>
            <div class="overflow-hidden rounded-3xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
              <div class="border-b border-[#E2E8F0] bg-slate-50 px-4 py-3 dark:border-[#334155] dark:bg-[#0F172A] sm:px-5">
                <div class="flex items-center gap-3">
                  <span class="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-red-600 text-white shadow-sm dark:bg-red-500">
                  <%= icon_svg(:chat, classes: "h-4 w-4") %>
                  </span>
                  <div class="min-w-0">
                    <p class="text-sm font-black text-slate-950 dark:text-white">AI Answer</p>
                    <p class="mt-0.5 truncate text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= @question %></p>
                  </div>
                </div>
              </div>
              <div class="space-y-2 bg-white p-4 dark:bg-[#1E293B] sm:p-5">
                <%= ai_answer_content(@answer) %>
              </div>
            </div>
          <% end %>

          <section>
            <div class="mb-3 flex items-center justify-between gap-3">
              <div>
                <h3 class="text-sm font-black text-[#0F172A] dark:text-white">Role-based Questions</h3>
                <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= User.role_label(current_user.role) %> tan question remchang te.</p>
              </div>
              <span class="hidden rounded-full bg-slate-100 px-3 py-1 text-xs font-black text-slate-600 dark:bg-slate-700 dark:text-slate-200 sm:inline-flex"><%= @suggested_questions.size %> topics</span>
            </div>

            <div class="grid gap-2 sm:grid-cols-2">
              <% @suggested_questions.each do |suggested_question| %>
                <%= button_to ai_assistant_path,
                  method: :post,
                  params: { question: suggested_question },
                  form: { data: { turbo: false } },
                  class: "group flex min-h-14 w-full items-center justify-between gap-3 rounded-2xl border border-[#E2E8F0] bg-white px-3 py-3 text-left text-xs font-black text-[#0F172A] shadow-sm transition hover:border-red-200 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white dark:hover:bg-[#334155] sm:px-4" do %>
                  <span class="leading-5"><%= suggested_question %></span>
                  <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-slate-100 text-slate-400 transition group-hover:bg-red-600 group-hover:text-white dark:bg-slate-800 dark:group-hover:bg-red-500">
                    <%= icon_svg(:arrow_right, classes: "h-3.5 w-3.5") %>
                  </span>
                <% end %>
              <% end %>
            </div>
          </section>
        </div>
      </article>
    </div>

    <aside class="space-y-4">
      <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <h3 class="text-sm font-black text-[#0F172A] dark:text-white">How it works</h3>
        <div class="mt-3 space-y-3">
          <div class="flex gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-300">1</span>
            <p class="text-sm font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1]">Question card click rawh.</p>
          </div>
          <div class="flex gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-300">2</span>
            <p class="text-sm font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1]">AI chuan i role leh portal context a en ang.</p>
          </div>
          <div class="flex gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-300">3</span>
            <p class="text-sm font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1]">Step-by-step answer i hmu ang.</p>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-red-100 bg-red-50 p-4 dark:border-red-500/20 dark:bg-red-500/10">
        <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">Safe Use</p>
        <p class="mt-2 text-sm font-semibold leading-6 text-red-900 dark:text-red-100">
          AI answer chu help guide a ni. Payment paid confirmation, private welfare decision, leh official approval chu portal record leh Office Bearer confirmation hmang chauh tur a ni.
        </p>
      </section>
    </aside>
  </section>
</div>
