<% content_for :page_title, "Welfare Request" %>
<% welfare_case_policy = policy(@welfare_case) %>
<% welfare_case_actions = capture do %>
  <div class="grid w-full <%= welfare_case_policy.edit? ? 'grid-cols-2' : 'grid-cols-1' %> gap-2 sm:flex sm:w-auto">
    <%= link_to welfare_cases_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>My Requests</span>
    <% end %>
    <% if welfare_case_policy.edit? %>
      <%= link_to edit_welfare_case_path(@welfare_case), class: action_button_classes(:dark, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:edit, classes: "h-4 w-4") %>
        <span>Edit Request</span>
      <% end %>
    <% end %>
  </div>
<% end %>

<div class="space-y-4 sm:space-y-6">
  <%= render "shared/page_header",
    eyebrow: "Member support",
    title: @welfare_case.title,
    subtitle: "#{@welfare_case.welfare_category.name} · submitted #{@welfare_case.submitted_at.strftime("%b %d, %Y")}",
    actions: welfare_case_actions %>

  <section class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_20rem]">
    <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:p-6">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <div class="flex flex-wrap items-center gap-2">
            <span class="rounded-full bg-red-50 px-2.5 py-1 text-xs font-black uppercase tracking-wide text-red-700 dark:bg-red-500/15 dark:text-red-200"><%= @welfare_case.welfare_category.name %></span>
            <span class="text-xs font-black text-slate-400 dark:text-slate-500">Case #<%= @welfare_case.id %></span>
          </div>
          <h2 class="mt-3 text-xl font-black leading-7 text-slate-950 dark:text-white"><%= @welfare_case.title %></h2>
        </div>
        <%= render "shared/status_badge", status: @welfare_case.status %>
      </div>

      <dl class="mt-4 grid grid-cols-2 gap-2 text-xs sm:grid-cols-3">
        <div class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 dark:border-slate-700 dark:bg-slate-900">
          <dt class="font-black uppercase tracking-wide text-slate-400">Urgency</dt>
          <dd class="mt-0.5 font-black text-slate-950 dark:text-white"><%= @welfare_case.priority.humanize %></dd>
        </div>
        <div class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 dark:border-slate-700 dark:bg-slate-900">
          <dt class="font-black uppercase tracking-wide text-slate-400">Submitted</dt>
          <dd class="mt-0.5 font-black text-slate-950 dark:text-white"><%= @welfare_case.submitted_at.strftime("%b %d, %Y") %></dd>
        </div>
        <div class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 dark:border-slate-700 dark:bg-slate-900">
          <dt class="font-black uppercase tracking-wide text-slate-400">Office Bearer</dt>
          <dd class="mt-0.5 truncate font-black text-slate-950 dark:text-white"><%= @welfare_case.assigned_to&.display_name || "Not assigned" %></dd>
        </div>
      </dl>

      <div class="mt-4 rounded-2xl border border-slate-100 bg-slate-50 p-4 whitespace-pre-line text-sm font-semibold leading-6 text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200"><%= @welfare_case.description %></div>
    </article>

    <aside class="space-y-3">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="text-sm font-black text-slate-950 dark:text-white">Request status</h3>
        <dl class="mt-4 space-y-3 text-sm">
          <div>
            <dt class="font-black uppercase tracking-wide text-slate-400">Submitted</dt>
            <dd class="mt-1 font-black text-slate-950 dark:text-white"><%= @welfare_case.submitted_at.strftime("%b %d, %Y %H:%M") %></dd>
          </div>
          <div>
            <dt class="font-black uppercase tracking-wide text-slate-400">Office Bearer</dt>
            <dd class="mt-1 font-black text-slate-950 dark:text-white"><%= @welfare_case.assigned_to&.display_name || "Not assigned yet" %></dd>
          </div>
          <div>
            <dt class="font-black uppercase tracking-wide text-slate-400">Resolved</dt>
            <dd class="mt-1 font-black text-slate-950 dark:text-white"><%= @welfare_case.resolved_at&.strftime("%b %d, %Y") || "Not resolved" %></dd>
          </div>
        </dl>

        <% if @welfare_case.closed? %>
          <div class="mt-4 flex items-start gap-2 rounded-xl border border-slate-200 bg-slate-50 p-3 text-xs font-semibold leading-5 text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
            <span class="mt-0.5 shrink-0 text-slate-500 dark:text-slate-400"><%= icon_svg(:lock, classes: "h-4 w-4") %></span>
            <p>This request is closed. Its details are now read-only.</p>
          </div>
        <% elsif !welfare_case_policy.edit? %>
          <div class="mt-4 flex items-start gap-2 rounded-xl border border-amber-200 bg-amber-50 p-3 text-xs font-semibold leading-5 text-amber-800 dark:border-amber-500/30 dark:bg-amber-500/10 dark:text-amber-200">
            <span class="mt-0.5 shrink-0"><%= icon_svg(:clock, classes: "h-4 w-4") %></span>
            <p>An Office Bearer is reviewing this request. Details cannot be changed during review.</p>
          </div>
        <% end %>
      </div>

      <div class="rounded-2xl border border-red-100 bg-red-50 p-4 text-sm font-semibold text-red-900 shadow-sm dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-100">
        <p class="flex items-center gap-2 font-black"><%= icon_svg(:lock, classes: "h-4 w-4") %><span>Privacy note</span></p>
        <p class="mt-1 leading-5 text-red-800 dark:text-red-100/80">Your request details are visible only to authorized Office Bearers.</p>
      </div>
    </aside>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:p-5">
    <h3 class="text-base font-black text-slate-950 dark:text-white">Attachments</h3>
    <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
      <% @welfare_case.welfare_attachments.each do |attachment| %>
        <%= link_to rails_blob_path(attachment.file, disposition: "attachment"), class: "rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm font-bold text-slate-700 transition hover:border-red-100 hover:bg-white dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-red-500/30" do %>
          <span class="flex items-center gap-2 font-black text-slate-950 dark:text-white"><%= icon_svg(:paperclip, classes: "h-4 w-4 text-red-700 dark:text-red-300") %><span class="truncate"><%= attachment.file.filename %></span></span>
          <span class="mt-1 block text-slate-500 dark:text-slate-400"><%= attachment.file_extension.upcase %> · <%= formatted_file_size(attachment) %></span>
        <% end %>
      <% end %>
      <% if @welfare_case.welfare_attachments.empty? %>
        <div class="rounded-xl border border-dashed border-slate-200 bg-slate-50 p-4 text-sm font-semibold text-slate-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-400">
          No attachments uploaded.
        </div>
      <% end %>
    </div>
  </section>
</div>
