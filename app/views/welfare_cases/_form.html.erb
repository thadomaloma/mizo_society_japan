<%= form_with model: welfare_case, class: "space-y-5 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm" do |form| %>
  <% if welfare_case.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-700">
      <%= welfare_case.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-bold text-gray-700" %>
    <%= form.text_field :title, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :welfare_category_id, "Category", class: "block text-sm font-bold text-gray-700" %>
      <%= form.collection_select :welfare_category_id, @welfare_categories, :id, :name, { prompt: "Choose category" }, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div>
      <%= form.label :priority, class: "block text-sm font-bold text-gray-700" %>
      <%= form.select :priority, WelfareCase.priorities.keys.map { |priority| [ priority.humanize, priority ] }, {}, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-bold text-gray-700" %>
    <%= form.text_area :description, rows: 7, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
  </div>

  <div>
    <%= form.label :files, "Attachments", class: "block text-sm font-bold text-gray-700" %>
    <%= form.file_field :files, multiple: true, direct_upload: false, accept: ".pdf,.jpg,.jpeg,.png", class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-700 shadow-sm file:mr-4 file:rounded-lg file:border-0 file:bg-gray-950 file:px-3 file:py-2 file:text-sm file:font-black file:text-white" %>
    <p class="mt-2 text-xs font-semibold text-gray-500">PDF, JPG, and PNG only.</p>
  </div>

  <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
    <%= link_to(welfare_case.persisted? ? welfare_case_path(welfare_case) : welfare_cases_path, class: action_button_classes(:secondary)) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Cancel</span>
    <% end %>
    <%= form.button type: :submit, class: action_button_classes(:primary) do %>
      <%= icon_svg(welfare_case.persisted? ? :save : :upload, classes: "h-4 w-4") %>
      <span><%= welfare_case.persisted? ? "Update Request" : "Submit Request" %></span>
    <% end %>
  </div>
<% end %>
