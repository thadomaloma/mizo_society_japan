<% input_classes = "mt-2 block w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm font-semibold text-slate-950 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-slate-600 dark:bg-slate-900 dark:text-white dark:focus:border-red-500 dark:focus:ring-red-500/20" %>
<% label_classes = "block text-sm font-black text-slate-800 dark:text-slate-100" %>
<% hint_classes = "mt-1 text-xs font-semibold leading-5 text-slate-500 dark:text-slate-400" %>

<%= form_with model: welfare_case, class: "space-y-4" do |form| %>
  <% if welfare_case.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-100">
      <%= welfare_case.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <section class="rounded-2xl border border-red-100 bg-red-50 p-4 text-sm font-semibold text-red-900 shadow-sm dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-100">
    <div class="flex gap-3">
      <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-700 text-white dark:bg-red-600"><%= icon_svg(:lock, classes: "h-5 w-5") %></span>
      <div>
        <p class="font-black">Confidential welfare support</p>
        <p class="mt-1 leading-5 text-red-800 dark:text-red-100/80">Please share only what is needed. Authorized MSJ officers will review your request privately.</p>
      </div>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:p-5">
    <div>
      <%= form.label :title, "Request title", class: label_classes %>
      <%= form.text_field :title, placeholder: "Example: Medical support request", class: input_classes %>
      <p class="<%= hint_classes %>">Use a short title so the team can understand the request quickly.</p>
    </div>

    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div>
        <%= form.label :welfare_category_id, "Support type", class: label_classes %>
        <%= form.collection_select :welfare_category_id, @welfare_categories, :id, :name, { prompt: "Choose support type" }, class: input_classes %>
        <p class="<%= hint_classes %>">Choose the closest category.</p>
      </div>

      <div>
        <%= form.label :priority, "Urgency", class: label_classes %>
        <%= form.select :priority, WelfareCase.priorities.keys.map { |priority| [ priority.humanize, priority ] }, {}, class: input_classes %>
        <p class="<%= hint_classes %>">Use urgent only when immediate attention is needed.</p>
      </div>
    </div>

    <div class="mt-4">
      <%= form.label :description, "What support do you need?", class: label_classes %>
      <%= form.text_area :description, rows: 6, placeholder: "Write the details here. Include dates, amount, or background only if useful.", class: input_classes %>
      <p class="<%= hint_classes %>">This message is private to authorized welfare officers.</p>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:p-5">
    <%= form.label :files, "Attachments (optional)", class: label_classes %>
    <%= form.file_field :files, multiple: true, direct_upload: false, accept: ".pdf,.jpg,.jpeg,.png", class: "mt-2 block w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm file:mr-3 file:rounded-lg file:border-0 file:bg-slate-950 file:px-3 file:py-2 file:text-xs file:font-black file:text-white dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200 dark:file:bg-slate-700" %>
    <p class="<%= hint_classes %>">Upload PDF, JPG, or PNG only if it helps explain the request.</p>
  </section>

  <div class="sticky bottom-[calc(env(safe-area-inset-bottom)+4.85rem)] z-20 -mx-4 border-t border-slate-200 bg-slate-50/95 px-4 py-3 shadow-[0_-12px_30px_rgba(15,23,42,0.08)] backdrop-blur dark:border-slate-700 dark:bg-slate-950/95 sm:bottom-0 sm:mx-0 sm:rounded-2xl sm:border sm:bg-white/95 sm:shadow-lg sm:dark:bg-slate-900/95">
    <div class="grid grid-cols-2 gap-2 sm:flex sm:justify-end">
    <%= link_to(welfare_case.persisted? ? welfare_case_path(welfare_case) : welfare_cases_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3")) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Cancel</span>
    <% end %>
    <%= form.button type: :submit, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
      <%= icon_svg(welfare_case.persisted? ? :save : :upload, classes: "h-4 w-4") %>
      <span><%= welfare_case.persisted? ? "Update Request" : "Submit Request" %></span>
    <% end %>
    </div>
  </div>
<% end %>
