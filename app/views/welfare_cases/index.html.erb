<% content_for :page_title, "My Welfare Requests" %>

<div class="space-y-4 sm:space-y-6">
  <% welfare_actions = link_to(new_welfare_case_path, class: action_button_classes(:primary, size: :sm, extra: "px-3")) { safe_join([ icon_svg(:plus, classes: "h-4 w-4"), tag.span("Request Support") ]) } %>

  <%= render "shared/page_header",
    eyebrow: "Member support",
    title: "Welfare Support",
    subtitle: "Send a private support request and track the response from MSJ officers.",
    actions: welfare_actions %>

  <section class="grid gap-3 sm:grid-cols-3">
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
      <div class="flex items-center gap-3">
        <span class="grid h-10 w-10 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-300"><%= icon_svg(:welfare, classes: "h-5 w-5") %></span>
        <div>
          <p class="text-xs font-black uppercase tracking-wide text-slate-500 dark:text-slate-400">Open requests</p>
          <p class="mt-0.5 text-2xl font-black text-slate-950 dark:text-white"><%= @welfare_cases.count(&:open?) %></p>
        </div>
      </div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
      <div class="flex items-center gap-3">
        <span class="grid h-10 w-10 place-items-center rounded-xl bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300"><%= icon_svg(:check, classes: "h-5 w-5") %></span>
        <div>
          <p class="text-xs font-black uppercase tracking-wide text-slate-500 dark:text-slate-400">Resolved</p>
          <p class="mt-0.5 text-2xl font-black text-slate-950 dark:text-white"><%= @welfare_cases.count(&:resolved?) %></p>
        </div>
      </div>
    </div>
    <div class="rounded-2xl border border-red-100 bg-red-50 p-4 text-sm font-semibold text-red-900 shadow-sm dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-100">
      <p class="font-black">Private by default</p>
      <p class="mt-1 leading-5 text-red-800 dark:text-red-100/80">Only authorized MSJ officers can review your request details.</p>
    </div>
  </section>

  <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_20rem]">
    <div class="space-y-4">
      <%= form_with url: welfare_cases_path, method: :get, class: "flex items-center gap-2 rounded-2xl border border-slate-200 bg-white p-2 shadow-sm dark:border-slate-700 dark:bg-slate-800" do |form| %>
        <%= form.select :status, options_for_select([ [ "All statuses", "" ] ] + WelfareCase.statuses.keys.map { |status| [ status.humanize, status ] }, @status), {}, class: "min-w-0 flex-1 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-bold text-slate-900 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-slate-600 dark:bg-slate-900 dark:text-white" %>
        <%= form.button type: :submit, class: action_button_classes(:dark, size: :sm, extra: "px-3") do %>
          <%= icon_svg(:filter, classes: "h-4 w-4") %>
          <span>Filter</span>
        <% end %>
      <% end %>

      <% if @welfare_cases.any? %>
        <div class="grid gap-3 md:grid-cols-2">
          <%= render partial: "case_card", collection: @welfare_cases, as: :welfare_case %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No welfare requests yet", message: "Use Request Support when you need confidential help from MSJ." %>
      <% end %>
    </div>

    <aside class="space-y-3">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h2 class="text-sm font-black text-slate-950 dark:text-white">How it works</h2>
        <div class="mt-4 space-y-3 text-sm font-semibold text-slate-600 dark:text-slate-300">
          <div class="flex gap-3">
            <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full bg-red-100 text-xs font-black text-red-700 dark:bg-red-500/20 dark:text-red-200">1</span>
            <p>Submit only the details you are comfortable sharing.</p>
          </div>
          <div class="flex gap-3">
            <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full bg-red-100 text-xs font-black text-red-700 dark:bg-red-500/20 dark:text-red-200">2</span>
            <p>An authorized officer reviews the request privately.</p>
          </div>
          <div class="flex gap-3">
            <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full bg-red-100 text-xs font-black text-red-700 dark:bg-red-500/20 dark:text-red-200">3</span>
            <p>You can track the status from this page.</p>
          </div>
        </div>
      </div>
    </aside>
  </div>
</div>
