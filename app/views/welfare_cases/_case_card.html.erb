<article class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm transition hover:-translate-y-0.5 hover:border-red-100 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-red-500/30 sm:p-4">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <div class="flex min-w-0 flex-wrap items-center gap-1.5">
        <span class="rounded-full bg-red-50 px-2 py-0.5 text-[10px] font-black uppercase tracking-wide text-red-700 dark:bg-red-500/15 dark:text-red-200"><%= welfare_case.welfare_category.name %></span>
        <span class="text-[11px] font-black text-slate-400 dark:text-slate-500">#<%= welfare_case.id %></span>
      </div>
      <h3 class="mt-2 line-clamp-2 text-[15px] font-black leading-5 text-slate-950 dark:text-white sm:text-base"><%= welfare_case.title %></h3>
      <p class="mt-1 line-clamp-2 text-xs font-semibold leading-5 text-slate-500 dark:text-slate-400"><%= welfare_case.description %></p>
    </div>
    <span class="shrink-0"><%= render "shared/status_badge", status: welfare_case.status, compact: true %></span>
  </div>

  <dl class="mt-3 grid grid-cols-2 gap-2 text-xs sm:mt-4">
    <div class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 dark:border-slate-700 dark:bg-slate-900">
      <dt class="font-black uppercase tracking-wide text-slate-400">Urgency</dt>
      <dd class="mt-0.5 font-black text-slate-950 dark:text-white"><%= welfare_case.priority.humanize %></dd>
    </div>
    <div class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 dark:border-slate-700 dark:bg-slate-900">
      <dt class="font-black uppercase tracking-wide text-slate-400">Submitted</dt>
      <dd class="mt-0.5 font-black text-slate-950 dark:text-white"><%= welfare_case.submitted_at.strftime("%b %d, %Y") %></dd>
    </div>
  </dl>

  <div class="mt-3 <%= policy(welfare_case).edit? ? 'grid grid-cols-2 gap-2' : 'flex' %> sm:mt-4">
    <%= link_to welfare_case_path(welfare_case), class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2") do %>
      <%= icon_svg(:eye, classes: "h-4 w-4") %>
      <span>Details</span>
    <% end %>
    <% if policy(welfare_case).edit? %>
      <%= link_to edit_welfare_case_path(welfare_case), class: action_button_classes(:dark, size: :sm, full_width: true, extra: "px-2") do %>
        <%= icon_svg(:edit, classes: "h-4 w-4") %>
        <span>Edit</span>
      <% end %>
    <% end %>
  </div>
</article>
