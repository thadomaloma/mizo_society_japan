<article class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-xs font-bold uppercase tracking-wide text-red-700"><%= welfare_case.welfare_category.name %></p>
      <h3 class="mt-2 font-black text-gray-950"><%= welfare_case.title %></h3>
    </div>
    <%= render "shared/status_badge", status: welfare_case.status %>
  </div>

  <dl class="mt-5 grid grid-cols-2 gap-3 text-sm">
    <div>
      <dt class="font-bold text-gray-400">Priority</dt>
      <dd class="mt-1 font-black text-gray-950"><%= welfare_case.priority.humanize %></dd>
    </div>
    <div>
      <dt class="font-bold text-gray-400">Submitted</dt>
      <dd class="mt-1 font-black text-gray-950"><%= welfare_case.submitted_at.strftime("%b %d, %Y") %></dd>
    </div>
  </dl>

  <div class="mt-5 grid grid-cols-2 gap-2">
    <%= link_to welfare_case_path(welfare_case), class: action_button_classes(:secondary, full_width: true) do %>
      <%= icon_svg(:eye, classes: "h-4 w-4") %>
      <span>View</span>
    <% end %>
    <% if policy(welfare_case).edit? %>
      <%= link_to edit_welfare_case_path(welfare_case), class: action_button_classes(:dark, full_width: true) do %>
        <%= icon_svg(:edit, classes: "h-4 w-4") %>
        <span>Edit</span>
      <% end %>
    <% else %>
      <span class="inline-flex items-center justify-center gap-2 rounded-lg bg-gray-100 px-3 py-2 text-center text-sm font-black text-gray-400">
        <%= icon_svg(:lock, classes: "h-4 w-4") %>
        <span>Locked</span>
      </span>
    <% end %>
  </div>
</article>
