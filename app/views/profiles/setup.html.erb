<% content_for :page_title, "Complete Profile" %>

<div class="mx-auto max-w-3xl space-y-4">
  <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="flex items-start gap-3">
      <div class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300">
        <%= icon_svg(:user_plus, classes: "h-5 w-5") %>
      </div>
      <div class="min-w-0">
        <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-400">Member Onboarding</p>
        <h1 class="mt-1 text-xl font-black tracking-tight text-[#0F172A] dark:text-[#F8FAFC]">Complete your member profile</h1>
        <p class="mt-1 text-sm font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1]">
          Add your contact and address details to continue.
        </p>
      </div>
    </div>
  </section>

  <%= render "form", member_profile: @member_profile, setup_mode: true %>
</div>
