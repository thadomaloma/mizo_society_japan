<div class="grid grid-cols-12 gap-x-2.5 gap-y-4 rounded-xl border border-slate-200 bg-slate-50/70 p-3 shadow-sm shadow-slate-950/[0.02] sm:gap-x-3 sm:p-4 dark:border-[#334155] dark:bg-[#0F172A]/55 dark:shadow-none" data-family-details-target="childRow">
  <%= child_form.hidden_field :relationship, value: "Child" %>
  <%= child_form.hidden_field :_destroy, value: "0", data: { family_details_target: "destroyInput" } %>

  <div class="col-span-12 min-w-0 sm:col-span-6">
    <%= child_form.label :name, "Child Name", class: "mb-2 block text-sm font-bold leading-5 text-[#334155] dark:text-[#CBD5E1]" %>
    <%= child_form.text_field :name,
      placeholder: "Enter child's full name",
      autocomplete: "off",
      class: "block h-11 w-full min-w-0 rounded-lg border border-[#CBD5E1] bg-white px-3 text-sm font-semibold text-[#0F172A] shadow-sm shadow-slate-950/[0.03] outline-none transition placeholder:font-medium placeholder:text-slate-400 hover:border-slate-400 focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#1E293B] dark:text-[#F8FAFC] dark:shadow-none dark:placeholder:text-slate-500 dark:hover:border-slate-500 dark:focus:border-red-500 dark:focus:ring-red-500/20" %>
  </div>

  <%= render "profiles/child_date_of_birth_fields", child_form: child_form %>

  <div class="col-span-12 flex min-w-0 justify-end border-t border-slate-200 pt-3 dark:border-[#334155]">
    <% if child_form.object.persisted? && child_form.object.membership_payments.exists? %>
      <span class="inline-flex h-8 items-center gap-1.5 rounded-lg bg-slate-100 px-2.5 text-xs font-bold text-slate-500 dark:bg-[#1E293B] dark:text-slate-400" title="This child has payment history and cannot be removed" aria-label="Child cannot be removed because payment history exists">
        <%= icon_svg(:lock, classes: "h-3.5 w-3.5") %>
        <span>Cannot remove</span>
      </span>
    <% else %>
      <button type="button" class="inline-flex h-8 items-center justify-center gap-1.5 rounded-lg px-2.5 text-xs font-bold text-red-600 transition hover:bg-red-100 hover:text-red-700 focus:outline-none focus:ring-2 focus:ring-red-500/30 focus:ring-offset-1 active:scale-[0.98] dark:text-red-300 dark:hover:bg-red-500/10 dark:hover:text-red-200 dark:focus:ring-offset-[#0F172A]" data-action="family-details#removeChild" aria-label="Remove child" title="Remove child">
        <%= icon_svg(:trash, classes: "h-3.5 w-3.5") %>
        <span>Remove child</span>
      </button>
    <% end %>
  </div>
</div>
