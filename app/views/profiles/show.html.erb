<% content_for :page_title, "My Profile" %>

<div class="mx-auto max-w-6xl space-y-5">
  <section class="overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="h-2 bg-red-600"></div>
    <div class="grid gap-5 p-4 sm:p-5 lg:grid-cols-[1fr_18rem] lg:items-center">
      <div class="flex min-w-0 items-start gap-4">
        <div class="grid h-16 w-16 shrink-0 place-items-center overflow-hidden rounded-2xl bg-red-50 text-xl font-black text-red-700 ring-1 ring-red-100 dark:bg-red-500/10 dark:text-red-300 dark:ring-red-500/20 sm:h-20 sm:w-20">
          <% if @member_profile.avatar.attached? %>
            <%= image_tag @member_profile.avatar, class: "h-full w-full object-cover", alt: @member_profile.full_name, loading: "lazy", decoding: "async" %>
          <% else %>
            <%= @member_profile.full_name.first&.upcase || "M" %>
          <% end %>
        </div>

        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-2">
            <h1 class="truncate text-[1.35rem] font-black leading-7 text-[#0F172A] dark:text-[#F8FAFC] sm:text-2xl"><%= @member_profile.full_name %></h1>
            <%= render "shared/status_badge", status: @member_profile.status, compact: true %>
          </div>
          <p class="mt-1 text-[13px] font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1] sm:text-sm"><%= @member_profile.membership_number %> · <%= role_label(current_user.role) %></p>

          <div class="mt-4 flex flex-wrap gap-2">
            <%= link_to edit_profile_path, class: action_button_classes(:primary, size: :sm) do %>
              <%= icon_svg(:edit, classes: "h-4 w-4") %>
              <span>Edit Profile</span>
            <% end %>
          </div>
        </div>
      </div>

      <aside class="rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-4 dark:border-[#334155] dark:bg-[#0F172A]">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-400">Completion</p>
            <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= @member_profile.complete? ? "Profile is ready." : "Some details are missing." %></p>
          </div>
          <p class="text-2xl font-black text-[#0F172A] dark:text-[#F8FAFC] sm:text-3xl"><%= @member_profile.profile_completion_percentage %>%</p>
        </div>
        <div class="mt-3 h-2 overflow-hidden rounded-full bg-slate-200 dark:bg-[#334155]">
          <div class="h-full rounded-full bg-red-600" style="width: <%= @member_profile.profile_completion_percentage %>%"></div>
        </div>
        <% unless @member_profile.complete? %>
          <%= link_to setup_profile_path, class: "#{action_button_classes(:primary, size: :xs, full_width: true)} mt-3" do %>
            <%= icon_svg(:edit, classes: "h-3.5 w-3.5") %>
            <span>Complete Profile</span>
          <% end %>
        <% end %>
      </aside>
    </div>
  </section>

  <section class="grid gap-5 lg:grid-cols-[1fr_24rem]">
    <div class="space-y-5">
      <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5">
        <div class="mb-4 flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300"><%= icon_svg(:members, classes: "h-5 w-5") %></span>
          <div>
            <h2 class="text-base font-black text-[#0F172A] dark:text-[#F8FAFC]">Personal Details</h2>
            <p class="text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Basic member information.</p>
          </div>
        </div>

        <dl class="grid gap-3 sm:grid-cols-2">
          <% [
            [ "Mobile Number", @member_profile.mobile_number ],
            [ "Gender", @member_profile.gender&.humanize || "Not set" ],
            [ "Date of Birth", @member_profile.date_of_birth&.strftime("%b %d, %Y") || "Not set" ],
            [ "Joined On", @member_profile.joined_on&.strftime("%b %d, %Y") || "Not set" ]
          ].each do |label, value| %>
            <div class="rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
              <dt class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= label %></dt>
              <dd class="mt-1 break-words text-[15px] font-black leading-5 text-[#0F172A] dark:text-[#F8FAFC] sm:text-sm"><%= value %></dd>
            </div>
          <% end %>
        </dl>
      </section>

      <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5">
        <div class="mb-4 flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300"><%= icon_svg(:members, classes: "h-5 w-5") %></span>
          <div>
            <h2 class="text-base font-black text-[#0F172A] dark:text-[#F8FAFC]">Family Details</h2>
            <p class="text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Parent and household information.</p>
          </div>
        </div>

        <dl class="grid gap-3 sm:grid-cols-2">
          <% [
            [ "Father's Name", @member_profile.father_name.presence || "Not set" ],
            [ "Mother's Name", @member_profile.mother_name.presence || "Not set" ],
            [ "Family Status", @member_profile.family_status.humanize ],
            [ "Spouse Name", @member_profile.family? ? (@member_profile.spouse_name.presence || "Not set") : "Not applicable" ]
          ].each do |label, value| %>
            <div class="rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
              <dt class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= label %></dt>
              <dd class="mt-1 break-words text-[15px] font-black leading-5 text-[#0F172A] dark:text-[#F8FAFC] sm:text-sm"><%= value %></dd>
            </div>
          <% end %>
        </dl>

        <% if @member_profile.family? %>
          <div class="mt-4 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
            <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Children</p>
            <% if @member_profile.child_family_members.any? %>
              <div class="mt-2 flex flex-wrap gap-2">
                <% @member_profile.child_family_members.each_with_index do |child, index| %>
                  <span class="rounded-lg bg-white px-2.5 py-1 text-xs font-black text-[#0F172A] ring-1 ring-[#E2E8F0] dark:bg-[#1E293B] dark:text-[#F8FAFC] dark:ring-[#334155]"><%= index + 1 %>. <%= child.name %></span>
                <% end %>
              </div>
            <% else %>
              <p class="mt-1 text-sm font-black text-[#0F172A] dark:text-[#F8FAFC]">Not set</p>
            <% end %>
          </div>
        <% end %>
      </section>
    </div>

    <aside class="space-y-5">
      <section class="overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <div class="border-b border-[#E2E8F0] p-4 dark:border-[#334155]">
          <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-400">Google Map</p>
          <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Address</p>
          <p class="mt-1 text-sm font-black leading-6 text-[#0F172A] dark:text-[#F8FAFC]"><%= @member_profile.full_address %></p>
        </div>
        <iframe
          title="Profile address map"
          src="<%= google_maps_embed_url_for(@member_profile) %>"
          class="h-64 w-full border-0 sm:h-72 lg:h-80"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </section>
    </aside>
  </section>
</div>
