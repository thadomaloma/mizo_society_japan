<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "MSJ Payment Receipt" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="payment-receipt-body bg-slate-100 text-slate-950 antialiased">
    <%= yield %>
  </body>
</html>
