<% content_for :page_title, "Official Notices" %>

<div class="space-y-6">
  <% actions = capture do %>
    <%= link_to events_path, class: action_button_classes(:secondary) do %><%= icon_svg(:events, classes: "h-4 w-4") %><span>Updates</span><% end %>
    <% if policy(Announcement).create? %>
      <%= link_to new_announcement_path, class: action_button_classes(:primary) do %><%= icon_svg(:plus, classes: "h-4 w-4") %><span>New Notice</span><% end %>
    <% end %>
  <% end %>

  <%= render "shared/page_header", eyebrow: "Updates", title: "Official Notices", subtitle: "Important announcements and society messages.", actions: actions %>

  <%= form_with url: announcements_path, method: :get, class: "flex flex-col gap-3 rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm sm:flex-row sm:items-end sm:justify-between dark:border-[#334155] dark:bg-[#1E293B]" do |form| %>
    <div class="flex min-w-0 flex-1 flex-col gap-3 sm:flex-row">
      <%= form.search_field :query, value: @query, placeholder: "Search notices...", class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:max-w-sm dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      <%= form.select :category, options_for_select([ [ "All categories", "" ] ] + Announcement.categories.keys.map { |category| [ category.humanize, category ] }, @category), {}, class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:w-40 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      <% if current_user.content_admin? %>
        <%= form.select :status, options_for_select([ [ "All statuses", "" ] ] + Announcement.statuses.keys.map { |status| [ status.humanize, status ] }, @status), {}, class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:w-36 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      <% end %>
    </div>
    <%= form.button type: :submit, class: action_button_classes(:dark, size: :sm) do %><%= icon_svg(:filter, classes: "h-4 w-4") %><span>Filter</span><% end %>
    <% end %>

  <% if @announcements.any? %>
    <div class="space-y-3">
      <% @announcements.each do |announcement| %>
        <article class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm transition hover:border-red-200 hover:shadow-md dark:border-[#334155] dark:bg-[#1E293B] dark:hover:border-red-400/40">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2"><% if announcement.pinned? %><span class="rounded-full bg-red-100 px-2.5 py-1 text-xs font-black text-red-700 dark:bg-red-500/20 dark:text-red-200">Pinned</span><% end %><span class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= announcement.category.humanize %></span><%= render "shared/status_badge", status: announcement.status if current_user.content_admin? %></div>
              <h2 class="mt-2 text-lg font-black text-[#0F172A] dark:text-white"><%= link_to announcement.title, announcement, class: "hover:text-red-700 dark:hover:text-red-300" %></h2>
              <p class="mt-2 line-clamp-2 text-sm font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1]"><%= announcement.body %></p>
            </div>
            <% unless announcement.read_by?(current_user) %><span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-red-600" title="Unread"></span><% end %>
          </div>
          <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-[#E2E8F0] pt-3 text-xs font-semibold text-[#64748B] dark:border-[#334155] dark:text-[#CBD5E1]"><span><%= announcement.published_at&.strftime("%d %b %Y") || "Draft" %> · <%= announcement.author.name %></span><%= link_to "Read notice", announcement, class: "font-black text-red-700 hover:text-red-800 dark:text-red-300" %></div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No notices found", message: "There are no notices matching your filters." %>
  <% end %>
</div>
