<%= form_with model: announcement, class: "space-y-5" do |form| %>
  <% if announcement.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-200"><%= announcement.errors.full_messages.to_sentence %></div>
  <% end %>

  <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="md:col-span-2">
        <%= form.label :title, class: "text-sm font-black text-[#0F172A] dark:text-white" do %>Announcement Title <span class="text-red-600">*</span><% end %>
        <%= form.text_field :title, required: true, placeholder: "e.g. MSJ Annual General Meeting", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      </div>
      <div>
        <%= form.label :category, "Category", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
        <%= form.select :category, Announcement.categories.keys.map { |category| [ category.humanize, category ] }, {}, class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      </div>
      <div>
        <%= form.label :expires_at, "Expiry Date", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
        <%= form.datetime_local_field :expires_at, class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      </div>
      <div class="md:col-span-2">
        <%= form.label :body, class: "text-sm font-black text-[#0F172A] dark:text-white" do %>Message <span class="text-red-600">*</span><% end %>
        <%= form.text_area :body, required: true, rows: 9, placeholder: "Write the announcement members need to know.", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold leading-6 text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      </div>
      <div class="md:col-span-2 rounded-xl border border-[#E2E8F0] bg-slate-50 px-4 py-3 dark:border-[#334155] dark:bg-[#0F172A]">
        <label class="flex items-center gap-3 text-sm font-black text-[#0F172A] dark:text-white"><%= form.check_box :pinned, class: "h-5 w-5 rounded border-slate-300 text-red-700 focus:ring-red-600" %> Pin this announcement at the top</label>
        <p class="mt-1 pl-8 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Use this only for important notices that members should see first.</p>
      </div>
    </div>
  </section>

  <div class="flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
    <%= link_to announcements_path, class: action_button_classes(:secondary) do %><%= icon_svg(:arrow_left, classes: "h-4 w-4") %><span>Cancel</span><% end %>
    <%= form.button type: :submit, class: action_button_classes(:primary) do %><%= icon_svg(:save, classes: "h-4 w-4") %><span><%= announcement.persisted? ? "Update Announcement" : "Save Draft" %></span><% end %>
  </div>
<% end %>
