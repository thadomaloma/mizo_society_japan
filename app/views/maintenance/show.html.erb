<main class="flex min-h-screen items-center justify-center px-4 py-10">
  <section class="w-full max-w-lg rounded-2xl border border-[#334155] bg-[#1E293B] p-8 text-center shadow-2xl">
    <div class="mx-auto grid h-14 w-14 place-items-center rounded-xl bg-red-500/10 text-red-300">
      <%= icon_svg(:settings, classes: "h-7 w-7") %>
    </div>
    <p class="mt-6 text-xs font-black uppercase tracking-wide text-red-300">Temporarily unavailable</p>
    <h1 class="mt-2 text-2xl font-black text-white"><%= portal_organization_name %></h1>
    <p class="mt-4 text-sm font-semibold leading-6 text-[#CBD5E1]">The portal is under maintenance. Please check back shortly.</p>
  </section>
</main>
