<% content_for :page_title, @document.title %>

<% letter = ->(key) { @document.letter_attribute(key) } %>
<% motto_lines = letter.call(:motto).to_s.split(/\r?\n/).map(&:strip).reject(&:blank?) %>

<div class="space-y-6">
  <% actions = capture do %>
    <%= link_to documents_path, class: action_button_classes(:secondary) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Back</span>
    <% end %>
    <% if @document.official_letter? %>
      <%= link_to download_letter_document_path(@document), class: action_button_classes(:secondary) do %>
        <%= icon_svg(:download, classes: "h-4 w-4") %>
        <span>Download DOCX</span>
      <% end %>
    <% end %>
    <% if @document.published? && @document.file.attached? && policy(@document).download? %>
      <%= link_to download_document_path(@document), class: action_button_classes(:primary) do %>
        <%= icon_svg(:paperclip, classes: "h-4 w-4") %>
        <span>Final File</span>
      <% end %>
    <% end %>
    <% if policy(@document).update? && !(@document.draft? && !@document.file.attached?) %>
      <%= link_to edit_document_path(@document), class: action_button_classes(:secondary) do %>
        <%= icon_svg(:edit, classes: "h-4 w-4") %>
        <span>Edit</span>
      <% end %>
    <% end %>
    <% if policy(@document).publish? && @document.draft? && @document.file.attached? %>
      <%= button_to publish_document_path(@document), method: :patch, form_class: "inline-flex", class: action_button_classes(:primary) do %>
        <%= icon_svg(:upload, classes: "h-4 w-4") %>
        <span>Publish</span>
      <% end %>
    <% end %>
    <% if policy(@document).update? && @document.draft? && !@document.file.attached? %>
      <%= link_to edit_document_path(@document), class: action_button_classes(:primary) do %>
        <%= icon_svg(:upload, classes: "h-4 w-4") %>
        <span>Attach Final</span>
      <% end %>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Official Letter",
    title: @document.title,
    subtitle: @document.published_at&.strftime("Published %d %B %Y") || "Draft letter",
    actions: actions %>

  <section class="grid gap-4 lg:grid-cols-4">
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Status</p>
      <div class="mt-3"><%= render "shared/status_badge", status: @document.status %></div>
    </div>
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Visibility</p>
      <p class="mt-3 text-sm font-black text-[#0F172A] dark:text-white"><%= visibility_label(@document.visibility) %></p>
    </div>
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Reference</p>
      <p class="mt-3 truncate text-sm font-black text-[#0F172A] dark:text-white"><%= letter.call(:reference_number) %></p>
    </div>
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Final File</p>
      <p class="mt-3 truncate text-sm font-black text-[#0F172A] dark:text-white"><%= @document.file.attached? ? @document.file.filename : "Not attached yet" %></p>
    </div>
  </section>

  <% if @document.draft? && !@document.file.attached? && policy(@document).update? %>
    <section class="rounded-2xl border border-amber-200 bg-amber-50 p-4 shadow-sm dark:border-amber-500/30 dark:bg-amber-500/10">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-black text-amber-800 dark:text-amber-200">Final file is not attached yet.</p>
          <p class="mt-1 text-sm font-semibold text-amber-700 dark:text-amber-100">Download the DOCX, finalise it, then attach the final DOCX or PDF before publishing.</p>
        </div>
      </div>
    </section>
  <% end %>

  <section class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_20rem]">
    <div class="official-letter-preview-shell rounded-2xl border border-[#E2E8F0] bg-slate-100 p-3 shadow-sm dark:border-[#334155] dark:bg-[#0F172A]">
      <div class="official-letter-preview-frame mx-auto">
        <article class="official-letter-preview-page mx-auto min-h-[297mm] w-[210mm] bg-white px-[18mm] py-[16mm] font-serif text-[12px] leading-5 text-black shadow-sm">
          <header class="text-center">
            <h2 class="text-[25px] font-black leading-7 tracking-tight"><%= letter.call(:organization_name).to_s.upcase %></h2>
            <p class="text-[21px] font-black leading-6"><%= letter.call(:organization_location).to_s.upcase %></p>
          </header>

          <div class="mt-2 grid grid-cols-[1fr_auto_1fr] items-center gap-4 border-b border-black pb-2">
            <div class="text-[11px] leading-4">
              <p class="font-bold">MOTTO:</p>
              <% motto_lines.each_with_index do |line, index| %>
                <p><%= index + 1 %>. <%= line %></p>
              <% end %>
            </div>
            <div class="grid h-16 w-16 place-items-center rounded-full border border-black text-center text-[10px] font-black leading-3">MSJ<br>印</div>
            <div class="space-y-1 text-right text-[11px] leading-4">
              <p>President : <%= letter.call(:president_name) %></p>
              <p>Phone : <%= letter.call(:president_phone) %></p>
              <p>Secretary : <%= letter.call(:secretary_name) %></p>
              <p>Phone : <%= letter.call(:secretary_phone) %></p>
            </div>
          </div>

          <div class="mt-5 flex justify-between gap-8 text-[12px]">
            <p>No. <%= letter.call(:reference_number) %></p>
            <p class="text-right">Dated <%= letter.call(:dated_place) %> the <%= letter.call(:letter_date) %></p>
          </div>

          <main class="mt-8">
            <p>To</p>
            <div class="ml-24 mt-5 whitespace-pre-line"><%= letter.call(:recipient_block) %></div>
            <div class="mt-7 grid grid-cols-[5rem_1fr] gap-4 font-bold">
              <p>Subject :</p>
              <p><%= letter.call(:subject) %></p>
            </div>
            <p class="mt-6"><%= letter.call(:salutation) %></p>
            <div class="official-letter-preview-body mt-7 space-y-5 text-justify">
              <% letter.call(:body).to_s.split(/\n{2,}/).each do |paragraph| %>
                <p><%= simple_format(paragraph.strip, {}, wrapper_tag: "span") %></p>
              <% end %>
            </div>
            <div class="mt-12 ml-auto w-56 text-center">
              <p><%= letter.call(:closing) %></p>
              <div class="mt-14 font-semibold leading-5">
                <p><%= letter.call(:signer_name) %></p>
                <p><%= letter.call(:signer_title) %></p>
                <p><%= letter.call(:organization_name) %></p>
              </div>
            </div>
          </main>
        </article>
      </div>
    </div>

    <aside class="space-y-4">
      <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <h3 class="text-sm font-black text-[#0F172A] dark:text-white">Letter Details</h3>
        <dl class="mt-4 space-y-3 text-sm">
          <div>
            <dt class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Date</dt>
            <dd class="mt-1 font-bold text-[#0F172A] dark:text-white"><%= letter.call(:letter_date) %></dd>
          </div>
          <div>
            <dt class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Place</dt>
            <dd class="mt-1 font-bold text-[#0F172A] dark:text-white"><%= letter.call(:dated_place) %></dd>
          </div>
          <div>
            <dt class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Subject</dt>
            <dd class="mt-1 font-bold text-[#0F172A] dark:text-white"><%= letter.call(:subject) %></dd>
          </div>
        </dl>
      </section>

      <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <h3 class="text-sm font-black text-[#0F172A] dark:text-white">Final Copy</h3>
        <p class="mt-2 text-sm font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1]">
          <%= @document.file.attached? ? "A final file is attached and ready for download." : "No final file has been attached yet." %>
        </p>
        <% if policy(@document).archive? && @document.published? %>
          <div class="mt-4 border-t border-[#E2E8F0] pt-4 dark:border-[#334155]">
            <%= button_to archive_document_path(@document), method: :patch, form_class: "w-full", class: action_button_classes(:outline_danger, size: :xs, full_width: true) do %>
              <%= icon_svg(:documents, classes: "h-3.5 w-3.5") %>
              <span>Archive Letter</span>
            <% end %>
          </div>
        <% end %>
      </section>

      <% if @document.description.present? %>
        <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
          <h3 class="text-sm font-black text-[#0F172A] dark:text-white">Notes</h3>
          <div class="mt-3 text-sm font-semibold leading-7 text-[#64748B] dark:text-[#CBD5E1]"><%= simple_format(@document.description) %></div>
        </section>
      <% end %>
    </aside>
  </section>
</div>
