<% content_for :page_title, "Official Letters" %>

<div class="space-y-6">
  <% actions = capture do %>
    <div class="flex w-full gap-2 sm:w-auto">
      <% if @can_manage_documents %>
        <%= link_to admin_document_categories_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "flex-1 px-2 sm:w-auto sm:flex-none sm:px-3") do %>
          <%= icon_svg(:tag, classes: "h-4 w-4") %>
          <span>Categories</span>
        <% end %>
      <% end %>
      <% if policy(Document).create? %>
        <%= link_to new_document_path(letter_format: "msj"), class: action_button_classes(:primary, size: :sm, full_width: true, extra: "flex-1 px-2 sm:w-auto sm:flex-none sm:px-3") do %>
          <%= icon_svg(:plus, classes: "h-4 w-4") %>
          <span>New Letter</span>
        <% end %>
      <% end %>
    </div>
  <% end %>
  <%= render "shared/page_header", eyebrow: "Letters", title: "Official Letters", subtitle: "Prepare formal MSJ letters and keep the final copies in one place.", actions: actions %>

  <section class="grid min-w-0 gap-3">
    <div class="min-w-0 overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="grid min-w-0 gap-0 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="flex min-w-0 flex-col justify-between gap-4 border-b border-[#E2E8F0] bg-[#F8FAFC] p-4 sm:gap-6 sm:p-6 lg:border-b-0 lg:border-r dark:border-[#334155] dark:bg-[#0F172A]">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full border border-red-100 bg-white px-3 py-1 text-xs font-black uppercase tracking-wide text-red-700 shadow-sm dark:border-red-500/30 dark:bg-[#1E293B] dark:text-red-300">
              <%= icon_svg(:documents, classes: "h-3.5 w-3.5") %>
              MSJ Letterhead
            </div>
            <h2 class="mt-4 text-[1.35rem] font-black leading-7 text-[#0F172A] dark:text-white sm:text-xl">Formal letter composer</h2>
            <p class="mt-2 max-w-xl text-[13px] font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1] sm:text-sm">Create reference-numbered letters with recipient, subject, body, closing, and signature details in a consistent MSJ format.</p>
          </div>

          <div class="grid grid-cols-3 gap-2 sm:gap-3">
            <div class="rounded-xl border border-[#E2E8F0] bg-white p-3 dark:border-[#334155] dark:bg-[#1E293B]">
              <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Format</p>
              <p class="mt-1 truncate text-sm font-black text-[#0F172A] dark:text-white">Letterhead</p>
            </div>
            <div class="rounded-xl border border-[#E2E8F0] bg-white p-3 dark:border-[#334155] dark:bg-[#1E293B]">
              <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Archive</p>
              <p class="mt-1 truncate text-sm font-black text-[#0F172A] dark:text-white">Final copy</p>
            </div>
            <div class="rounded-xl border border-[#E2E8F0] bg-white p-3 dark:border-[#334155] dark:bg-[#1E293B]">
              <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Export</p>
              <p class="mt-1 truncate text-sm font-black text-[#0F172A] dark:text-white">DOCX</p>
            </div>
          </div>
        </div>

        <div class="min-w-0 p-3 sm:p-6">
          <div class="mx-auto w-full max-w-full overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white p-3 text-[10px] font-semibold leading-4 text-[#334155] shadow-sm dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1] sm:max-w-xl sm:p-5 sm:text-[11px] sm:leading-5">
            <div class="text-center">
              <p class="text-sm font-black tracking-wide text-[#0F172A] dark:text-white sm:text-base">MIZO SOCIETY OF JAPAN</p>
              <p class="text-xs font-black tracking-wide text-[#0F172A] dark:text-white sm:text-sm">TOKYO : JAPAN</p>
            </div>

            <div class="mt-3 grid min-w-0 grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-2 border-b border-t border-[#CBD5E1] py-2.5 dark:border-[#334155] sm:mt-4 sm:gap-3 sm:py-3">
              <div class="min-w-0 space-y-0.5">
                <p>Unity</p>
                <p>Culture</p>
                <p>Welfare</p>
              </div>
              <div class="grid h-10 w-10 place-items-center rounded-full border border-red-200 bg-red-50 text-[10px] font-black text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-300 sm:h-14 sm:w-14 sm:text-xs">MSJ</div>
              <div class="min-w-0 space-y-0.5 break-words text-right">
                <p>President: Name</p>
                <p>Phone: +81-XX-XXXX</p>
                <p>Secretary: Name</p>
                <p>Phone: +81-XX-XXXX</p>
              </div>
            </div>

            <div class="mt-4 flex items-start justify-between gap-4">
              <p>No. MSJ/LET/2026/001</p>
              <p class="text-right">Dated Tokyo<br class="sm:hidden"> the 29 June, 2026</p>
            </div>
            <p class="mt-5">To</p>
            <p class="ml-5 mt-2 sm:ml-8">The President/General Secretary,<br>Organization Name,<br>Address.</p>
            <p class="mt-4"><span class="font-black text-[#0F172A] dark:text-white">Subject:</span> Official communication</p>
            <p class="mt-4">Thawhpui duhtak,</p>
            <p class="mt-3 indent-8">Mizo Society of Japan hmingin chibai kan buk a che. This preview follows the official letter layout used by the portal.</p>
            <div class="mt-5 ml-auto w-36 text-center sm:mt-6 sm:w-44">
              <p>Yours faithfully,</p>
              <div class="mx-auto mt-8 h-px w-32 bg-[#CBD5E1] dark:bg-[#334155]"></div>
              <p class="mt-2 font-black text-[#0F172A] dark:text-white">Secretary</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%= form_with url: documents_path, method: :get, class: "flex flex-col gap-2 rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm sm:flex-row sm:items-end sm:justify-between sm:gap-3 sm:p-4 dark:border-[#334155] dark:bg-[#1E293B]" do |form| %>
    <div class="grid min-w-0 flex-1 grid-cols-2 gap-2 sm:flex sm:flex-row sm:gap-3">
      <%= form.search_field :query, value: @query, placeholder: "Search letters...", class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:max-w-xs dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      <%= form.select :visibility, options_for_select([ [ "All audiences", "" ] ] + Document.official_letter_visibility_options.map { |visibility| [ visibility_label(visibility), visibility ] }, @visibility), {}, class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:w-52 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      <% if @can_manage_documents %><%= form.select :status, options_for_select([ [ "All statuses", "" ] ] + Document.statuses.keys.map { |status| [ status.humanize, status ] }, @status), {}, class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:w-36 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %><% end %>
    </div>
    <%= form.button type: :submit, class: action_button_classes(:dark, size: :sm, extra: "px-3") do %><%= icon_svg(:filter, classes: "h-4 w-4") %><span>Filter</span><% end %>
  <% end %>

  <% if @documents.any? %>
    <div class="grid min-w-0 gap-2 sm:gap-4 md:grid-cols-2 xl:grid-cols-3">
      <% @documents.each do |document| %>
        <article class="min-w-0 overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm transition hover:border-red-200 hover:shadow-md dark:border-[#334155] dark:bg-[#1E293B] dark:hover:border-red-400/40 sm:p-5">
          <div class="flex min-w-0 items-start justify-between gap-2 sm:gap-3"><div class="min-w-0"><p class="truncate text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300"><%= document.document_category.name %></p><h2 class="mt-1 truncate text-base font-black leading-6 text-[#0F172A] dark:text-white sm:text-lg"><%= link_to document.title, document, class: "hover:text-red-700 dark:hover:text-red-300" %></h2></div><%= render "shared/status_badge", status: document.status, compact: true if @can_manage_documents %></div>
          <p class="mt-3 line-clamp-2 min-h-10 text-[13px] font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1] sm:min-h-12 sm:text-sm"><%= document.description.presence || "No description provided." %></p>
          <div class="mt-3 flex items-center justify-between gap-2 border-t border-[#E2E8F0] pt-3 text-[12px] font-semibold text-[#64748B] dark:border-[#334155] dark:text-[#CBD5E1] sm:mt-4 sm:gap-3 sm:text-xs">
            <span class="min-w-0 truncate"><%= visibility_label(document.visibility) %> · <%= document.file_extension.upcase.presence || "FILE" %></span>
            <div class="flex shrink-0 gap-1.5 sm:gap-2">
              <%= link_to document, class: "inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-[#E2E8F0] bg-white px-2.5 text-xs font-black text-[#0F172A] transition hover:border-red-200 hover:bg-red-50 dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#F8FAFC] dark:hover:border-red-400/40 dark:hover:bg-[#334155] sm:h-auto sm:py-1.5" do %>
                <%= icon_svg(:eye, classes: "h-3.5 w-3.5") %>
                <span>View</span>
              <% end %>
              <% if policy(document).update? %>
                <%= link_to edit_document_path(document), class: "inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-[#E2E8F0] bg-white px-2.5 text-xs font-black text-[#0F172A] transition hover:border-red-200 hover:bg-red-50 dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#F8FAFC] dark:hover:border-red-400/40 dark:hover:bg-[#334155] sm:h-auto sm:py-1.5" do %>
                  <%= icon_svg(:edit, classes: "h-3.5 w-3.5") %>
                  <span>Edit</span>
                <% end %>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No letters found", message: "No letters match your search or filters." %>
  <% end %>
</div>
