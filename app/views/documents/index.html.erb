<% content_for :page_title, "Official Letters" %>

<div class="space-y-6">
  <% actions = capture do %>
    <% if @can_manage_documents %><%= link_to admin_document_categories_path, class: action_button_classes(:secondary) do %><%= icon_svg(:tag, classes: "h-4 w-4") %><span>Categories</span><% end %><% end %>
    <% if policy(Document).create? %><%= link_to new_document_path(letter_format: "msj"), class: action_button_classes(:primary) do %><%= icon_svg(:plus, classes: "h-4 w-4") %><span>New Letter</span><% end %><% end %>
  <% end %>
  <%= render "shared/page_header", eyebrow: "Letters", title: "Official Letters", subtitle: "Prepare formal MSJ letters and keep the final copies in one place.", actions: actions %>

  <section class="grid gap-3">
    <div class="overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="grid gap-0 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="flex flex-col justify-between gap-6 border-b border-[#E2E8F0] bg-[#F8FAFC] p-5 sm:p-6 lg:border-b-0 lg:border-r dark:border-[#334155] dark:bg-[#0F172A]">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full border border-red-100 bg-white px-3 py-1 text-xs font-black uppercase tracking-wide text-red-700 shadow-sm dark:border-red-500/30 dark:bg-[#1E293B] dark:text-red-300">
              <%= icon_svg(:documents, classes: "h-3.5 w-3.5") %>
              MSJ Letterhead
            </div>
            <h2 class="mt-4 text-xl font-black tracking-tight text-[#0F172A] dark:text-white">Formal letter composer</h2>
            <p class="mt-2 max-w-xl text-sm font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1]">Create reference-numbered letters with recipient, subject, body, closing, and signature details in a consistent MSJ format.</p>
          </div>

          <div class="grid gap-3 sm:grid-cols-3">
            <div class="rounded-xl border border-[#E2E8F0] bg-white p-3 dark:border-[#334155] dark:bg-[#1E293B]">
              <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Format</p>
              <p class="mt-1 text-sm font-black text-[#0F172A] dark:text-white">Letterhead</p>
            </div>
            <div class="rounded-xl border border-[#E2E8F0] bg-white p-3 dark:border-[#334155] dark:bg-[#1E293B]">
              <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Archive</p>
              <p class="mt-1 text-sm font-black text-[#0F172A] dark:text-white">Final copy</p>
            </div>
            <div class="rounded-xl border border-[#E2E8F0] bg-white p-3 dark:border-[#334155] dark:bg-[#1E293B]">
              <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Export</p>
              <p class="mt-1 text-sm font-black text-[#0F172A] dark:text-white">DOCX</p>
            </div>
          </div>
        </div>

        <div class="p-4 sm:p-6">
          <div class="mx-auto max-w-xl rounded-2xl border border-[#E2E8F0] bg-white p-5 text-[11px] font-semibold leading-5 text-[#334155] shadow-sm dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1]">
            <div class="text-center">
              <p class="text-base font-black tracking-wide text-[#0F172A] dark:text-white">MIZO SOCIETY OF JAPAN</p>
              <p class="text-sm font-black tracking-wide text-[#0F172A] dark:text-white">TOKYO : JAPAN</p>
            </div>

            <div class="mt-4 grid grid-cols-[1fr_auto_1fr] items-center gap-3 border-b border-t border-[#CBD5E1] py-3 dark:border-[#334155]">
              <div class="space-y-0.5">
                <p>Unity</p>
                <p>Culture</p>
                <p>Welfare</p>
              </div>
              <div class="grid h-14 w-14 place-items-center rounded-full border border-red-200 bg-red-50 text-xs font-black text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-300">MSJ</div>
              <div class="space-y-0.5 text-right">
                <p>President: Name</p>
                <p>Phone: +81-XX-XXXX-XXXX</p>
                <p>Secretary: Name</p>
                <p>Phone: +81-XX-XXXX-XXXX</p>
              </div>
            </div>

            <div class="mt-4 flex items-start justify-between gap-4">
              <p>No. MSJ/LET/2026/001</p>
              <p class="text-right">Dated Tokyo<br class="sm:hidden"> the 29 June, 2026</p>
            </div>
            <p class="mt-5">To</p>
            <p class="ml-8 mt-2">The President/General Secretary,<br>Organization Name,<br>Address.</p>
            <p class="mt-4"><span class="font-black text-[#0F172A] dark:text-white">Subject:</span> Official communication</p>
            <p class="mt-4">Thawhpui duhtak,</p>
            <p class="mt-3 indent-8">Mizo Society of Japan hmingin chibai kan buk a che. This preview follows the official letter layout used by the portal.</p>
            <div class="mt-6 ml-auto w-44 text-center">
              <p>Yours faithfully,</p>
              <div class="mx-auto mt-8 h-px w-32 bg-[#CBD5E1] dark:bg-[#334155]"></div>
              <p class="mt-2 font-black text-[#0F172A] dark:text-white">Secretary</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%= form_with url: documents_path, method: :get, class: "flex flex-col gap-3 rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm sm:flex-row sm:items-end sm:justify-between dark:border-[#334155] dark:bg-[#1E293B]" do |form| %>
    <div class="flex min-w-0 flex-1 flex-col gap-3 sm:flex-row">
      <%= form.search_field :query, value: @query, placeholder: "Search letters...", class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:max-w-xs dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      <%= form.select :category_id, options_for_select([ [ "All categories", "" ] ] + @category_options.map { |category| [ category.name, category.id ] }, @category_id), {}, class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:w-40 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      <%= form.select :visibility, options_for_select([ [ "All visibility", "" ] ] + Document.visibilities.keys.map { |visibility| [ visibility_label(visibility), visibility ] }, @visibility), {}, class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:w-40 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      <% if @can_manage_documents %><%= form.select :status, options_for_select([ [ "All statuses", "" ] ] + Document.statuses.keys.map { |status| [ status.humanize, status ] }, @status), {}, class: "w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 sm:w-36 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %><% end %>
    </div>
    <%= form.button type: :submit, class: action_button_classes(:dark, size: :sm) do %><%= icon_svg(:filter, classes: "h-4 w-4") %><span>Filter</span><% end %>
  <% end %>

  <% if @documents.any? %>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      <% @documents.each do |document| %>
        <article class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm transition hover:border-red-200 hover:shadow-md dark:border-[#334155] dark:bg-[#1E293B] dark:hover:border-red-400/40">
          <div class="flex items-start justify-between gap-3"><div class="min-w-0"><p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300"><%= document.document_category.name %></p><h2 class="mt-1 truncate text-lg font-black text-[#0F172A] dark:text-white"><%= link_to document.title, document, class: "hover:text-red-700 dark:hover:text-red-300" %></h2></div><%= render "shared/status_badge", status: document.status if @can_manage_documents %></div>
          <p class="mt-3 line-clamp-2 min-h-12 text-sm font-semibold leading-6 text-[#64748B] dark:text-[#CBD5E1]"><%= document.description.presence || "No description provided." %></p>
          <div class="mt-4 flex items-center justify-between gap-3 border-t border-[#E2E8F0] pt-3 text-xs font-semibold text-[#64748B] dark:border-[#334155] dark:text-[#CBD5E1]"><span><%= visibility_label(document.visibility) %> · <%= document.file_extension.upcase.presence || "FILE" %></span><div class="flex gap-2"><%= link_to document, class: action_button_classes(:secondary, size: :xs) do %><%= icon_svg(:eye, classes: "h-3.5 w-3.5") %><span>View</span><% end %><% if policy(document).update? %><%= link_to edit_document_path(document), class: action_button_classes(:secondary, size: :xs) do %><%= icon_svg(:edit, classes: "h-3.5 w-3.5") %><span>Edit</span><% end %><% end %></div></div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No letters found", message: "No letters match your search or filters." %>
  <% end %>
</div>
