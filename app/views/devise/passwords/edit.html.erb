<div class="overflow-hidden rounded-2xl border border-white/10 bg-white shadow-2xl shadow-slate-950/40">
  <div class="bg-[#1E293B] px-6 py-7 text-white">
    <%= render "devise/shared/auth_logo" %>
    <h1 class="mt-6 text-2xl font-black tracking-tight">Choose a new password</h1>
    <p class="mt-2 text-sm font-semibold text-slate-300">Use a strong password for your MSJ Portal account.</p>
  </div>

  <div class="p-6 sm:p-8">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <div class="flex items-center justify-between gap-3">
          <%= f.label :password, "New password", class: "block text-sm font-bold text-[#334155]" %>
          <% if @minimum_password_length %>
            <span class="text-xs font-semibold text-[#64748B]"><%= @minimum_password_length %> characters minimum</span>
          <% end %>
        </div>
        <%= render "shared/password_input", form: f, attribute: :password, autocomplete: "new-password", autofocus: true %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-bold text-[#334155]" %>
        <%= render "shared/password_input", form: f, attribute: :password_confirmation, autocomplete: "new-password" %>
      </div>

      <%= f.button type: :submit, class: action_button_classes(:primary, full_width: true) do %>
        <%= icon_svg(:save, classes: "h-4 w-4") %>
        <span>Update password</span>
      <% end %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
