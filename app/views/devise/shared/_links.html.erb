<div class="mt-6 space-y-3 text-center text-sm font-semibold">
<%- if controller_name != 'sessions' %>
  <p><%= link_to "Log in", new_session_path(resource_name), class: "text-red-700 hover:text-red-800 dark:text-red-400" %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p><%= link_to "Create account", new_registration_path(resource_name), class: "text-red-700 hover:text-red-800 dark:text-red-400" %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' && controller_name != 'sessions' %>
  <p><%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-[#64748B] hover:text-[#0F172A] dark:text-[#CBD5E1] dark:hover:text-white" %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p><%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-gray-500 hover:text-gray-800" %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p><%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-gray-500 hover:text-gray-800" %></p>
<% end %>

</div>
