<div class="overflow-hidden rounded-2xl border border-white/10 bg-white shadow-2xl shadow-slate-950/40">
  <div class="relative overflow-hidden bg-[#1E293B] px-5 py-4 text-white sm:px-6 sm:py-5">
    <div class="absolute inset-x-0 top-0 h-1 bg-red-600"></div>
    <div class="flex justify-center">
      <%= render "devise/shared/auth_logo", wrapper_classes: "h-12 w-12 rounded-2xl", image_classes: "h-10 w-10" %>
    </div>
    <div class="mt-4 border-t border-white/10 pt-4">
      <h1 class="text-xl font-black tracking-tight">Chibai le...</h1>
      <p class="mt-1 text-sm font-semibold text-slate-300">Mizo Society of Japan portal-ah kan lo lawm a che.</p>
    </div>
  </div>

  <div class="p-4 sm:p-5">
    <% if devise_mapping.omniauthable? && resource_class.omniauth_providers.include?(:google_oauth2) && google_oauth_configured? %>
      <div class="rounded-2xl border border-red-100 bg-red-50 p-2.5">
        <div class="mb-2 flex items-start gap-2.5">
          <span class="grid h-8 w-8 shrink-0 place-items-center rounded-xl bg-white text-sm font-black text-red-600 shadow-sm">G</span>
          <div>
            <p class="text-sm font-black text-[#0F172A]">Recommended: sign in with Google</p>
            <p class="mt-0.5 text-xs font-semibold leading-4 text-[#64748B]">No portal password is needed. Choose your Google account and continue.</p>
          </div>
        </div>
        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "flex w-full items-center justify-center gap-2 rounded-xl bg-red-700 px-3 py-2 text-sm font-black text-white shadow-sm transition hover:bg-red-800 focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2" do %>
          <span>Continue with Google</span>
          <%= icon_svg(:arrow_right, classes: "h-4 w-4") %>
        <% end %>
      </div>

      <div class="my-3.5 flex items-center gap-3">
        <div class="h-px flex-1 bg-[#E2E8F0]"></div>
        <span class="text-xs font-black uppercase tracking-wide text-[#64748B]">or use email password</span>
        <div class="h-px flex-1 bg-[#E2E8F0]"></div>
      </div>
    <% elsif devise_mapping.omniauthable? && resource_class.omniauth_providers.include?(:google_oauth2) %>
      <div class="mb-5 rounded-lg border border-amber-200 bg-amber-50 p-3 text-xs font-semibold leading-5 text-amber-800">
        Google sign-in is ready in code. Set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET to enable the button.
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-3" }) do |f| %>
      <div>
        <%= f.label :email, class: "block text-sm font-bold text-[#334155]" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1.5 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] shadow-sm outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
      </div>

      <div>
        <div class="flex items-center justify-between gap-3">
          <%= f.label :password, class: "block text-sm font-bold text-[#334155]" %>
          <%= link_to "Forgot?", new_password_path(resource_name), class: "text-xs font-black text-red-700 hover:text-red-800" %>
        </div>
        <%= render "shared/password_input", form: f, attribute: :password, autocomplete: "current-password", class_name: "block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] shadow-sm outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-2 text-sm font-semibold text-[#64748B]">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-[#CBD5E1] text-red-700 focus:ring-red-600" %>
          Remember me
        </label>
      <% end %>

      <%= f.button type: :submit, class: action_button_classes(:primary, full_width: true) do %>
        <%= icon_svg(:arrow_right, classes: "h-4 w-4") %>
        <span>Sign in with email</span>
      <% end %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
