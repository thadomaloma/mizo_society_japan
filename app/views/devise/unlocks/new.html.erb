<div class="overflow-hidden rounded-2xl border border-white/10 bg-white shadow-2xl shadow-slate-950/40">
  <div class="bg-[#1E293B] px-6 py-7 text-white">
    <%= render "devise/shared/auth_logo" %>
    <h1 class="mt-6 text-2xl font-black tracking-tight">Unlock account</h1>
    <p class="mt-2 text-sm font-semibold text-slate-300">Send a secure unlock link to your account email.</p>
  </div>

  <div class="p-6 sm:p-8">
    <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-sm font-bold text-[#334155]" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] shadow-sm outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
      </div>

      <%= f.button type: :submit, class: action_button_classes(:primary, full_width: true) do %>
        <%= icon_svg(:lock, classes: "h-4 w-4") %>
        <span>Send unlock link</span>
      <% end %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
