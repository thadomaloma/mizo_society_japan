<% content_for :page_title, "Account Settings" %>

<div class="mx-auto max-w-2xl rounded-lg border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
  <h2 class="text-2xl font-black tracking-tight text-gray-950">Account settings</h2>
  <p class="mt-2 text-sm text-gray-600">Update your portal sign-in details.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "mt-6 space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, class: "block text-sm font-bold text-gray-700" %>
      <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-bold text-gray-700" %>
      <%= f.email_field :email, autocomplete: "email", class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="rounded-lg bg-amber-50 p-3 text-sm font-semibold text-amber-800">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
    <% end %>

    <div>
      <%= f.label :password, class: "block text-sm font-bold text-gray-700" %>
      <p class="mt-1 text-xs font-semibold text-gray-500">Leave blank if you do not want to change it.</p>
      <%= render "shared/password_input", form: f, attribute: :password, autocomplete: "new-password", class_name: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-bold text-gray-700" %>
      <%= render "shared/password_input", form: f, attribute: :password_confirmation, autocomplete: "new-password", class_name: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div>
      <%= f.label :current_password, class: "block text-sm font-bold text-gray-700" %>
      <p class="mt-1 text-xs font-semibold text-gray-500">Required to confirm account changes.</p>
      <%= render "shared/password_input", form: f, attribute: :current_password, autocomplete: "current-password", class_name: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <%= f.button type: :submit, class: action_button_classes(:primary, full_width: true, extra: "sm:w-auto") do %>
      <%= icon_svg(:save, classes: "h-4 w-4") %>
      <span>Update account</span>
    <% end %>
  <% end %>

  <div class="mt-6 border-t border-gray-200 pt-5">
    <%= link_to request.referer || root_path, class: action_button_classes(:secondary, size: :sm) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Back</span>
    <% end %>
  </div>
</div>
