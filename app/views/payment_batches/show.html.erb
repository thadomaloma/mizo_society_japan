<% content_for :page_title, "Combined Payment" %>

<div class="space-y-4 sm:space-y-6">
  <%= render "shared/page_header",
    eyebrow: "Member finance",
    title: "Combined Payment",
    actions: link_to(membership_payments_path, class: action_button_classes(:secondary)) { safe_join([ icon_svg(:arrow_left, classes: "h-4 w-4"), tag.span("Payments") ]) } %>

  <section class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_24rem]">
    <div class="space-y-4">
      <article class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">Transfer once</p>
            <h2 class="mt-1 text-2xl font-black text-[#0F172A] dark:text-white"><%= yen(@payment_batch.total_amount) %></h2>
            <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Total for all selected payments.</p>
          </div>
          <%= render "shared/status_badge", status: @payment_batch.status %>
        </div>

        <div class="mt-4 divide-y divide-[#E2E8F0] overflow-hidden rounded-2xl border border-[#E2E8F0] dark:divide-[#334155] dark:border-[#334155]">
          <% @payment_batch.membership_payments.each do |payment| %>
            <div class="flex items-center justify-between gap-3 bg-[#F8FAFC] px-3 py-2.5 dark:bg-[#0F172A]">
              <div class="min-w-0">
                <p class="truncate text-sm font-black text-[#0F172A] dark:text-white"><%= payment.membership_plan.name %></p>
                <p class="mt-0.5 truncate text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= payment.plan_type_label %> · <%= payment.period_label %></p>
              </div>
              <p class="shrink-0 text-sm font-black text-[#0F172A] dark:text-white"><%= yen(payment.amount) %></p>
            </div>
          <% end %>
        </div>
      </article>

      <% if policy(@payment_batch).submit_transfer? %>
        <article class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5">
          <h3 class="text-base font-black text-[#0F172A] dark:text-white">Submit Bank Transfer Details</h3>
          <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Transfer the total amount once, then submit the details below.</p>

          <%= form_with model: @payment_batch, url: submit_transfer_payment_batch_path(@payment_batch), method: :patch, class: "mt-4 grid gap-4 sm:grid-cols-2" do |form| %>
            <%= render "devise/shared/error_messages", resource: @payment_batch %>
            <div>
              <%= form.label :transferred_on, "Transfer Date", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.date_field :transferred_on, required: true, class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
            </div>
            <div>
              <%= form.label :transfer_amount, "Total Amount", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.number_field :transfer_amount, required: true, min: 0, step: 1, value: @payment_batch.total_amount.to_i, class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
            </div>
            <div class="sm:col-span-2">
              <%= form.label :transfer_reference_name, "Reference Name", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.text_field :transfer_reference_name, required: true, placeholder: "Name shown in bank transfer", class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
            </div>
            <div class="sm:col-span-2">
              <%= form.label :transfer_screenshot, "Screenshot (optional)", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.file_field :transfer_screenshot, accept: "image/png,image/jpeg,image/webp,application/pdf", class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-sm text-[#334155] file:mr-3 file:rounded-md file:border-0 file:bg-[#0F172A] file:px-3 file:py-1.5 file:text-xs file:font-black file:text-white dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1]" %>
            </div>
            <div class="sm:col-span-2">
              <%= form.button type: :submit, class: action_button_classes(:primary, full_width: true) do %>
                <%= icon_svg(:upload, classes: "h-4 w-4") %>
                <span>Submit Combined Transfer</span>
              <% end %>
            </div>
          <% end %>
        </article>
      <% else %>
        <article class="rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm font-semibold text-amber-800 dark:border-amber-500/30 dark:bg-amber-500/10 dark:text-amber-100">
          <p class="font-black">Transfer submitted</p>
          <p class="mt-1">Treasurer will verify this combined payment and mark all included payments as paid.</p>
        </article>
      <% end %>
    </div>

    <aside class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5 xl:sticky xl:top-24 xl:self-start">
      <h3 class="text-base font-black text-[#0F172A] dark:text-white">Bank Transfer</h3>
      <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Use these details and transfer the total once.</p>
      <div class="mt-4 space-y-3">
        <div class="rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
          <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">From another bank</p>
          <% [
            [ "Bank", @bank_transfer_details[:bank_name], false ],
            [ "Store Name", @bank_transfer_details[:branch_name], true ],
            [ "Account Number", @bank_transfer_details[:account_number], true ],
            [ "Account Name", @bank_transfer_details[:account_name], false ]
          ].each do |label, value, copyable| %>
            <% next if value.blank? %>
            <div class="mt-2 flex items-center justify-between gap-2 rounded-lg bg-white px-3 py-2 dark:bg-[#1E293B]">
              <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= label %></p>
              <div class="flex min-w-0 items-center gap-2">
                <p class="truncate text-right text-sm font-black text-[#0F172A] dark:text-white"><%= value %></p>
                <% if copyable %>
                  <button type="button" class="inline-flex h-8 shrink-0 items-center gap-1 rounded-lg border border-[#E2E8F0] bg-white px-2 text-[11px] font-black text-[#64748B] transition hover:border-red-200 hover:text-red-700 dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1]" data-controller="clipboard" data-clipboard-text-value="<%= value %>" data-action="clipboard#copy">
                    <%= icon_svg(:copy, classes: "h-3.5 w-3.5") %>
                    <span data-clipboard-target="label">Copy</span>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        <div class="rounded-xl border border-red-100 bg-red-50 p-3 dark:border-red-500/20 dark:bg-red-500/10">
          <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">From ゆうちょ銀行</p>
          <% [
            [ "Symbol", @bank_transfer_details[:yucho_symbol] ],
            [ "Number", @bank_transfer_details[:yucho_number] ]
          ].each do |label, value| %>
            <% next if value.blank? %>
            <div class="mt-2 flex items-center justify-between gap-2 rounded-lg bg-white px-3 py-2 dark:bg-[#0F172A]">
              <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= label %></p>
              <div class="flex min-w-0 items-center gap-2">
                <p class="truncate text-sm font-black text-[#0F172A] dark:text-white"><%= value %></p>
                <button type="button" class="inline-flex h-8 shrink-0 items-center gap-1 rounded-lg border border-[#E2E8F0] bg-white px-2 text-[11px] font-black text-[#64748B] transition hover:border-red-200 hover:text-red-700 dark:border-[#334155] dark:bg-[#1E293B] dark:text-[#CBD5E1]" data-controller="clipboard" data-clipboard-text-value="<%= value %>" data-action="clipboard#copy">
                  <%= icon_svg(:copy, classes: "h-3.5 w-3.5") %>
                  <span data-clipboard-target="label">Copy</span>
                </button>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </aside>
  </section>
</div>
