<% content_for :page_title, "Combined Payment" %>

<div class="space-y-4 sm:space-y-6">
  <div class="hidden sm:block">
    <%= render "shared/page_header",
      eyebrow: "Member finance",
      title: "Combined Payment",
      actions: link_to(membership_payments_path, class: action_button_classes(:secondary)) { safe_join([ icon_svg(:arrow_left, classes: "h-4 w-4"), tag.span("Payments") ]) } %>
  </div>

  <div class="sm:hidden">
    <%= link_to membership_payments_path, class: "inline-flex items-center gap-1.5 rounded-lg px-1 text-xs font-black text-[#64748B] transition hover:text-red-700 dark:text-[#CBD5E1] dark:hover:text-red-300" do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Payments</span>
    <% end %>
  </div>

  <section class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_24rem]">
    <div class="space-y-4 xl:order-1">
      <article class="hidden rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:block sm:p-5">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">Transfer once</p>
            <h2 class="mt-1 text-2xl font-black text-[#0F172A] dark:text-white"><%= yen(@payment_batch.total_amount) %></h2>
            <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Total for all selected payments.</p>
          </div>
          <%= render "shared/status_badge", status: @payment_batch.status %>
        </div>

        <div class="mt-4 divide-y divide-[#E2E8F0] overflow-hidden rounded-2xl border border-[#E2E8F0] dark:divide-[#334155] dark:border-[#334155]">
          <% @payment_batch.membership_payments.each do |payment| %>
            <div class="flex items-center justify-between gap-3 bg-[#F8FAFC] px-3 py-2.5 dark:bg-[#0F172A]">
              <div class="min-w-0">
                <p class="truncate text-sm font-black text-[#0F172A] dark:text-white"><%= payment.membership_plan.name %></p>
                <p class="mt-0.5 truncate text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= payment.plan_type_label %> · <%= payment.period_label %></p>
              </div>
              <p class="shrink-0 text-sm font-black text-[#0F172A] dark:text-white"><%= yen(payment.amount) %></p>
            </div>
          <% end %>
        </div>
      </article>

      <% if policy(@payment_batch).submit_transfer? %>
        <article class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5">
          <div class="mb-4 rounded-xl border border-red-100 bg-red-50 p-3 dark:border-red-500/20 dark:bg-red-500/10 sm:hidden">
            <div class="flex items-center justify-between gap-3">
              <div class="min-w-0">
                <p class="text-[10px] font-black uppercase tracking-wide text-red-700 dark:text-red-300"><%= pluralize(@payment_batch.membership_payments.count, "selected item") %></p>
                <p class="mt-0.5 truncate text-2xl font-black text-[#0F172A] dark:text-white"><%= yen(@payment_batch.total_amount) %></p>
              </div>
              <%= render "shared/status_badge", status: @payment_batch.status, compact: true %>
            </div>
          </div>

          <h3 class="text-base font-black text-[#0F172A] dark:text-white">Submit Bank Transfer Details</h3>
          <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Transfer the total amount once, then submit the details below.</p>

          <%= form_with model: @payment_batch, url: submit_transfer_payment_batch_path(@payment_batch), method: :patch, class: "mt-4 grid gap-4 sm:grid-cols-2" do |form| %>
            <%= render "devise/shared/error_messages", resource: @payment_batch %>
            <div>
              <%= form.label :transferred_on, "Transfer Date", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.date_field :transferred_on, required: true, max: Date.current, class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
            </div>
            <div>
              <%= form.label :transfer_amount, "Total Amount", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.number_field :transfer_amount, required: true, min: 0, step: 1, value: @payment_batch.total_amount.to_i, class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
            </div>
            <div class="sm:col-span-2">
              <%= form.label :transfer_reference_name, "Reference Name", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.text_field :transfer_reference_name, required: true, value: @payment_batch.transfer_reference_name.presence || current_user.display_name, class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
            </div>
            <div class="sm:col-span-2">
              <%= form.label :transfer_screenshot, "Screenshot (optional)", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.file_field :transfer_screenshot, accept: "image/png,image/jpeg,image/webp,application/pdf", class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-sm text-[#334155] file:mr-3 file:rounded-md file:border-0 file:bg-[#0F172A] file:px-3 file:py-1.5 file:text-xs file:font-black file:text-white dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1]" %>
            </div>
            <div class="sm:col-span-2">
              <%= form.button type: :submit, class: action_button_classes(:primary, full_width: true) do %>
                <%= icon_svg(:upload, classes: "h-4 w-4") %>
                <span>Submit Transfer</span>
              <% end %>
            </div>
          <% end %>
        </article>
      <% else %>
        <article class="rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm font-semibold text-amber-800 dark:border-amber-500/30 dark:bg-amber-500/10 dark:text-amber-100">
          <p class="font-black">Transfer submitted</p>
          <p class="mt-1">Treasurer will verify this combined payment and mark all included payments as paid.</p>
        </article>
      <% end %>
    </div>

    <aside class="order-first rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5 xl:order-2 xl:sticky xl:top-24 xl:self-start">
      <h3 class="text-base font-black text-[#0F172A] dark:text-white">Bank Transfer</h3>
      <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Use these details and transfer the total once.</p>
      <div class="mt-4 space-y-3">
        <div class="rounded-xl border border-sky-100 bg-gradient-to-br from-sky-50 to-white p-3 shadow-sm shadow-sky-950/5 dark:border-sky-400/20 dark:from-sky-500/10 dark:to-[#0F172A]">
          <p class="inline-flex rounded-full bg-yellow-100 px-2.5 py-1 text-xs font-black uppercase tracking-wide text-yellow-900 ring-1 ring-yellow-200 dark:bg-yellow-400/15 dark:text-yellow-100 dark:ring-yellow-300/20">From another bank</p>
          <% [
            [ "Bank", @bank_transfer_details[:bank_name], false ],
            [ "Store Name<br><span class=\"text-inherit normal-case tracking-normal\">店名</span>".html_safe, @bank_transfer_details[:branch_name], true ],
            [ "Account Number<br><span class=\"text-inherit normal-case tracking-normal\">口座番号</span>".html_safe, @bank_transfer_details[:account_number], true ],
            [ "Account Name", @bank_transfer_details[:account_name], false ]
          ].each do |label, value, copyable| %>
            <% next if value.blank? %>
            <% copy_title = strip_tags(label.to_s).squish %>
            <div class="mt-2 flex items-start justify-between gap-3 rounded-lg bg-white/90 px-3 py-2 ring-1 ring-sky-100/70 dark:bg-[#1E293B]/85 dark:ring-sky-400/10">
              <p class="w-24 shrink-0 text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= label %></p>
              <div class="flex min-w-0 flex-1 items-start justify-end gap-2">
                <p class="min-w-0 break-all text-right text-sm font-black text-[#0F172A] dark:text-white"><%= value %></p>
                <% if copyable %>
                  <button type="button" class="inline-flex h-8 shrink-0 items-center gap-1 rounded-lg border border-[#E2E8F0] bg-white px-2 text-[11px] font-black text-[#64748B] transition hover:border-red-200 hover:text-red-700 dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1]" data-controller="clipboard" data-clipboard-text-value="<%= value %>" data-action="clipboard#copy" title="Copy <%= copy_title %>">
                    <%= icon_svg(:copy, classes: "h-3.5 w-3.5") %>
                    <span data-clipboard-target="label">Copy</span>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        <div class="rounded-xl border border-red-100 bg-gradient-to-br from-red-50 to-white p-3 shadow-sm shadow-red-950/5 dark:border-red-400/20 dark:from-red-500/10 dark:to-[#0F172A]">
          <p class="inline-flex rounded-full bg-yellow-100 px-2.5 py-1 text-xs font-black uppercase tracking-wide text-yellow-900 ring-1 ring-yellow-200 dark:bg-yellow-400/15 dark:text-yellow-100 dark:ring-yellow-300/20">From ゆうちょ銀行</p>
          <% [
            [ "Symbol<br><span class=\"text-inherit normal-case tracking-normal\">記号</span>".html_safe, @bank_transfer_details[:yucho_symbol] ],
            [ "Number<br><span class=\"text-inherit normal-case tracking-normal\">番号</span>".html_safe, @bank_transfer_details[:yucho_number] ]
          ].each do |label, value| %>
            <% display_value = value.presence || "Not set" %>
            <% copy_title = strip_tags(label.to_s).squish %>
            <div class="mt-2 flex items-start justify-between gap-3 rounded-lg bg-white/90 px-3 py-2 ring-1 ring-red-100/70 dark:bg-[#1E293B]/85 dark:ring-red-400/10">
              <p class="w-24 shrink-0 text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= label %></p>
              <div class="flex min-w-0 flex-1 items-start justify-end gap-2">
                <p class="min-w-0 break-all text-right text-sm font-black text-[#0F172A] dark:text-white"><%= display_value %></p>
                <% if value.present? %>
                  <button type="button" class="inline-flex h-8 shrink-0 items-center gap-1 rounded-lg border border-[#E2E8F0] bg-white px-2 text-[11px] font-black text-[#64748B] transition hover:border-red-200 hover:text-red-700 dark:border-[#334155] dark:bg-[#1E293B] dark:text-[#CBD5E1]" data-controller="clipboard" data-clipboard-text-value="<%= value %>" data-action="clipboard#copy" title="Copy <%= copy_title %>">
                    <%= icon_svg(:copy, classes: "h-3.5 w-3.5") %>
                    <span data-clipboard-target="label">Copy</span>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

    </aside>
  </section>
</div>
