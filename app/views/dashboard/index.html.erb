<% content_for :page_title, "Dashboard" %>

<div class="space-y-5 lg:space-y-6">
  <%= render "shared/portal_notice" %>
  <section class="overflow-hidden rounded-xl bg-gradient-to-br from-red-950 via-red-800 to-[#0F172A] shadow-lg shadow-slate-950/10 lg:hidden">
    <div class="px-4 py-4">
      <p class="text-xs font-bold text-red-100">Welcome back,</p>
      <h2 class="mt-0.5 truncate text-[1.35rem] font-black leading-7 text-white"><%= current_user.display_name %></h2>
      <p class="mt-1 text-[13px] font-bold text-red-100"><%= role_label(current_user.role) %></p>
    </div>
  </section>

  <section class="hidden lg:block">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h2 class="text-2xl font-black tracking-tight text-gray-950 dark:text-white sm:text-3xl">
          Welcome back, <%= current_user.display_name %>
        </h2>
        <p class="mt-2 text-sm font-semibold text-gray-500 dark:text-gray-400">
          Your payments, updates, and profile activity are shown here.
        </p>
      </div>

      <% if admin_portal_user? %>
        <%= render "shared/action_button", label: "Open admin", path: admin_dashboard_path, icon: :dashboard %>
      <% end %>
    </div>
  </section>

  <% unless profile_complete? %>
    <section class="rounded-2xl border border-red-200 bg-red-50 p-4 shadow-sm dark:border-red-500/30 dark:bg-red-500/10">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-black text-red-700 dark:text-red-300">I profile hi la famkim lo.</p>
          <p class="mt-1 text-sm font-semibold text-red-700/80 dark:text-red-100">Member information hi update rawh.</p>
        </div>
        <%= link_to setup_profile_path, class: action_button_classes(:primary, size: :sm) do %>
          <%= icon_svg(:edit, classes: "h-4 w-4") %>
          <span>Complete Profile</span>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="rounded-xl border border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:rounded-2xl sm:p-4">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-4">
      <div class="flex items-center justify-between gap-3 sm:w-52 sm:justify-start">
        <div>
          <p class="text-[11px] font-black uppercase tracking-wide text-red-700 dark:text-red-400 sm:text-xs">Profile Completion</p>
          <p class="hidden text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1] sm:mt-1 sm:block"><%= profile_complete? ? "Your profile is complete." : "Update your member information." %></p>
        </div>
        <p class="text-lg font-black text-[#0F172A] dark:text-[#F8FAFC] sm:text-2xl"><%= @profile_completion_percentage %>%</p>
      </div>
      <div class="flex flex-1 items-center gap-3">
        <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-slate-100 dark:bg-[#334155] sm:h-2">
          <div class="h-full rounded-full bg-red-600 transition-all" style="width: <%= @profile_completion_percentage %>%"></div>
        </div>
        <%= link_to(profile_complete? ? profile_path : setup_profile_path, class: action_button_classes(profile_complete? ? :secondary : :primary, size: :xs, extra: "px-2.5 sm:px-3 sm:py-2")) do %>
          <%= icon_svg(profile_complete? ? :eye : :edit, classes: "h-3.5 w-3.5") %>
          <span class="sm:hidden"><%= profile_complete? ? "View" : "Complete" %></span>
          <span class="hidden sm:inline"><%= profile_complete? ? "View Profile" : "Complete Profile" %></span>
        <% end %>
      </div>
    </div>
  </section>

  <section class="grid grid-cols-2 gap-3 rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:grid-cols-4 lg:hidden">
    <% @member_stats.each do |stat| %>
      <div class="border-r border-[#E2E8F0] px-2 py-3 text-center last:border-r-0 dark:border-[#334155]">
        <div class="mx-auto grid h-8 w-8 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-600/15 dark:text-red-300">
          <%= icon_svg(stat[:icon], classes: "h-4 w-4") %>
        </div>
        <p class="mt-2 text-[11px] font-black leading-4 text-gray-500 dark:text-gray-400"><%= stat[:label] %></p>
        <p class="mt-1 text-xl font-black text-gray-950 dark:text-white"><%= stat[:value] %></p>
      </div>
    <% end %>
  </section>

  <section class="hidden gap-4 lg:grid lg:grid-cols-4">
    <% @member_stats.each do |stat| %>
      <%= render "shared/stat_card", label: stat[:label], value: stat[:value], tone: "red", icon: stat[:icon], caption: "Visible to your role" %>
    <% end %>
  </section>

  <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex items-center gap-3">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-600/15 dark:text-red-300">
          <%= icon_svg(:members, classes: "h-5 w-5") %>
        </span>
        <div>
          <p class="text-[11px] font-black uppercase tracking-wide text-red-700 dark:text-red-400 sm:text-xs">Community Overview</p>
          <h3 class="mt-1 text-[17px] font-black leading-6 text-[#0F172A] dark:text-white sm:text-lg">MSJ member presence</h3>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:min-w-[28rem]">
        <div class="rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
            <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1] sm:text-xs">Active Members</p>
          <p class="mt-1 text-2xl font-black text-[#0F172A] dark:text-white"><%= @community_overview[:total_active_members] %></p>
        </div>
        <div class="rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
          <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= @community_overview[:current_prefecture].presence || "My Prefecture" %></p>
          <p class="mt-1 text-2xl font-black text-[#0F172A] dark:text-white"><%= @community_overview[:current_prefecture_count] %></p>
        </div>
      </div>
    </div>

    <div class="mt-4 border-t border-[#E2E8F0] pt-4 dark:border-[#334155]">
      <div class="mb-4 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
        <div class="flex items-center justify-between gap-3">
          <div>
          <p class="text-[11px] font-black uppercase tracking-wide text-red-700 dark:text-red-400 sm:text-xs">Member Status</p>
            <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Single and family household profile count.</p>
          </div>
          <p class="text-sm font-black text-[#0F172A] dark:text-white"><%= pluralize(@community_overview[:family_status_total], "profile") %></p>
        </div>

        <div class="mt-4 space-y-3">
          <% [
            [ "Single", @community_overview[:single_members], @community_overview[:single_percentage], "bg-red-600" ],
            [ "Family", @community_overview[:family_members], @community_overview[:family_percentage], "bg-[#0F172A] dark:bg-[#CBD5E1]" ]
          ].each do |label, count, percentage, color_class| %>
            <div class="rounded-lg bg-white p-3 ring-1 ring-[#E2E8F0] dark:bg-[#1E293B] dark:ring-[#334155]">
              <div class="mb-2 flex items-center justify-between gap-3">
                <div class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full <%= color_class %>"></span>
                  <p class="text-xs font-black text-[#0F172A] dark:text-white"><%= label %></p>
                </div>
                <p class="text-xs font-black text-[#64748B] dark:text-[#CBD5E1]"><%= count %> · <%= percentage %>%</p>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-slate-100 dark:bg-[#334155]">
                <div class="h-full rounded-full <%= color_class %>" style="width: <%= percentage %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <% if @community_overview[:top_prefectures].any? %>
        <div class="flex flex-wrap gap-2">
          <% @community_overview[:top_prefectures].each do |prefecture, count| %>
            <span class="inline-flex items-center gap-2 rounded-full border border-[#E2E8F0] bg-[#F8FAFC] px-3 py-1.5 text-xs font-black text-[#0F172A] dark:border-[#334155] dark:bg-[#0F172A] dark:text-white">
              <%= prefecture %>
              <span class="rounded-full bg-red-100 px-2 py-0.5 text-red-700 dark:bg-red-500/15 dark:text-red-300"><%= count %></span>
            </span>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Prefecture overview will appear when more member data is available.</p>
      <% end %>
    </div>
  </section>

  <% if @latest_pinned_announcement.present? %>
    <%= link_to announcement_path(@latest_pinned_announcement), class: "block rounded-xl border border-red-100 bg-red-50 p-5 shadow-sm transition hover:border-red-200 hover:bg-red-100/70 dark:border-red-500/20 dark:bg-red-500/10 dark:hover:bg-red-500/15" do %>
      <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">Pinned notice</p>
      <h3 class="mt-2 text-lg font-black text-gray-950 dark:text-white"><%= @latest_pinned_announcement.title %></h3>
      <p class="mt-2 line-clamp-2 text-sm font-semibold text-gray-600 dark:text-gray-300"><%= @latest_pinned_announcement.body %></p>
    <% end %>
  <% end %>

  <section class="grid items-stretch gap-5 xl:grid-cols-2">
    <%= render "shared/section_card",
      title: "Announcements & Updates",
      action: action_link("Open", events_path, icon: :events),
      class: "h-full",
      body_class: "space-y-2 p-3 sm:space-y-3 sm:p-5" do %>
      <% @recent_updates.each do |update| %>
        <%= link_to update[:path], class: "group flex items-start gap-2.5 rounded-lg border border-[#E2E8F0] bg-[#F8FAFC] p-2.5 transition hover:border-red-200 hover:bg-red-50/50 dark:border-[#334155] dark:bg-[#0F172A] dark:hover:bg-[#334155] sm:gap-3 sm:rounded-xl sm:p-3" do %>
          <span class="mt-0.5 grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-600/15 dark:text-red-300 sm:h-9 sm:w-9">
            <%= icon_svg(update[:icon], classes: "h-3.5 w-3.5 sm:h-4 sm:w-4") %>
          </span>
          <span class="min-w-0 flex-1">
            <span class="block line-clamp-1 text-[13px] font-black leading-5 text-[#0F172A] group-hover:text-red-700 dark:text-white dark:group-hover:text-red-300 sm:line-clamp-2 sm:text-sm"><%= update[:title] %></span>
            <span class="block text-[12px] font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1] sm:mt-1 sm:text-xs"><%= update[:subtitle] %></span>
          </span>
          <%= icon_svg(:arrow_right, classes: "mt-2 h-3.5 w-3.5 shrink-0 text-slate-300 transition group-hover:text-red-600 dark:text-slate-500 dark:group-hover:text-red-300 sm:h-4 sm:w-4") %>
        <% end %>
      <% end %>
      <% if @recent_updates.empty? %>
        <p class="text-sm font-semibold text-gray-500 dark:text-gray-400">No updates yet.</p>
      <% end %>
    <% end %>

    <%= render "shared/section_card",
      title: "Payments",
      action: action_link("View all", membership_payments_path, icon: :finance),
      class: "h-full",
      body_class: "space-y-2.5 p-3 sm:space-y-3 sm:p-5" do %>
      <% @latest_payments.each do |payment| %>
        <%= link_to membership_payment_path(payment), class: "block rounded-lg border border-[#E2E8F0] p-3 transition hover:border-red-200 hover:bg-red-50/40 dark:border-[#334155] dark:hover:bg-[#334155] sm:p-4" do %>
          <div class="flex items-start justify-between gap-3">
            <p class="text-sm font-black leading-5 text-gray-950 dark:text-white"><%= payment.membership_plan.name %></p>
            <%= render "shared/status_badge", status: payment.status, compact: true %>
          </div>
          <p class="mt-2 text-xl font-black text-gray-950 dark:text-white sm:mt-3"><%= yen(payment.amount) %></p>
        <% end %>
      <% end %>
      <% if @latest_payments.empty? %>
        <p class="text-sm font-semibold text-gray-500 dark:text-gray-400">No payments yet.</p>
      <% end %>
    <% end %>
  </section>

  <% if @show_events_dashboard %>
    <section>
      <%= render "shared/section_card",
        title: "Upcoming Events",
        action: action_link("View all", events_path, icon: :events),
        body_class: "grid gap-4 p-5 md:grid-cols-2 xl:grid-cols-3" do %>
        <% @upcoming_events.each do |event| %>
          <%= render "shared/event_item", event: event %>
        <% end %>
      <% end %>
    </section>
  <% end %>

  <% if @show_welfare_dashboard %>
    <section class="grid gap-5">
      <%= render "shared/section_card",
        title: "My Welfare Requests",
        action: action_link("Open", welfare_cases_path, icon: :welfare),
        body_class: "space-y-3 p-5" do %>
        <% @recent_welfare_updates.each do |welfare_case| %>
          <%= link_to welfare_case_path(welfare_case), class: "block rounded-lg border border-[#E2E8F0] p-4 transition hover:border-red-200 hover:bg-red-50/40 dark:border-[#334155] dark:hover:bg-[#334155]" do %>
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="font-black text-gray-950 dark:text-white"><%= welfare_case.title %></p>
                <p class="mt-1 text-sm font-semibold text-gray-500 dark:text-gray-400"><%= welfare_case.welfare_category.name %></p>
              </div>
              <%= render "shared/status_badge", status: welfare_case.status %>
            </div>
          <% end %>
        <% end %>
        <% if @recent_welfare_updates.empty? %>
          <p class="text-sm font-semibold text-gray-500 dark:text-gray-400">No welfare requests yet.</p>
        <% end %>
      <% end %>
    </section>
  <% end %>

</div>
