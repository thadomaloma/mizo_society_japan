<% content_for :page_title, "Meeting Minutes" %>

<div class="space-y-6">
  <% page_actions = capture do %>
    <% if policy(MeetingMinute).create? %>
      <%= link_to new_meeting_minute_path, class: action_button_classes(:primary) do %>
        <%= icon_svg(:plus, classes: "h-4 w-4") %>
        <span>New Minute</span>
      <% end %>
    <% end %>
  <% end %>

  <%= render "shared/page_header", eyebrow: "Meeting Minutes", title: "Meeting Minutes", subtitle: "Official meeting minutes and decisions.", actions: page_actions %>

  <%= form_with url: meeting_minutes_path, method: :get, class: "grid gap-3 rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm md:grid-cols-[1fr_10rem_auto] dark:border-[#334155] dark:bg-[#1E293B]" do |form| %>
    <%= form.search_field :query, value: @query, placeholder: "Search meeting title...", class: "rounded-xl border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    <%= form.select :year, options_for_select([[ "All years", "" ]] + @years.map { |year| [ year, year ] }, @year), {}, class: "rounded-xl border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    <%= form.button type: :submit, class: action_button_classes(:dark) do %>
      <%= icon_svg(:search, classes: "h-4 w-4") %>
      <span>Search</span>
    <% end %>
  <% end %>

  <% if @meeting_minutes.any? %>
    <div class="hidden overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B] lg:block">
      <table class="min-w-full divide-y divide-[#E2E8F0] text-left text-sm dark:divide-[#334155]">
        <thead class="bg-[#F8FAFC] text-xs font-black uppercase tracking-wide text-[#64748B] dark:bg-[#0F172A] dark:text-[#CBD5E1]">
          <tr>
            <th class="px-5 py-3">Meeting</th>
            <th class="px-5 py-3">Time</th>
            <th class="px-5 py-3">Date</th>
            <th class="px-5 py-3">Venue</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#E2E8F0] dark:divide-[#334155]">
          <% @meeting_minutes.each do |minute| %>
            <tr>
              <td class="px-5 py-4">
                <p class="font-black text-[#0F172A] dark:text-white"><%= minute.title %></p>
                <p class="mt-2 text-xs font-black text-[#64748B] dark:text-[#CBD5E1]"><%= meeting_minute_attendance_badge(minute) %></p>
              </td>
              <td class="px-5 py-4 font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= minute.meeting_time_label %></td>
              <td class="px-5 py-4 font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= minute.meeting_date.strftime("%b %d, %Y") %></td>
              <td class="px-5 py-4 font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= minute.venue.presence || "-" %></td>
              <td class="px-5 py-4"><%= render "shared/status_badge", status: minute.status %></td>
              <td class="px-5 py-4">
                <div class="flex justify-end gap-2">
                  <%= link_to meeting_minute_path(minute), class: action_button_classes(:secondary, size: :xs) do %>
                    <%= icon_svg(:eye, classes: "h-3.5 w-3.5") %>
                    <span>View</span>
                  <% end %>
                  <% if policy(minute).edit? %>
                    <%= link_to edit_meeting_minute_path(minute), class: action_button_classes(:primary, size: :xs) do %>
                      <%= icon_svg(:edit, classes: "h-3.5 w-3.5") %>
                      <span>Edit</span>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="grid gap-4 lg:hidden">
      <% @meeting_minutes.each do |minute| %>
        <article class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300"><%= minute.meeting_time_label %></p>
              <h3 class="mt-1 break-words font-black text-[#0F172A] dark:text-white"><%= minute.title %></h3>
              <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= minute.meeting_date.strftime("%b %d, %Y") %><%= " · #{minute.venue}" if minute.venue.present? %></p>
            </div>
            <%= render "shared/status_badge", status: minute.status %>
          </div>
          <p class="mt-3 rounded-lg bg-[#F8FAFC] px-3 py-2 text-xs font-black text-[#64748B] dark:bg-[#0F172A] dark:text-[#CBD5E1]"><%= meeting_minute_attendance_badge(minute) %></p>
          <div class="mt-4 grid gap-2 <%= policy(minute).edit? ? "grid-cols-2" : "grid-cols-1" %>">
            <%= link_to meeting_minute_path(minute), class: action_button_classes(:secondary, full_width: true) do %>
              <%= icon_svg(:eye, classes: "h-4 w-4") %>
              <span>View Record</span>
            <% end %>
            <% if policy(minute).edit? %>
              <%= link_to edit_meeting_minute_path(minute), class: action_button_classes(:primary, full_width: true) do %>
                <%= icon_svg(:edit, classes: "h-4 w-4") %>
                <span>Edit Record</span>
              <% end %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No meeting minutes found.", message: "Create a new minute when a meeting is completed." %>
  <% end %>
</div>
