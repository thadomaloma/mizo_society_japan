<% content_for :page_title, @meeting_minute.title %>

<% present_users = @meeting_minute.meeting_minute_attendances.select { |attendance| attendance.status == "present" }.map(&:user) %>
<% absent_users = @meeting_minute.meeting_minute_attendances.select { |attendance| attendance.status == "absent" }.map(&:user) %>

<div class="space-y-6">
  <% page_actions = capture do %>
    <%= link_to meeting_minutes_path, class: action_button_classes(:secondary) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Back</span>
    <% end %>
    <%= link_to export_pdf_meeting_minute_path(@meeting_minute), class: action_button_classes(:primary) do %>
      <%= icon_svg(:download, classes: "h-4 w-4") %>
      <span>Export PDF</span>
    <% end %>
    <% if policy(@meeting_minute).download? && @meeting_minute.file.attached? %>
      <%= link_to download_meeting_minute_path(@meeting_minute), class: action_button_classes(:secondary) do %>
        <%= icon_svg(:download, classes: "h-4 w-4") %>
        <span>Attachment</span>
      <% end %>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Meeting Minutes",
    title: @meeting_minute.title,
    subtitle: [ @meeting_minute.meeting_date.strftime("%B %d, %Y"), @meeting_minute.meeting_time_label, @meeting_minute.venue.presence ].compact.join(" · "),
    actions: page_actions %>

  <% if policy(@meeting_minute).publish? %>
    <div class="flex flex-wrap justify-end gap-2 rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <% if policy(@meeting_minute).publish? %>
        <%= button_to publish_meeting_minute_path(@meeting_minute), method: :patch, class: action_button_classes(:primary) do %>
          <%= icon_svg(:upload, classes: "h-4 w-4") %>
          <span>Publish</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <article class="mx-auto min-h-[297mm] w-full max-w-[210mm] rounded-2xl border border-[#E2E8F0] bg-white px-6 py-8 shadow-sm dark:border-[#334155] dark:bg-white sm:px-12 sm:py-14 print:border-0 print:px-0 print:py-0 print:shadow-none">
    <div class="text-[15px] font-normal leading-7 text-black sm:text-base">
      <header class="mb-9 text-center">
        <h1 class="text-2xl font-black uppercase tracking-wide sm:text-3xl">MIZO SOCIETY OF JAPAN</h1>
        <h2 class="mx-auto mt-5 max-w-2xl text-xl font-black uppercase tracking-wide sm:text-2xl"><%= @meeting_minute.title %></h2>

        <dl class="mx-auto mt-7 max-w-2xl space-y-1 text-left text-base leading-6">
          <div><dt class="inline font-black">A Hun (Date &amp; Time):</dt> <dd class="inline"><%= @meeting_minute.meeting_date.strftime("%d/%m/%Y") %>, <%= @meeting_minute.meeting_time_label %></dd></div>
          <div><dt class="inline font-black">A Hmun (Venue):</dt> <dd class="inline"><%= @meeting_minute.venue.presence || "-" %></dd></div>
          <div><dt class="inline font-black">Chairman:</dt> <dd class="inline"><%= @meeting_minute.chairman.presence || "-" %></dd></div>
          <div><dt class="inline font-black">Secretary:</dt> <dd class="inline"><%= @meeting_minute.minute_recorder.presence || "-" %></dd></div>
          <% if @meeting_minute.opening_prayer.present? %>
            <div><dt class="inline font-black">Opening Prayer:</dt> <dd class="inline"><%= @meeting_minute.opening_prayer %></dd></div>
          <% end %>
        </dl>
      </header>

      <section class="mt-8">
        <h3 class="text-lg font-black">Kal zat (Members Present):</h3>
        <% if present_users.any? %>
          <ol class="mt-5 list-decimal space-y-1 pl-12">
            <% present_users.each do |user| %>
              <li class="pl-2"><%= user.display_name %></li>
            <% end %>
          </ol>
        <% else %>
          <p class="mt-4 pl-10">No present members recorded.</p>
        <% end %>
      </section>

      <section class="mt-8">
        <h3 class="text-lg font-black">Member pha (Members Apology):</h3>
        <% if absent_users.any? %>
          <ol class="mt-5 list-decimal space-y-1 pl-12">
            <% absent_users.each do |user| %>
              <li class="pl-2"><%= user.display_name %></li>
            <% end %>
          </ol>
        <% else %>
          <p class="mt-4 pl-10">No apologies recorded.</p>
        <% end %>
      </section>

      <section class="mt-10">
        <h2 class="text-lg font-black uppercase">I. PROGRAMME TLANGPUI</h2>

        <div class="mt-6 space-y-5">
          <% if @meeting_minute.opening_prayer.present? %>
            <p><span class="font-black">Hun serh / Tawngtaina:</span> <%= @meeting_minute.opening_prayer %></p>
          <% end %>

          <% if @meeting_minute.welcome_speech.present? %>
            <p><span class="font-black">Chairman Thuhmahrui:</span> <%= @meeting_minute.welcome_speech %></p>
          <% end %>

          <% if @meeting_minute.previous_minutes_approval.present? %>
            <div>
              <p class="font-black">Previous Minute Approval:</p>
              <div class="mt-1 whitespace-pre-line"><%= @meeting_minute.previous_minutes_approval %></div>
            </div>
          <% end %>

          <% if @meeting_minute.reports.present? %>
            <div>
              <p class="font-black">Reports:</p>
              <div class="mt-1 whitespace-pre-line"><%= @meeting_minute.reports %></div>
            </div>
          <% end %>

          <div>
            <p class="font-black">Agenda:</p>
            <div class="minute-document-content mt-1 pl-6">
              <%= minute_rich_text(@meeting_minute.summary) %>
            </div>
          </div>
        </div>
      </section>

      <% if @meeting_minute.decisions.present? %>
        <section class="mt-8">
          <h2 class="text-lg font-black uppercase">II. THU RELTE (RESOLUTIONS)</h2>
          <div class="minute-document-content mt-3 pl-6">
            <%= minute_rich_text(@meeting_minute.decisions) %>
          </div>
        </section>
      <% end %>

      <section class="mt-4">
        <h2 class="text-lg font-black uppercase">MEETING KHARNA</h2>
        <p class="mt-3 whitespace-pre-line"><%= @meeting_minute.adjournment.presence || "Minute ngaihthlakna kan nei a, siam rem ngai te kan siam rem. Meeting chu tawngtaina hmanga khar a ni." %></p>
      </section>

      <footer class="mt-20 grid grid-cols-2 gap-10 text-center text-base leading-7 sm:gap-16">
        <div class="mx-auto w-full max-w-56 text-center">
          <% if @meeting_minute.chairman_signature.attached? %>
            <%= image_tag @meeting_minute.chairman_signature, class: "mx-auto h-14 max-w-44 object-contain" %>
          <% else %>
            <p class="text-center">Sd/-</p>
          <% end %>
          <p class="<%= @meeting_minute.chairman_signature.attached? ? "mt-6" : "mt-8" %> font-medium uppercase"><%= @meeting_minute.chairman_signature_display_name %></p>
          <p><%= @meeting_minute.chairman_signature_display_title %></p>
          <p>Mizo Society of Japan</p>
        </div>
        <div class="mx-auto w-full max-w-56 text-center">
          <% if @meeting_minute.secretary_signature.attached? %>
            <%= image_tag @meeting_minute.secretary_signature, class: "mx-auto h-14 max-w-44 object-contain" %>
          <% else %>
            <p class="text-center">Sd/-</p>
          <% end %>
          <p class="<%= @meeting_minute.secretary_signature.attached? ? "mt-6" : "mt-8" %> font-medium uppercase"><%= @meeting_minute.secretary_signature_display_name %></p>
          <p><%= @meeting_minute.secretary_signature_display_title %></p>
          <p>Mizo Society of Japan</p>
        </div>
      </footer>
    </div>
  </article>

  <% if @meeting_minute.file.attached? %>
    <%= render "shared/section_card", title: "PDF Attachment", body_class: "p-5" do %>
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="font-black text-[#0F172A] dark:text-white"><%= @meeting_minute.file.filename %></p>
          <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= formatted_file_size(@meeting_minute) %></p>
        </div>
        <%= link_to download_meeting_minute_path(@meeting_minute), class: action_button_classes(:secondary, size: :xs) do %>
          <%= icon_svg(:download, classes: "h-3.5 w-3.5") %>
          <span>Download</span>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
