<% action_name = field == :summary ? "focus->minute-editor#startAgenda input->simple-rich-text#sync input->minute-editor#refreshAgendaPoints keydown->minute-editor#continueNumbering blur->minute-editor#normalizeNumbering blur->simple-rich-text#sync blur->minute-editor#refreshAgendaPoints" : "input->simple-rich-text#sync keydown->minute-editor#continueNumbering blur->minute-editor#normalizeNumbering blur->simple-rich-text#sync" %>
<% target_name = field == :summary ? "agenda" : "decisions" %>
<% text_weight_class = local_assigns.fetch(:text_weight_class, "font-semibold") %>

<div class="mt-3 overflow-hidden rounded-xl border border-[#E2E8F0] bg-white focus-within:border-red-500 focus-within:ring-2 focus-within:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A]" data-controller="simple-rich-text">
  <% if local_assigns.fetch(:show_toolbar, true) %>
    <div class="flex items-center gap-1 border-b border-[#E2E8F0] bg-[#F8FAFC] px-2 py-1.5 dark:border-[#334155] dark:bg-[#1E293B]">
    <button type="button" class="grid h-8 w-8 place-items-center rounded-md text-sm font-black text-[#0F172A] transition hover:bg-white hover:text-red-700 data-[active=true]:bg-red-700 data-[active=true]:text-white data-[active=true]:shadow-sm data-[active=true]:hover:bg-red-800 dark:text-white dark:hover:bg-[#334155] dark:data-[active=true]:bg-red-600 dark:data-[active=true]:hover:bg-red-500" data-simple-rich-text-target="button" data-action="mousedown->simple-rich-text#keepFocus click->simple-rich-text#format" data-simple-rich-text-command-param="bold" data-active="false" title="Bold" aria-label="Bold" aria-pressed="false">B</button>
    <button type="button" class="grid h-8 w-8 place-items-center rounded-md text-sm font-black italic text-[#0F172A] transition hover:bg-white hover:text-red-700 data-[active=true]:bg-red-700 data-[active=true]:text-white data-[active=true]:shadow-sm data-[active=true]:hover:bg-red-800 dark:text-white dark:hover:bg-[#334155] dark:data-[active=true]:bg-red-600 dark:data-[active=true]:hover:bg-red-500" data-simple-rich-text-target="button" data-action="mousedown->simple-rich-text#keepFocus click->simple-rich-text#format" data-simple-rich-text-command-param="italic" data-active="false" title="Italic" aria-label="Italic" aria-pressed="false">I</button>
    <button type="button" class="grid h-8 w-8 place-items-center rounded-md text-sm font-black underline text-[#0F172A] transition hover:bg-white hover:text-red-700 data-[active=true]:bg-red-700 data-[active=true]:text-white data-[active=true]:shadow-sm data-[active=true]:hover:bg-red-800 dark:text-white dark:hover:bg-[#334155] dark:data-[active=true]:bg-red-600 dark:data-[active=true]:hover:bg-red-500" data-simple-rich-text-target="button" data-action="mousedown->simple-rich-text#keepFocus click->simple-rich-text#format" data-simple-rich-text-command-param="underline" data-active="false" title="Underline" aria-label="Underline" aria-pressed="false">U</button>
    </div>
  <% end %>
  <div contenteditable="true" role="textbox" aria-multiline="true" data-simple-rich-text-target="editor" data-minute-editor-target="<%= target_name %>" data-action="<%= action_name %>" class="<%= height_class %> <%= text_weight_class %> px-3 py-3 text-sm leading-6 text-[#0F172A] outline-none empty:before:text-[#64748B] empty:before:content-[attr(data-placeholder)] [&_ul]:my-2 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:my-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:my-1 dark:text-white dark:empty:before:text-[#CBD5E1]" data-placeholder="<%= placeholder %>"><%= minute_rich_text_editor_content(meeting_minute.public_send(field)) %></div>
  <%= form.hidden_field field, required: field == :summary, data: { simple_rich_text_target: "input" } %>
</div>
