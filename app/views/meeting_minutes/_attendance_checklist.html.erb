<section class="flex min-h-full flex-col rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]" data-controller="attendance-checklist">
  <div>
    <h2 class="font-black text-[#0F172A] dark:text-white">Attendance</h2>
    <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Mark members who attended, then record apologies separately.</p>
  </div>

  <%= hidden_field_tag "meeting_minute[present_attendee_ids][]", "" %>
  <div class="mt-4 max-h-52 space-y-2 overflow-y-auto overscroll-contain pr-1">
    <% users.each do |user| %>
      <% input_id = "meeting-minute-attendance-#{user.id}" %>
      <label for="<%= input_id %>" class="flex cursor-pointer items-center gap-3 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] px-3 py-2 transition hover:border-red-200 hover:bg-red-50/40 dark:border-[#334155] dark:bg-[#0F172A] dark:hover:border-red-500/30 dark:hover:bg-red-500/10">
        <%= check_box_tag "meeting_minute[present_attendee_ids][]", user.id, user.id.in?(meeting_minute.attendance_ids_for(:present)), id: input_id, class: "h-4 w-4 rounded border-[#CBD5E1] text-red-700 focus:ring-red-600", data: { attendance_checklist_target: "presentInput", attendance_checklist_name: user.display_name, attendance_checklist_role: role_label(user.role), action: "change->attendance-checklist#sync" } %>
        <span class="min-w-0">
          <span class="block truncate text-sm font-black text-[#0F172A] dark:text-white"><%= user.display_name %></span>
          <span class="block truncate text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= role_label(user.role) %></span>
        </span>
      </label>
    <% end %>
  </div>

  <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
    <section class="rounded-xl border border-emerald-200 bg-emerald-50/70 p-3 dark:border-emerald-500/30 dark:bg-emerald-500/10">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h3 class="font-black text-emerald-800 dark:text-emerald-200">Present</h3>
          <p class="mt-1 text-xs font-semibold text-emerald-700/80 dark:text-emerald-300">Marked present.</p>
        </div>
        <span data-attendance-checklist-target="presentCount" class="grid h-7 min-w-7 place-items-center rounded-full bg-white px-2 text-xs font-black text-emerald-700 shadow-sm dark:bg-[#0F172A] dark:text-emerald-300">0</span>
      </div>
      <textarea readonly rows="4" data-attendance-checklist-target="presentList" class="mt-3 block h-24 w-full resize-none rounded-lg border border-emerald-200 bg-white/80 px-3 py-2 text-sm font-semibold leading-6 text-emerald-900 outline-none dark:border-emerald-500/30 dark:bg-[#0F172A]/45 dark:text-emerald-100"></textarea>
    </section>

    <section class="rounded-xl border border-amber-200 bg-amber-50/70 p-3 dark:border-amber-500/30 dark:bg-amber-500/10">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h3 class="font-black text-amber-900 dark:text-amber-200">Apologies</h3>
          <p class="mt-1 text-xs font-semibold text-amber-800/80 dark:text-amber-300">Select members who sent an apology.</p>
        </div>
        <span data-attendance-checklist-target="apologyCount" class="grid h-7 min-w-7 place-items-center rounded-full bg-white px-2 text-xs font-black text-amber-800 shadow-sm dark:bg-[#0F172A] dark:text-amber-300">0</span>
      </div>
      <%= hidden_field_tag "meeting_minute[apology_attendee_ids][]", "" %>
      <div class="mt-3 max-h-24 space-y-1.5 overflow-y-auto overscroll-contain pr-1">
        <% users.each do |user| %>
          <% apology_id = "meeting-minute-apology-#{user.id}" %>
          <label for="<%= apology_id %>" class="flex cursor-pointer items-center gap-2 rounded-lg border border-amber-200 bg-white/80 px-2.5 py-2 dark:border-amber-500/30 dark:bg-[#0F172A]/45" data-attendance-checklist-target="apologyOption" data-user-id="<%= user.id %>">
            <%= check_box_tag "meeting_minute[apology_attendee_ids][]", user.id, user.id.in?(meeting_minute.attendance_ids_for(:apology)), id: apology_id, class: "h-4 w-4 rounded border-amber-300 text-amber-600 focus:ring-amber-500", data: { attendance_checklist_target: "apologyInput", action: "change->attendance-checklist#sync" } %>
            <span class="min-w-0 truncate text-sm font-bold text-amber-950 dark:text-amber-100"><%= user.display_name %></span>
          </label>
        <% end %>
      </div>
    </section>
  </div>

</section>
