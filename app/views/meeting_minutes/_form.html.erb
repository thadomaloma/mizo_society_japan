<% if meeting_minute.errors.any? %>
  <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-200">
    <p class="font-black">Please check the form.</p>
    <ul class="mt-2 list-disc space-y-1 pl-5"><% meeting_minute.errors.full_messages.each do |message| %><li><%= message %></li><% end %></ul>
  </div>
<% end %>

<%= form_with model: meeting_minute, class: "space-y-5" do |form| %>
  <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="mb-5 flex items-start gap-3">
      <div class="grid h-10 w-10 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300"><%= icon_svg(:documents, classes: "h-5 w-5") %></div>
      <div><h2 class="font-black text-[#0F172A] dark:text-white">Meeting details</h2><p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Enter the basic details for this meeting.</p></div>
    </div>

    <div class="grid gap-4">
      <div>
        <%= form.label :title, class: "text-sm font-black text-[#0F172A] dark:text-white" do %>Meeting Title <span class="text-red-600 dark:text-red-400">*</span><% end %>
        <%= form.text_field :title, required: true, placeholder: "e.g. Executive Committee Meeting / Office Bearers' Meeting Vawi 1-na", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        <div>
          <%= form.label :meeting_date, class: "text-sm font-black text-[#0F172A] dark:text-white" do %>Meeting Date <span class="text-red-600 dark:text-red-400">*</span><% end %>
          <%= form.date_field :meeting_date, required: true, class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
        </div>
        <div>
          <%= form.label :meeting_time, class: "text-sm font-black text-[#0F172A] dark:text-white" do %>Meeting Time <span class="text-red-600 dark:text-red-400">*</span><% end %>
          <%= form.time_field :meeting_time, required: true, class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
        </div>
        <div>
          <%= form.label :venue, "Venue", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
          <%= form.text_field :venue, placeholder: "e.g. Shinjuku, Tokyo or Zoom", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <div>
          <%= form.label :opening_prayer, "Opening Prayer", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
          <%= form.text_field :opening_prayer, placeholder: "e.g. Lalbiakzuali", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
        </div>
        <div>
          <%= form.label :welcome_speech, "Welcome Speech", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
          <%= form.text_field :welcome_speech, placeholder: "e.g. Welcome remarks by the Chairman", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
        </div>
      </div>
    </div>
  </section>

  <section class="space-y-5" data-controller="minute-editor">
    <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <%= form.label :previous_minutes_approval, "Previous Minute Approval", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
      <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Record how the previous meeting minutes were approved.</p>
      <%= form.text_area :previous_minutes_approval, rows: 2, placeholder: "e.g. Previous minutes were read and approved.", class: "mt-3 block w-full resize-y rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold leading-6 text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    </section>

    <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <%= form.label :reports, "Reports", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
      <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Add reports shared during the meeting.</p>
      <%= form.text_area :reports, rows: 3, placeholder: "e.g. Treasurer's report, ministry updates, and other reports.", class: "mt-3 block w-full resize-y rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold leading-6 text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    </section>

    <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="flex items-start justify-between gap-4">
        <div>
          <%= form.label :summary, class: "text-sm font-black text-[#0F172A] dark:text-white" do %>Meeting Agenda <span class="text-red-600 dark:text-red-400">*</span><% end %>
          <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Add each agenda item clearly before the meeting.</p>
        </div>
        <button type="button" class="<%= action_button_classes(:secondary, size: :xs) %>" data-action="minute-editor#insertAgenda" title="Add numbered agenda item">
          <%= icon_svg(:plus, classes: "h-3.5 w-3.5") %><span>Add item</span>
        </button>
      </div>
      <div class="<%= "hidden" unless meeting_minute.summary.present? || meeting_minute.errors[:summary].any? %>" data-minute-editor-target="agendaPanel">
        <%= render "simple_rich_text_editor", form: form, meeting_minute: meeting_minute, field: :summary, placeholder: "1. Opening prayer\n2. Previous meeting review\n3. New business", height_class: "min-h-12", show_toolbar: false, text_weight_class: "font-semibold" %>
      </div>
    </section>

    <div class="grid gap-5 lg:grid-cols-2">
      <%= render "attendance_checklist", form: form, meeting_minute: meeting_minute, users: @attendance_users %>

      <section class="flex min-h-full flex-col rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <div class="flex items-start justify-between gap-4">
          <div>
            <%= form.label :decisions, "Decisions / Resolutions", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
            <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Choose an agenda point, then add its decision.</p>
          </div>
        </div>
        <div class="mt-3 flex flex-col gap-2 sm:flex-row">
          <select class="min-w-0 flex-1 rounded-xl border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" data-minute-editor-target="agendaPoint">
            <option value="">Add agenda items first</option>
          </select>
          <button type="button" class="<%= action_button_classes(:secondary, size: :sm) %>" data-action="minute-editor#insertDecision" data-minute-editor-target="decisionButton" title="Add numbered decision for the selected agenda point" disabled>
            <%= icon_svg(:plus, classes: "h-4 w-4") %><span>Add decision</span>
          </button>
        </div>
        <div class="flex-1">
          <%= render "simple_rich_text_editor", form: form, meeting_minute: meeting_minute, field: :decisions, placeholder: "1. [Agenda 1] Write the agreed decision...", height_class: "min-h-48", text_weight_class: "font-normal" %>
        </div>
      </section>
    </div>

    <section class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <%= form.label :adjournment, "Adjournment", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
      <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Record how the meeting was closed.</p>
      <%= form.text_area :adjournment, rows: 3, placeholder: "e.g. The meeting was closed with prayer after all agenda items were discussed.", class: "mt-3 block w-full resize-y rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold leading-6 text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    </section>
  </section>

  <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="mb-5 flex items-start gap-3">
      <div class="grid h-10 w-10 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300"><%= icon_svg(:edit, classes: "h-5 w-5") %></div>
      <div>
        <h2 class="font-black text-[#0F172A] dark:text-white">Signature block</h2>
        <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Edit the names and titles shown at the bottom of the minute.</p>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= form.label :chairman_signature_name, "Chairman Name", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
        <%= form.text_field :chairman_signature_name, placeholder: meeting_minute.chairman.presence || "Chairman name", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      </div>
      <div>
        <%= form.label :chairman_signature_title, "Chairman Title", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
        <%= form.text_field :chairman_signature_title, placeholder: "President", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      </div>
      <div>
        <%= form.label :secretary_signature_name, "Secretary Name", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
        <%= form.text_field :secretary_signature_name, placeholder: meeting_minute.minute_recorder.presence || "Secretary name", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      </div>
      <div>
        <%= form.label :secretary_signature_title, "Secretary Title", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
        <%= form.text_field :secretary_signature_title, placeholder: "Gen. Secretary", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      </div>
      <div>
        <%= form.label :chairman_signature, "Chairman Signature PNG", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
        <%= form.file_field :chairman_signature, accept: "image/png,.png", class: "mt-2 block w-full rounded-xl border border-dashed border-[#CBD5E1] bg-[#F8FAFC] px-3 py-3 text-sm font-semibold text-[#0F172A] file:mr-3 file:rounded-lg file:border-0 file:bg-red-700 file:px-3 file:py-1.5 file:text-xs file:font-black file:text-white hover:file:bg-red-800 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
        <p class="mt-2 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">PNG file only. The PDF will only control display size.</p>
        <% if meeting_minute.chairman_signature.attached? %>
          <p class="mt-2 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Current signature: <%= meeting_minute.chairman_signature.filename %></p>
        <% end %>
      </div>
      <div>
        <%= form.label :secretary_signature, "Secretary Signature PNG", class: "text-sm font-black text-[#0F172A] dark:text-white" %>
        <%= form.file_field :secretary_signature, accept: "image/png,.png", class: "mt-2 block w-full rounded-xl border border-dashed border-[#CBD5E1] bg-[#F8FAFC] px-3 py-3 text-sm font-semibold text-[#0F172A] file:mr-3 file:rounded-lg file:border-0 file:bg-red-700 file:px-3 file:py-1.5 file:text-xs file:font-black file:text-white hover:file:bg-red-800 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
        <p class="mt-2 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">PNG file only. The PDF will only control display size.</p>
        <% if meeting_minute.secretary_signature.attached? %>
          <p class="mt-2 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Current signature: <%= meeting_minute.secretary_signature.filename %></p>
        <% end %>
      </div>
    </div>
  </section>

  <div class="flex flex-row flex-wrap gap-2 sm:justify-end">
    <%= link_to meeting_minutes_path, class: action_button_classes(:secondary, size: :sm, extra: "px-2 sm:px-3") do %><%= icon_svg(:x_mark, classes: "h-4 w-4") %><span>Cancel</span><% end %>
    <% if meeting_minute.new_record? || meeting_minute.draft? %>
      <%= form.button type: :submit, name: :commit_action, value: "draft", class: action_button_classes(:secondary, size: :sm, extra: "px-2 sm:px-3") do %><%= icon_svg(:save, classes: "h-4 w-4") %><span>Save Draft</span><% end %>
      <%= form.button type: :submit, name: :commit_action, value: "publish", class: action_button_classes(:primary, size: :sm, extra: "px-2 sm:px-3") do %><%= icon_svg(:upload, classes: "h-4 w-4") %><span>Publish</span><% end %>
    <% else %>
      <%= form.button type: :submit, name: :commit_action, value: "update", class: action_button_classes(:primary, size: :sm, extra: "px-2 sm:px-3") do %><%= icon_svg(:save, classes: "h-4 w-4") %><span>Update Minute</span><% end %>
    <% end %>
  </div>
<% end %>
