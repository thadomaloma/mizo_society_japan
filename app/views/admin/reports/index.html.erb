<% content_for :page_title, "Reports" %>

<div class="space-y-6">
  <%= render "shared/page_header",
    eyebrow: "Operations",
    title: "Reports",
    subtitle: "Export-ready summaries from existing MSJ portal records." %>

  <section class="grid min-w-0 gap-3 sm:gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% [
      {
        title: "Finance Report",
        description: "Income, expenses, balance, and category breakdown.",
        scope: "Money records",
        path: finance_admin_reports_path,
        icon: :finance,
        accent: "bg-emerald-50 text-emerald-700 ring-emerald-100 dark:bg-emerald-500/10 dark:text-emerald-300 dark:ring-emerald-500/20"
      },
      {
        title: "Member Report",
        description: "Member counts, profile status, and location summary.",
        scope: "Member data",
        path: members_admin_reports_path,
        icon: :members,
        accent: "bg-sky-50 text-sky-700 ring-sky-100 dark:bg-sky-500/10 dark:text-sky-300 dark:ring-sky-500/20"
      },
      {
        title: "Event Report",
        description: "Events, RSVP activity, and attendance totals.",
        scope: "Programme data",
        path: events_admin_reports_path,
        icon: :events,
        accent: "bg-violet-50 text-violet-700 ring-violet-100 dark:bg-violet-500/10 dark:text-violet-300 dark:ring-violet-500/20"
      },
      {
        title: "Welfare Report",
        description: "Open, urgent, resolved, and category totals.",
        scope: "Officer records",
        path: welfare_admin_reports_path,
        icon: :welfare,
        accent: "bg-red-50 text-red-700 ring-red-100 dark:bg-red-500/10 dark:text-red-300 dark:ring-red-500/20"
      }
    ].each do |report| %>
      <%= link_to report[:path], class: "group min-w-0 overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-red-200 hover:shadow-md dark:border-[#334155] dark:bg-[#1E293B] dark:hover:border-red-400/40 dark:hover:bg-[#334155] sm:p-5" do %>
        <div class="flex items-start justify-between gap-3">
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl ring-1 ring-inset <%= report[:accent] %> sm:h-12 sm:w-12">
            <%= icon_svg(report[:icon], classes: "h-5 w-5") %>
          </span>
          <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-[#F8FAFC] text-[#64748B] transition group-hover:bg-red-50 group-hover:text-red-700 dark:bg-[#0F172A] dark:text-[#CBD5E1] dark:group-hover:bg-red-500/10 dark:group-hover:text-red-300">
            <%= icon_svg(:arrow_right, classes: "h-4 w-4") %>
          </span>
        </div>

        <div class="mt-4 min-w-0">
          <h3 class="truncate text-base font-black text-gray-950 dark:text-white sm:text-lg"><%= report[:title] %></h3>
          <p class="mt-1.5 line-clamp-2 text-[13px] font-semibold leading-5 text-gray-500 dark:text-gray-400 sm:text-sm"><%= report[:description] %></p>
        </div>

        <div class="mt-4 flex items-center justify-between gap-3 border-t border-[#E2E8F0] pt-3 dark:border-[#334155]">
          <span class="truncate text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= report[:scope] %></span>
          <span class="shrink-0 text-xs font-black text-red-700 dark:text-red-300">Open</span>
        </div>
      <% end %>
    <% end %>
  </section>
</div>
