<% content_for :page_title, @member_profile.full_name %>
<% profile = @member_profile %>
<% user = profile.user %>
<% children = profile.family_members.select(&:child?) %>
<% spouse = profile.family_members.find(&:spouse?) %>

<div class="mx-auto max-w-6xl space-y-5 sm:space-y-6">
  <% header_actions = capture do %>
    <%= link_to members_admin_reports_path, class: action_button_classes(:secondary, size: :sm) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %><span>Member Report</span>
    <% end %>
  <% end %>
  <%= render "shared/page_header", eyebrow: "Confidential member record", title: profile.full_name, subtitle: "Contact, membership, address, and registered household details.", actions: header_actions %>

  <%= render ::RubyUI::Card.new(class: "overflow-hidden rounded-xl border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]") do %>
    <div class="flex flex-col gap-4 p-4 sm:flex-row sm:items-center sm:justify-between sm:p-5">
      <div class="flex min-w-0 items-center gap-3.5">
        <%= user_avatar(user, classes: "h-14 w-14", text_classes: "text-lg") %>
        <div class="min-w-0">
          <h1 class="truncate text-xl font-black text-[#0F172A] dark:text-white"><%= profile.full_name %></h1>
          <p class="mt-1 truncate text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= profile.membership_number %> · <%= user&.role&.humanize || "Member" %></p>
        </div>
      </div>
      <div class="flex items-center gap-2 sm:justify-end">
        <%= render "shared/status_badge", status: profile.status %>
        <span class="rounded-md bg-slate-50 px-2.5 py-1 text-xs font-black text-slate-700 ring-1 ring-slate-200 dark:bg-[#0F172A] dark:text-slate-200 dark:ring-[#334155]"><%= profile.profile_completion_percentage %>% complete</span>
      </div>
    </div>
  <% end %>

  <div class="grid gap-4 lg:grid-cols-2">
    <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5") do %>
      <div class="flex items-center gap-2"><span class="grid h-8 w-8 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300"><%= icon_svg(:members, classes: "h-4 w-4") %></span><h2 class="font-black text-[#0F172A] dark:text-white">Personal details</h2></div>
      <dl class="mt-4 grid grid-cols-2 gap-x-4 gap-y-4 text-sm">
        <% [ [ "Gender", profile.gender&.humanize || "Not recorded" ], [ "Date of birth", profile.date_of_birth&.strftime("%d %b %Y") || "Not recorded" ], [ "Age", profile.age || "Not recorded" ], [ "Family status", profile.family_status&.humanize || "Not recorded" ], [ "Father's name", profile.father_name.presence || "Not recorded" ], [ "Mother's name", profile.mother_name.presence || "Not recorded" ] ].each do |label, value| %>
          <div class="min-w-0"><dt class="text-xs font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= label %></dt><dd class="mt-1 break-words font-black text-[#0F172A] dark:text-white"><%= value %></dd></div>
        <% end %>
      </dl>
    <% end %>

    <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5") do %>
      <div class="flex items-center justify-between gap-3"><div class="flex items-center gap-2"><span class="grid h-8 w-8 place-items-center rounded-lg bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300"><%= icon_svg(:phone, classes: "h-4 w-4") %></span><h2 class="font-black text-[#0F172A] dark:text-white">Contact</h2></div><%= render "admin/shared/member_contact_actions", profile: profile %></div>
      <dl class="mt-4 space-y-4 text-sm">
        <div><dt class="text-xs font-bold text-[#64748B] dark:text-[#CBD5E1]">Mobile number</dt><dd class="mt-1 font-black text-[#0F172A] dark:text-white"><%= profile.mobile_number %></dd></div>
        <div><dt class="text-xs font-bold text-[#64748B] dark:text-[#CBD5E1]">Email address</dt><dd class="mt-1 break-all font-black text-[#0F172A] dark:text-white"><%= user&.email.presence || "Not recorded" %></dd></div>
        <div><dt class="text-xs font-bold text-[#64748B] dark:text-[#CBD5E1]">Full address</dt><dd class="mt-1 leading-6 font-black text-[#0F172A] dark:text-white">〒<%= profile.postal_code %><br><%= [ profile.prefecture, profile.city, profile.address_line1, profile.address_line2 ].compact_blank.join(" ") %></dd></div>
      </dl>
    <% end %>

    <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5") do %>
      <div class="flex items-center gap-2"><span class="grid h-8 w-8 place-items-center rounded-lg bg-sky-50 text-sky-700 dark:bg-sky-500/10 dark:text-sky-300"><%= icon_svg(:reports, classes: "h-4 w-4") %></span><h2 class="font-black text-[#0F172A] dark:text-white">Membership</h2></div>
      <dl class="mt-4 grid grid-cols-2 gap-x-4 gap-y-4 text-sm">
        <% [ [ "Membership number", profile.membership_number ], [ "Portal role", user&.role&.humanize || "Member" ], [ "Joined date", profile.joined_on&.strftime("%d %b %Y") || "Not recorded" ], [ "Account status", user&.active? ? "Active" : "Inactive" ] ].each do |label, value| %>
          <div><dt class="text-xs font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= label %></dt><dd class="mt-1 font-black text-[#0F172A] dark:text-white"><%= value %></dd></div>
        <% end %>
      </dl>
    <% end %>

    <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5") do %>
      <div class="flex items-center justify-between gap-3"><div class="flex items-center gap-2"><span class="grid h-8 w-8 place-items-center rounded-lg bg-amber-50 text-amber-700 dark:bg-amber-500/10 dark:text-amber-300"><%= icon_svg(:home, classes: "h-4 w-4") %></span><h2 class="font-black text-[#0F172A] dark:text-white">Registered household</h2></div><span class="text-xs font-black text-[#64748B] dark:text-[#CBD5E1]"><%= 1 + profile.family_members.size %> people</span></div>
      <% if spouse.present? || children.any? %>
        <div class="mt-4 divide-y divide-[#E2E8F0] dark:divide-[#334155]">
          <% [ spouse, *children ].compact.each do |member| %>
            <div class="flex items-start justify-between gap-3 py-3 first:pt-0 last:pb-0"><div class="min-w-0"><p class="truncate text-sm font-black text-[#0F172A] dark:text-white"><%= member.name %></p><p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= member.relationship %> · <%= member.membership_number.presence || "No member number" %></p></div><div class="shrink-0 text-right text-xs"><p class="font-black text-[#0F172A] dark:text-white"><%= member.age.present? ? "Age #{member.age}" : "Age not set" %></p><p class="mt-0.5 font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= member.date_of_birth&.strftime("%d %b %Y") || "DOB not set" %></p></div></div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-4 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">No spouse or children are registered under this account.</p>
      <% end %>
    <% end %>
  </div>

  <p class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2.5 text-xs font-bold leading-5 text-amber-900 dark:border-amber-500/30 dark:bg-amber-500/10 dark:text-amber-100">Confidential member information. Use it only for authorized MSJ administration.</p>
</div>
