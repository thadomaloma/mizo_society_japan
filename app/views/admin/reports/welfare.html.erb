<% content_for :page_title, "Welfare Report" %>

<div class="space-y-6">
  <% export_action = policy(:report).export? ? link_to(safe_join([ icon_svg(:download, classes: "h-4 w-4"), tag.span("Export CSV") ]), welfare_admin_reports_path(format: :csv), class: action_button_classes(:primary, size: :sm, extra: "px-3")) : nil %>
  <%= render "shared/page_header",
    eyebrow: "Reports",
    title: "Welfare Report",
    subtitle: "Confidential welfare case summary for authorized officers.",
    actions: export_action %>

  <% open_cases = @summary[:open_cases].to_i %>
  <% urgent_cases = @summary[:urgent_cases].to_i %>
  <% resolved_cases = @summary[:resolved_cases].to_i %>
  <% total_tracked = open_cases + resolved_cases %>
  <% resolved_percent = total_tracked.positive? ? ((resolved_cases.to_f / total_tracked) * 100).round : 0 %>
  <% urgent_percent = open_cases.positive? ? ((urgent_cases.to_f / open_cases) * 100).round : 0 %>
  <% category_rows = @summary[:by_category].to_h.sort_by { |_name, count| -count }.first(6) %>
  <% status_rows = @summary[:by_status].to_h.sort_by { |status, _count| status.to_s } %>
  <% recent_cases = Array(@summary[:recent_cases]) %>

  <section class="grid min-w-0 grid-cols-2 gap-2 sm:hidden">
    <div class="rounded-2xl border border-red-100 bg-red-50 p-3 shadow-sm dark:border-red-500/20 dark:bg-red-500/10">
      <p class="text-[11px] font-black uppercase tracking-wide text-red-700 dark:text-red-300">Open</p>
      <p class="mt-1 text-2xl font-black text-[#0F172A] dark:text-white"><%= open_cases %></p>
    </div>
    <div class="rounded-2xl border border-amber-100 bg-amber-50 p-3 shadow-sm dark:border-amber-500/20 dark:bg-amber-500/10">
      <p class="text-[11px] font-black uppercase tracking-wide text-amber-700 dark:text-amber-300">Urgent</p>
      <p class="mt-1 text-2xl font-black text-[#0F172A] dark:text-white"><%= urgent_cases %></p>
    </div>
    <div class="col-span-2 rounded-2xl border border-emerald-100 bg-emerald-50 p-3 shadow-sm dark:border-emerald-500/20 dark:bg-emerald-500/10">
      <div class="flex items-end justify-between gap-3">
        <div>
          <p class="text-[11px] font-black uppercase tracking-wide text-emerald-700 dark:text-emerald-300">Resolved</p>
          <p class="mt-1 text-2xl font-black text-[#0F172A] dark:text-white"><%= resolved_cases %></p>
        </div>
        <span class="rounded-full bg-white px-2.5 py-1 text-xs font-black text-emerald-700 shadow-sm dark:bg-[#1E293B] dark:text-emerald-300"><%= resolved_percent %>%</span>
      </div>
    </div>
  </section>

  <section class="hidden gap-4 sm:grid md:grid-cols-3">
    <%= render "shared/stat_card", label: "Open Cases", value: @summary[:open_cases], tone: "red", icon: :welfare %>
    <%= render "shared/stat_card", label: "Urgent Cases", value: @summary[:urgent_cases], tone: "amber", icon: :welfare %>
    <%= render "shared/stat_card", label: "Resolved Cases", value: @summary[:resolved_cases], tone: "green", icon: :welfare %>
  </section>

  <section class="grid min-w-0 gap-3 sm:gap-4 xl:grid-cols-[0.9fr_1.1fr]">
    <article class="min-w-0 overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="border-b border-[#E2E8F0] px-3 py-3 dark:border-[#334155] sm:px-5 sm:py-4">
        <div class="flex items-center justify-between gap-3">
          <div class="min-w-0">
            <h3 class="truncate text-base font-black text-[#0F172A] dark:text-white">Case Status</h3>
            <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Resolution and urgent-case balance.</p>
          </div>
          <span class="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300 sm:h-10 sm:w-10">
            <%= icon_svg(:welfare, classes: "h-4 w-4 sm:h-5 sm:w-5") %>
          </span>
        </div>
      </div>

      <div class="p-3 sm:p-5">
        <div class="grid grid-cols-2 gap-2">
          <div class="rounded-xl border border-emerald-100 bg-emerald-50 p-3 dark:border-emerald-500/20 dark:bg-emerald-500/10">
            <p class="text-[11px] font-black uppercase tracking-wide text-emerald-700 dark:text-emerald-300">Resolved</p>
            <p class="mt-1 text-xl font-black text-[#0F172A] dark:text-white"><%= resolved_percent %>%</p>
          </div>
          <div class="rounded-xl border border-amber-100 bg-amber-50 p-3 dark:border-amber-500/20 dark:bg-amber-500/10">
            <p class="text-[11px] font-black uppercase tracking-wide text-amber-700 dark:text-amber-300">Urgent Open</p>
            <p class="mt-1 text-xl font-black text-[#0F172A] dark:text-white"><%= urgent_percent %>%</p>
          </div>
        </div>

        <div class="mt-4 space-y-3">
          <% status_rows.each do |status, count| %>
            <% percent = total_tracked.positive? ? ((count.to_f / total_tracked) * 100).round : 0 %>
            <div>
              <div class="flex items-center justify-between gap-3">
                <div class="min-w-0"><%= render "shared/status_badge", status: status, compact: true %></div>
                <p class="shrink-0 text-xs font-black text-[#64748B] dark:text-[#CBD5E1]"><%= count %></p>
              </div>
              <div class="mt-1.5 h-2 overflow-hidden rounded-full bg-slate-100 dark:bg-[#0F172A]">
                <div class="h-full rounded-full bg-red-600 dark:bg-red-500" style="width: <%= percent %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </article>

    <article class="min-w-0 overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="border-b border-[#E2E8F0] px-3 py-3 dark:border-[#334155] sm:px-5 sm:py-4">
        <h3 class="text-base font-black text-[#0F172A] dark:text-white">Cases by Category</h3>
        <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Most used welfare support categories.</p>
      </div>

      <div class="space-y-2.5 p-3 sm:space-y-3 sm:p-5">
        <% if category_rows.any? %>
          <% category_rows.each do |category, count| %>
            <% percent = total_tracked.positive? ? ((count.to_f / total_tracked) * 100).round : 0 %>
            <div>
              <div class="flex items-center justify-between gap-3 text-sm">
                <p class="min-w-0 truncate font-black text-[#0F172A] dark:text-white"><%= category %></p>
                <p class="shrink-0 font-black text-[#64748B] dark:text-[#CBD5E1]"><%= count %></p>
              </div>
              <div class="mt-1.5 h-2 overflow-hidden rounded-full bg-slate-100 dark:bg-[#0F172A]">
                <div class="h-full rounded-full bg-amber-500" style="width: <%= percent %>%"></div>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="rounded-xl border border-dashed border-[#E2E8F0] p-4 text-sm font-semibold text-[#64748B] dark:border-[#334155] dark:text-[#CBD5E1]">No category data yet.</p>
        <% end %>
      </div>
    </article>
  </section>

  <section class="min-w-0 overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="border-b border-[#E2E8F0] px-3 py-3 dark:border-[#334155] sm:px-5 sm:py-4">
      <h3 class="text-base font-black text-[#0F172A] dark:text-white">Recent Welfare Cases</h3>
      <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Latest records visible to your role.</p>
    </div>

    <div class="divide-y divide-[#E2E8F0] dark:divide-[#334155]">
      <% if recent_cases.any? %>
        <% recent_cases.each do |welfare_case| %>
          <div class="grid min-w-0 gap-2 px-3 py-2.5 sm:grid-cols-[1fr_auto] sm:items-center sm:gap-3 sm:px-5 sm:py-3">
            <div class="min-w-0">
              <p class="truncate text-sm font-black text-[#0F172A] dark:text-white"><%= welfare_case.title %></p>
              <p class="mt-0.5 truncate text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= welfare_case.welfare_category.name %> · Assigned to <%= welfare_case.assigned_to&.display_name || "Unassigned" %></p>
            </div>
            <div class="flex items-center justify-between gap-3 sm:justify-end">
              <%= render "shared/status_badge", status: welfare_case.status, compact: true %>
              <span class="text-xs font-black text-[#64748B] dark:text-[#CBD5E1]"><%= welfare_case.submitted_at&.strftime("%b %d, %Y") || "No date" %></span>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="p-5 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">No welfare cases found.</p>
      <% end %>
    </div>
  </section>
</div>
