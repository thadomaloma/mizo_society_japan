<% content_for :page_title, "Member Report" %>
<% content_for :body_class, "members-report-page" %>

<% can_export_reports = policy(:report).export_members? %>
<% report_actions = [] %>
<% if can_export_reports %>
  <% report_actions << link_to(
    safe_join([ icon_svg(:download, classes: "h-4 w-4"), tag.span("Export CSV") ]),
    members_admin_reports_path(format: :csv),
    class: action_button_classes(:primary)
  ) %>
  <% report_actions << button_tag(
    type: :button,
    class: action_button_classes(:secondary),
    data: { action: "click->report-print#open" }
  ) { safe_join([ icon_svg(:printer, classes: "h-4 w-4"), tag.span("Print A4") ]) } %>
<% end %>

<% total_profiles = @summary[:total_profiles].to_i %>
<% active_percent = total_profiles.positive? ? ((@summary[:active_members].to_f / total_profiles) * 100).round : 0 %>
<% family_summary = @summary[:family_status] || {} %>
<% age_levels = Array(@summary[:age_levels]) %>
<% gender_summary = @summary[:gender] || {} %>
<% data_quality = @summary[:data_quality] || {} %>
<% top_prefectures = @summary[:by_prefecture].to_h.reject { |name, _count| name == "Not recorded" }.first(8) %>
<% profiles = @profiles %>
<% filters_active = @directory_filters.values.any?(&:present?) %>

<div class="members-report space-y-5" data-controller="report-print">
  <div class="members-report-screen-only">
    <%= render "shared/page_header",
      eyebrow: "Reports",
      title: "Member Community Report",
      subtitle: can_export_reports ? "Community demographics, household reach, location spread, and an export-ready member register." : "Community demographics, household reach, and location spread.",
      actions: safe_join(report_actions) %>
  </div>

  <div class="members-report-screen-only">
    <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-4") do %>
      <%= form_with url: members_admin_reports_path, method: :get, class: "grid grid-cols-2 gap-2 lg:grid-cols-[minmax(14rem,1fr)_10rem_10rem_11rem_10rem_auto]" do |form| %>
        <div class="relative col-span-2 lg:col-span-1">
          <span class="pointer-events-none absolute inset-y-0 left-0 grid w-10 place-items-center text-slate-400"><%= icon_svg(:search, classes: "h-4 w-4") %></span>
          <%= form.search_field :query, value: @directory_filters[:query], placeholder: "Search name, member no., mobile...", aria: { label: "Search member directory" }, class: "w-full rounded-lg border border-[#E2E8F0] bg-white py-2.5 pl-10 pr-3 text-sm font-semibold text-[#0F172A] outline-none placeholder:text-slate-400 focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white dark:placeholder:text-slate-400" %>
        </div>
        <%= form.select :status, options_for_select([[ "All statuses", "" ]] + MemberProfile.statuses.keys.map { |status| [ status.humanize, status ] }, @directory_filters[:status]), {}, aria: { label: "Member status" }, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
        <%= form.select :family_status, options_for_select([[ "All households", "" ]] + MemberProfile.family_statuses.keys.map { |status| [ status.humanize, status ] }, @directory_filters[:family_status]), {}, aria: { label: "Family status" }, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
        <%= form.select :prefecture, options_for_select([[ "All prefectures", "" ]] + @prefecture_options.map { |prefecture| [ prefecture_romaji(prefecture), prefecture ] }, @directory_filters[:prefecture]), {}, aria: { label: "Prefecture" }, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
        <%= form.select :age_group, options_for_select(Reports::MembersReport::AGE_FILTER_OPTIONS, @directory_filters[:age_group]), {}, aria: { label: "Age group" }, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
        <div class="col-span-2 flex justify-end gap-2 lg:col-span-1">
          <% if filters_active %>
            <%= link_to members_admin_reports_path, class: action_button_classes(:secondary, size: :sm) do %><%= icon_svg(:x_mark, classes: "h-4 w-4") %><span>Reset</span><% end %>
          <% end %>
          <%= form.button type: :submit, class: action_button_classes(:dark, size: :sm) do %><%= icon_svg(:filter, classes: "h-4 w-4") %><span>Filter</span><% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <article class="members-report-sheet overflow-hidden rounded-lg border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <header class="border-b border-[#E2E8F0] px-4 py-5 dark:border-[#334155] sm:px-6">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <p class="text-[10px] font-black uppercase tracking-[0.12em] text-red-700 dark:text-red-300">Mizo Society of Japan</p>
          <h1 class="mt-1 text-2xl font-black text-[#0F172A] dark:text-[#F8FAFC]">Member Community Report</h1>
          <p class="mt-1 max-w-2xl text-xs font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1]">A consolidated view of account holders, registered households, demographics, and member locations.</p>
        </div>
        <div class="shrink-0 text-right">
          <p class="text-[10px] font-black uppercase tracking-[0.08em] text-[#64748B] dark:text-[#CBD5E1]">Prepared</p>
          <p class="mt-1 text-xs font-black text-[#0F172A] dark:text-[#F8FAFC]"><%= Date.current.strftime("%d %b %Y") %></p>
          <p class="mt-0.5 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]">Portal member records</p>
        </div>
      </div>
    </header>

    <div class="space-y-5 p-4 sm:p-6">
      <section aria-label="Community summary" class="members-report-summary grid grid-cols-2 gap-2.5 lg:grid-cols-5">
        <div class="rounded-lg border border-red-100 bg-red-50/70 p-3 dark:border-red-500/20 dark:bg-red-500/10">
          <p class="text-[10px] font-black uppercase tracking-[0.08em] text-red-700 dark:text-red-300">Account Holders</p>
          <p class="mt-1 text-xl font-black tabular-nums text-[#0F172A] dark:text-white"><%= total_profiles %></p>
          <p class="mt-1 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]">Completed profiles</p>
        </div>
        <div class="rounded-lg border border-emerald-100 bg-emerald-50/70 p-3 dark:border-emerald-500/20 dark:bg-emerald-500/10">
          <p class="text-[10px] font-black uppercase tracking-[0.08em] text-emerald-700 dark:text-emerald-300">Active</p>
          <p class="mt-1 text-xl font-black tabular-nums text-[#0F172A] dark:text-white"><%= @summary[:active_members] %></p>
          <p class="mt-1 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= active_percent %>% of profiles</p>
        </div>
        <div class="rounded-lg border border-sky-100 bg-sky-50/70 p-3 dark:border-sky-500/20 dark:bg-sky-500/10">
          <p class="text-[10px] font-black uppercase tracking-[0.08em] text-sky-700 dark:text-sky-300">Household Reach</p>
          <p class="mt-1 text-xl font-black tabular-nums text-[#0F172A] dark:text-white"><%= @summary[:household_population] %></p>
          <p class="mt-1 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]">Profiles, spouses, children</p>
        </div>
        <div class="rounded-lg border border-violet-100 bg-violet-50/70 p-3 dark:border-violet-500/20 dark:bg-violet-500/10">
          <p class="text-[10px] font-black uppercase tracking-[0.08em] text-violet-700 dark:text-violet-300">Children</p>
          <p class="mt-1 text-xl font-black tabular-nums text-[#0F172A] dark:text-white"><%= @summary[:registered_children] %></p>
          <p class="mt-1 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= @summary[:children_14_and_over] %> aged 14+</p>
        </div>
        <div class="col-span-2 rounded-lg border border-amber-100 bg-amber-50/70 p-3 dark:border-amber-500/20 dark:bg-amber-500/10 lg:col-span-1">
          <p class="text-[10px] font-black uppercase tracking-[0.08em] text-amber-700 dark:text-amber-300">New This Month</p>
          <p class="mt-1 text-xl font-black tabular-nums text-[#0F172A] dark:text-white"><%= @summary[:new_members_this_month] %></p>
          <p class="mt-1 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= Date.current.strftime("%B %Y") %></p>
        </div>
      </section>

      <section class="members-report-demographics members-report-block grid gap-3 lg:grid-cols-3">
        <div class="rounded-lg border border-[#E2E8F0] p-4 dark:border-[#334155]">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h2 class="text-sm font-black text-[#0F172A] dark:text-white">Family Status</h2>
              <p class="mt-0.5 text-[11px] font-semibold text-[#64748B] dark:text-[#CBD5E1]">Account holder households</p>
            </div>
            <span class="text-xs font-black text-red-700 dark:text-red-300"><%= family_summary[:family_percentage].to_i %>% family</span>
          </div>
          <div class="mt-4 h-2.5 overflow-hidden rounded-full bg-slate-200 dark:bg-[#0F172A]">
            <div class="h-full bg-red-600 dark:bg-red-500" style="width: <%= family_summary[:family_percentage].to_i %>%"></div>
          </div>
          <dl class="mt-4 grid grid-cols-2 gap-2 text-xs">
            <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Family</dt><dd class="mt-0.5 text-lg font-black text-[#0F172A] dark:text-white"><%= family_summary[:family].to_i %></dd></div>
            <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Single</dt><dd class="mt-0.5 text-lg font-black text-[#0F172A] dark:text-white"><%= family_summary[:single].to_i %></dd></div>
          </dl>
        </div>

        <div class="rounded-lg border border-[#E2E8F0] p-4 dark:border-[#334155]">
          <h2 class="text-sm font-black text-[#0F172A] dark:text-white">Gender</h2>
          <p class="mt-0.5 text-[11px] font-semibold text-[#64748B] dark:text-[#CBD5E1]">Account holder records</p>
          <dl class="mt-4 space-y-3 text-xs">
            <% [ [ "Male", gender_summary[:male], "bg-sky-600" ], [ "Female", gender_summary[:female], "bg-red-600" ], [ "Not recorded", gender_summary[:not_recorded], "bg-slate-400" ] ].each do |label, count, color| %>
              <% share = total_profiles.positive? ? ((count.to_f / total_profiles) * 100).round : 0 %>
              <div>
                <div class="flex items-center justify-between gap-3"><dt class="font-black text-[#0F172A] dark:text-white"><%= label %></dt><dd class="font-black text-[#64748B] dark:text-[#CBD5E1]"><%= count %> · <%= share %>%</dd></div>
                <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-slate-100 dark:bg-[#0F172A]"><div class="h-full rounded-full <%= color %>" style="width: <%= share %>%"></div></div>
              </div>
            <% end %>
          </dl>
        </div>

        <div class="rounded-lg border border-[#E2E8F0] p-4 dark:border-[#334155]">
          <h2 class="text-sm font-black text-[#0F172A] dark:text-white">Registered Household</h2>
          <p class="mt-0.5 text-[11px] font-semibold text-[#64748B] dark:text-[#CBD5E1]">People linked to account holders</p>
          <dl class="mt-4 grid grid-cols-2 gap-x-4 gap-y-3 text-xs">
            <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Spouses</dt><dd class="mt-0.5 text-lg font-black text-[#0F172A] dark:text-white"><%= @summary[:registered_spouses] %></dd></div>
            <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Children</dt><dd class="mt-0.5 text-lg font-black text-[#0F172A] dark:text-white"><%= @summary[:registered_children] %></dd></div>
            <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Children 14+</dt><dd class="mt-0.5 text-lg font-black text-[#0F172A] dark:text-white"><%= @summary[:children_14_and_over] %></dd></div>
            <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Total Reach</dt><dd class="mt-0.5 text-lg font-black text-red-700 dark:text-red-300"><%= @summary[:household_population] %></dd></div>
          </dl>
        </div>
      </section>

      <section class="members-report-analysis members-report-block grid gap-3 lg:grid-cols-[1.15fr_0.85fr]">
        <div class="rounded-lg border border-[#E2E8F0] p-4 dark:border-[#334155]">
          <div class="flex items-center justify-between gap-3">
            <div><h2 class="text-sm font-black text-[#0F172A] dark:text-white">Age Distribution</h2><p class="mt-0.5 text-[11px] font-semibold text-[#64748B] dark:text-[#CBD5E1]">Account holders by age group</p></div>
            <span class="text-[10px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= total_profiles %> profiles</span>
          </div>
          <div class="mt-4 grid grid-cols-7 items-end gap-2" aria-label="Member age distribution chart">
            <% max_age_count = [ age_levels.map { |bucket| bucket[:count].to_i }.max.to_i, 1 ].max %>
            <% age_levels.each do |bucket| %>
              <% bar_height = bucket[:count].to_i.zero? ? 3 : [ ((bucket[:count].to_f / max_age_count) * 72).round, 8 ].max %>
              <div class="flex min-w-0 flex-col items-center justify-end">
                <span class="text-[10px] font-black tabular-nums text-[#0F172A] dark:text-white"><%= bucket[:count] %></span>
                <div class="mt-1 w-full max-w-8 rounded-t bg-red-600 dark:bg-red-500" style="height: <%= bar_height %>px"></div>
                <span class="mt-1 w-full truncate text-center text-[9px] font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= bucket[:label] %></span>
              </div>
            <% end %>
          </div>
        </div>

        <div class="rounded-lg border border-[#E2E8F0] p-4 dark:border-[#334155]">
          <div class="flex items-center justify-between gap-3"><div><h2 class="text-sm font-black text-[#0F172A] dark:text-white">Top Prefectures</h2><p class="mt-0.5 text-[11px] font-semibold text-[#64748B] dark:text-[#CBD5E1]">Account holder locations</p></div><span class="text-[10px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Top <%= top_prefectures.size %></span></div>
          <div class="mt-3 space-y-2">
            <% top_prefectures.each do |prefecture, count| %>
              <% share = total_profiles.positive? ? ((count.to_f / total_profiles) * 100).round : 0 %>
              <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-3 text-xs">
                <div class="min-w-0"><div class="flex justify-between gap-2"><p class="truncate font-black text-[#0F172A] dark:text-white"><%= prefecture_romaji(prefecture) %></p><span class="font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= share %>%</span></div><div class="mt-1 h-1.5 overflow-hidden rounded-full bg-slate-100 dark:bg-[#0F172A]"><div class="h-full rounded-full bg-[#0F172A] dark:bg-red-500" style="width: <%= share %>%"></div></div></div>
                <span class="font-black tabular-nums text-[#0F172A] dark:text-white"><%= count %></span>
              </div>
            <% end %>
            <% if top_prefectures.empty? %><p class="text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">No location data recorded.</p><% end %>
          </div>
        </div>
      </section>

      <section class="members-report-quality members-report-block rounded-lg border border-[#E2E8F0] p-4 dark:border-[#334155]">
        <div class="flex items-center justify-between gap-3"><div><h2 class="text-sm font-black text-[#0F172A] dark:text-white">Data Quality</h2><p class="mt-0.5 text-[11px] font-semibold text-[#64748B] dark:text-[#CBD5E1]">Coverage of fields used for community planning</p></div><span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-black text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300"><%= data_quality[:completion_percentage].to_i %>% complete</span></div>
        <dl class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-5">
          <% [ [ "Complete Profiles", data_quality[:complete_profiles] ], [ "Gender", data_quality[:gender_recorded] ], [ "Date of Birth", data_quality[:date_of_birth_recorded] ], [ "Mobile", data_quality[:mobile_recorded] ], [ "Address", data_quality[:address_complete] ] ].each do |label, count| %>
            <% share = total_profiles.positive? ? ((count.to_f / total_profiles) * 100).round : 0 %>
            <div class="rounded-md bg-[#F8FAFC] p-2.5 dark:bg-[#0F172A]"><dt class="text-[10px] font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= label %></dt><dd class="mt-1 text-sm font-black text-[#0F172A] dark:text-white"><%= count %> <span class="text-[10px] font-bold text-[#64748B] dark:text-[#CBD5E1]">(<%= share %>%)</span></dd></div>
          <% end %>
        </dl>
      </section>

      <section class="members-report-directory members-report-block overflow-hidden rounded-lg border border-[#E2E8F0] dark:border-[#334155]">
        <div class="flex items-center justify-between gap-3 border-b border-[#E2E8F0] px-4 py-3 dark:border-[#334155]">
          <div><h2 class="text-sm font-black text-[#0F172A] dark:text-white">Member Directory</h2><p class="mt-0.5 text-[11px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= pluralize(@pagination[:total_count], "matching profile") %> of <%= total_profiles %>, sorted by name</p></div>
          <span class="text-[10px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Confidential</span>
        </div>

        <div class="members-report-directory-table hidden overflow-x-auto sm:block">
          <table class="w-full text-left text-xs">
            <thead class="bg-[#F8FAFC] text-[10px] font-black uppercase tracking-[0.05em] text-[#64748B] dark:bg-[#0F172A] dark:text-[#CBD5E1]">
              <tr><th class="px-3 py-2.5">Member</th><th class="px-3 py-2.5">Contact</th><th class="px-3 py-2.5">Demographics</th><th class="px-3 py-2.5">Household</th><th class="px-3 py-2.5">Location</th><th class="px-3 py-2.5">Status</th></tr>
            </thead>
            <tbody class="divide-y divide-[#E2E8F0] dark:divide-[#334155]">
              <% profiles.each do |profile| %>
                <tr class="members-report-directory-row align-top">
                  <td class="px-3 py-2.5"><p class="font-black text-[#0F172A] dark:text-white"><%= profile.full_name %></p><p class="mt-0.5 whitespace-nowrap text-[10px] font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= profile.membership_number %> · <%= profile.user&.role&.humanize %></p><% if @can_view_member_details %><%= link_to admin_member_report_path(profile), class: "members-report-screen-only mt-1 inline-flex items-center gap-1 text-[10px] font-black text-red-700 hover:text-red-800 dark:text-red-300" do %><%= icon_svg(:eye, classes: "h-3 w-3") %> View details<% end %><% end %></td>
                  <td class="px-3 py-2.5"><% if @can_view_member_details %><p class="whitespace-nowrap font-bold text-[#0F172A] dark:text-white"><%= profile.mobile_number %></p><p class="mt-0.5 max-w-44 truncate text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= profile.user&.email %></p><% else %><p class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Office Bearers only</p><% end %></td>
                  <td class="px-3 py-2.5"><p class="font-bold text-[#0F172A] dark:text-white"><%= profile.gender&.humanize || "Not recorded" %> · <%= profile.age || "Age unknown" %></p><p class="mt-0.5 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= profile.family_status&.humanize || "Not recorded" %></p></td>
                  <td class="px-3 py-2.5"><p class="font-bold text-[#0F172A] dark:text-white"><%= 1 + profile.family_members.size %> people</p><p class="mt-0.5 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= pluralize(profile.family_members.count(&:child?), "child") %></p></td>
                  <td class="px-3 py-2.5"><p class="font-bold text-[#0F172A] dark:text-white"><%= profile.city.presence || "Not recorded" %></p><p class="mt-0.5 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= prefecture_romaji(profile.prefecture) || "Not recorded" %></p></td>
                  <td class="px-3 py-2.5"><%= render "shared/status_badge", status: profile.status, compact: true %><p class="mt-1 text-[10px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= profile.joined_on&.strftime("%d %b %Y") || "No join date" %></p></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="members-report-directory-cards divide-y divide-[#E2E8F0] dark:divide-[#334155] sm:hidden">
          <% profiles.each do |profile| %>
            <article class="p-3">
              <div class="flex items-start justify-between gap-3"><div class="min-w-0"><p class="truncate text-sm font-black text-[#0F172A] dark:text-white"><%= profile.full_name %></p><p class="mt-0.5 truncate text-[11px] font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= profile.membership_number %> · <%= profile.user&.role&.humanize %></p></div><%= render "shared/status_badge", status: profile.status, compact: true %></div>
              <dl class="mt-3 grid grid-cols-2 gap-x-3 gap-y-2 text-xs">
                <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Mobile</dt><dd class="mt-0.5 font-black text-[#0F172A] dark:text-white"><%= @can_view_member_details ? profile.mobile_number : "Restricted" %></dd></div>
                <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Age / Gender</dt><dd class="mt-0.5 font-black text-[#0F172A] dark:text-white"><%= profile.age || "-" %> · <%= profile.gender&.humanize || "Not set" %></dd></div>
                <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Household</dt><dd class="mt-0.5 font-black text-[#0F172A] dark:text-white"><%= 1 + profile.family_members.size %> people</dd></div>
                <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Location</dt><dd class="mt-0.5 truncate font-black text-[#0F172A] dark:text-white"><%= profile.city.presence || "-" %>, <%= prefecture_romaji(profile.prefecture) || "-" %></dd></div>
              </dl>
              <% if @can_view_member_details %><%= link_to admin_member_report_path(profile), class: "members-report-screen-only mt-3 inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-xs font-black text-[#0F172A] shadow-sm transition hover:border-red-200 hover:text-red-700 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white dark:hover:text-red-300" do %><%= icon_svg(:eye, classes: "h-3.5 w-3.5") %><span>View Member Details</span><% end %><% end %>
            </article>
          <% end %>
        </div>

        <% if profiles.empty? %><div class="p-8 text-center"><p class="text-sm font-black text-[#0F172A] dark:text-white">No member profiles found.</p><p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Completed profiles will appear in this report.</p></div><% end %>
        <div class="members-report-screen-only">
          <%= render "shared/data_table_footer", pagination: @pagination, label: "member profiles" %>
        </div>
      </section>

      <footer class="members-report-footer hidden border-t border-[#E2E8F0] pt-3 text-[9px] font-semibold text-[#64748B] dark:border-[#334155] dark:text-[#CBD5E1]">
        Confidential MSJ community record. Household reach is an estimate based on registered account holders, spouses, and children in the portal.
      </footer>
    </div>
  </article>
</div>
