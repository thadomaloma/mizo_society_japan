<% content_for :page_title, "Edit Internal Note" %>

<div class="mx-auto max-w-3xl space-y-6">
  <%= render "shared/page_header",
    eyebrow: "Confidential welfare",
    title: "Edit Internal Note",
    subtitle: "Case ##{@welfare_case.id} · #{@welfare_case.title}" %>

  <%= form_with model: [ :admin, @welfare_case, @welfare_note ], class: "space-y-5 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm" do |form| %>
    <% if @welfare_note.errors.any? %>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-700">
        <%= @welfare_note.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= form.label :body, class: "block text-sm font-bold text-gray-700" %>
      <%= form.text_area :body, rows: 7, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm font-bold text-gray-700">
      <%= form.check_box :internal, class: "h-4 w-4 rounded border-gray-300 text-red-700 focus:ring-red-600" %>
      Internal note
    </label>

    <div class="grid grid-cols-2 gap-2 sm:flex sm:justify-end">
      <%= link_to admin_welfare_case_path(@welfare_case), class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
        <span>Cancel</span>
      <% end %>
      <%= form.button type: :submit, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:save, classes: "h-4 w-4") %>
        <span>Update Note</span>
      <% end %>
    </div>
  <% end %>
</div>
