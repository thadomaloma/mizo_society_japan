<% content_for :page_title, "User Roles" %>

<div class="space-y-6">
  <% user_role_actions = capture do %>
    <%= link_to new_admin_user_role_path, class: action_button_classes(:primary) do %>
      <%= icon_svg(:user_plus, classes: "h-4 w-4") %>
      <span>Add User</span>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Settings",
    title: "User Roles",
    subtitle: "Manage user details, portal roles, and secure account access.",
    actions: user_role_actions %>

  <%= form_with url: admin_user_roles_path, method: :get, class: "grid gap-3 rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm md:grid-cols-[1fr_14rem_auto] dark:border-[#334155] dark:bg-[#1E293B]" do |form| %>
    <div class="relative">
      <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-[#64748B] dark:text-[#CBD5E1]">
        <%= icon_svg(:search, classes: "h-4 w-4") %>
      </span>
      <%= form.search_field :query,
        value: @query,
        placeholder: "Search users...",
        class: "block w-full rounded-xl border border-[#E2E8F0] bg-white py-2 pl-9 pr-3 text-sm font-semibold text-[#0F172A] outline-none transition placeholder:text-[#64748B] focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#F8FAFC]" %>
    </div>

    <%= form.select :role,
      options_for_select([ [ "All roles", "" ] ] + @role_options, @role),
      {},
      class: "rounded-xl border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none transition focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#F8FAFC]" %>

    <%= form.button type: :submit, class: action_button_classes(:dark) do %>
      <%= icon_svg(:filter, classes: "h-4 w-4") %>
      <span>Filter</span>
    <% end %>
  <% end %>

  <% if @users.any? %>
    <div class="hidden overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B] lg:block">
      <table class="min-w-full divide-y divide-[#E2E8F0] text-left text-sm dark:divide-[#334155]">
        <thead class="bg-[#F8FAFC] text-xs font-black uppercase tracking-wide text-[#64748B] dark:bg-[#0F172A] dark:text-[#CBD5E1]">
          <tr>
            <th class="px-5 py-3">Name</th>
            <th class="px-5 py-3">Email</th>
            <th class="px-5 py-3">Current Role</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#E2E8F0] bg-white dark:divide-[#334155] dark:bg-[#1E293B]">
          <% @users.each do |user| %>
            <tr>
              <td class="px-5 py-4">
                <p class="font-black text-[#0F172A] dark:text-white"><%= user.display_name %></p>
                <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= user.member_profile&.membership_number || "No profile" %></p>
              </td>
              <td class="px-5 py-4 font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= user.email %></td>
              <td class="px-5 py-4">
                <span class="inline-flex rounded-full bg-red-50 px-2.5 py-1 text-xs font-black text-red-700 ring-1 ring-inset ring-red-200 dark:bg-red-500/10 dark:text-red-300 dark:ring-red-500/30">
                  <%= role_label(user.role) %>
                </span>
              </td>
              <td class="px-5 py-4">
                <%= render "shared/status_badge", status: user.active? ? "active" : "inactive" %>
              </td>
              <td class="px-5 py-4">
                <div class="flex justify-end gap-2">
                  <%= link_to edit_admin_user_role_path(user), class: action_button_classes(:secondary, size: :xs) do %>
                    <%= icon_svg(:edit, classes: "h-3.5 w-3.5") %>
                    <span>Edit</span>
                  <% end %>
                  <% if user != current_user %>
                    <% if user.active? %>
                      <%= button_to deactivate_admin_user_role_path(user), method: :patch, data: { turbo_confirm: "Deactivate #{user.display_name}? They will not be able to sign in until reactivated." }, class: action_button_classes(:outline_danger, size: :xs) do %>
                        <%= icon_svg(:lock, classes: "h-3.5 w-3.5") %>
                        <span>Deactivate</span>
                      <% end %>
                    <% else %>
                      <%= button_to reactivate_admin_user_role_path(user), method: :patch, class: action_button_classes(:success, size: :xs) do %>
                        <%= icon_svg(:check, classes: "h-3.5 w-3.5") %>
                        <span>Reactivate</span>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="grid gap-4 lg:hidden">
      <% @users.each do |user| %>
        <article class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-black text-[#0F172A] dark:text-white"><%= user.display_name %></h3>
              <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= user.email %></p>
            </div>
            <%= render "shared/status_badge", status: user.active? ? "active" : "inactive" %>
          </div>

          <div class="mt-4 rounded-xl bg-[#F8FAFC] p-3 dark:bg-[#0F172A]">
            <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Current Role</p>
            <p class="mt-1 font-black text-red-700 dark:text-red-300"><%= role_label(user.role) %></p>
          </div>

          <div class="mt-4 grid grid-cols-2 gap-2">
            <%= link_to edit_admin_user_role_path(user), class: action_button_classes(:secondary, full_width: true) do %>
              <%= icon_svg(:edit, classes: "h-4 w-4") %>
              <span>Edit</span>
            <% end %>
            <% if user != current_user %>
              <% if user.active? %>
                <%= button_to deactivate_admin_user_role_path(user), method: :patch, data: { turbo_confirm: "Deactivate #{user.display_name}? They will not be able to sign in until reactivated." }, class: action_button_classes(:outline_danger, full_width: true) do %>
                  <%= icon_svg(:lock, classes: "h-4 w-4") %>
                  <span>Deactivate</span>
                <% end %>
              <% else %>
                <%= button_to reactivate_admin_user_role_path(user), method: :patch, class: action_button_classes(:success, full_width: true) do %>
                  <%= icon_svg(:check, classes: "h-4 w-4") %>
                  <span>Reactivate</span>
                <% end %>
              <% end %>
            <% else %>
              <span class="inline-flex items-center justify-center rounded-lg border border-slate-200 px-3 py-2 text-xs font-black text-slate-500 dark:border-[#334155] dark:text-slate-300">Current account</span>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No users found.", message: "Try another search or role filter." %>
  <% end %>
</div>
