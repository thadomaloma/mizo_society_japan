<% content_for :page_title, "Permissions" %>

<div class="space-y-6">
  <%= render "shared/page_header",
    eyebrow: "Settings",
    title: "Permissions",
    subtitle: "Role groups and access boundaries used across the portal." %>

  <div class="grid gap-4 lg:grid-cols-2">
    <% @permission_groups.each do |group| %>
      <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="text-lg font-black text-[#0F172A] dark:text-white"><%= group[:name] %></h3>
            <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= group[:users] %></p>
          </div>
          <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300">
            <%= icon_svg(:lock, classes: "h-5 w-5") %>
          </div>
        </div>

        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <div>
            <p class="text-xs font-black uppercase tracking-wide text-emerald-700 dark:text-emerald-300">Can</p>
            <div class="mt-3 space-y-2">
              <% group[:permissions].each do |permission| %>
                <div class="flex gap-2 text-sm font-semibold text-[#0F172A] dark:text-[#F8FAFC]">
                  <span class="mt-0.5 text-emerald-600 dark:text-emerald-300"><%= icon_svg(:check, classes: "h-4 w-4") %></span>
                  <span><%= permission %></span>
                </div>
              <% end %>
            </div>
          </div>

          <div>
            <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">Cannot</p>
            <% if group[:restrictions].any? %>
              <div class="mt-3 space-y-2">
                <% group[:restrictions].each do |restriction| %>
                  <div class="flex gap-2 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">
                    <span class="mt-0.5 text-red-600 dark:text-red-300"><%= icon_svg(:x_mark, classes: "h-4 w-4") %></span>
                    <span><%= restriction %></span>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="mt-3 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">No listed restrictions.</p>
            <% end %>
          </div>
        </div>
      </section>
    <% end %>
  </div>
</div>
