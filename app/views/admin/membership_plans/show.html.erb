<% content_for :page_title, @membership_plan.name %>

<div class="space-y-6">
  <% plan_actions = capture do %>
    <%= link_to admin_membership_plans_path, class: action_button_classes(:secondary, size: :sm) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Back</span>
    <% end %>
    <% if policy(@membership_plan).update? %>
      <%= link_to edit_admin_membership_plan_path(@membership_plan), class: action_button_classes(:primary, size: :sm) do %>
        <%= icon_svg(:edit, classes: "h-4 w-4") %>
        <span>Edit Plan</span>
      <% end %>
    <% end %>
    <% if policy(@membership_plan).destroy? %>
      <% if @membership_plan.membership_payments.exists? %>
        <span class="<%= action_button_classes(:secondary, size: :sm, extra: "cursor-not-allowed opacity-60") %>" title="This plan has payment records. Deactivate it instead of deleting." aria-label="This payment plan cannot be deleted because payment records exist">
          <%= icon_svg(:trash, classes: "h-4 w-4") %>
          <span>In use</span>
        </span>
      <% else %>
        <%= button_to admin_membership_plan_path(@membership_plan), method: :delete, data: { turbo_confirm: "Delete #{@membership_plan.name}? This cannot be undone." }, class: action_button_classes(:outline_danger, size: :sm), title: "Delete payment plan" do %>
          <%= icon_svg(:trash, classes: "h-4 w-4") %>
          <span>Delete</span>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Payment Plan",
    title: @membership_plan.name,
    subtitle: "Plan details and payment configuration.",
    actions: plan_actions %>

  <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-6">
    <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-5">
      <div>
        <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Amount</p>
        <p class="mt-2 text-3xl font-black text-[#0F172A] dark:text-white"><%= yen(@membership_plan.amount) %></p>
      </div>
      <div>
        <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Billing cycle</p>
        <p class="mt-2 text-lg font-black capitalize text-[#0F172A] dark:text-white"><%= @membership_plan.billing_cycle.humanize %></p>
      </div>
      <div>
        <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Plan type</p>
        <p class="mt-2"><span class="inline-flex items-center rounded-md bg-red-50 px-2.5 py-1.5 text-sm font-bold text-red-700 dark:bg-red-950/40 dark:text-red-200"><%= @membership_plan.plan_type_label %></span></p>
      </div>
      <div>
        <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Status</p>
        <p class="mt-2"><%= render "shared/status_badge", status: @membership_plan.active? ? "active" : "inactive" %></p>
      </div>
      <div>
        <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Member billing</p>
        <p class="mt-2">
          <% if @membership_plan.required_for_members? %>
            <span class="inline-flex items-center rounded-md bg-red-50 px-2.5 py-1.5 text-sm font-bold text-red-700 ring-1 ring-red-100 dark:bg-red-500/10 dark:text-red-300 dark:ring-red-500/20">Required</span>
          <% else %>
            <span class="inline-flex items-center rounded-md bg-slate-50 px-2.5 py-1.5 text-sm font-bold text-[#64748B] ring-1 ring-[#E2E8F0] dark:bg-[#0F172A] dark:text-[#CBD5E1] dark:ring-[#334155]">Optional</span>
          <% end %>
        </p>
      </div>
    </div>
    <div class="mt-6 border-t border-[#E2E8F0] pt-6 dark:border-[#334155]">
      <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Family member billing</p>
      <p class="mt-2 text-sm font-black text-[#0F172A] dark:text-white">
        <%= @membership_plan.child_fee_enabled? ? "Age 14+ · #{yen(@membership_plan.child_fee_amount)} per eligible child" : "Not enabled" %>
      </p>
    </div>
    <div class="mt-6 border-t border-[#E2E8F0] pt-6 dark:border-[#334155]">
      <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Description</p>
      <p class="mt-2 text-sm leading-6 text-[#64748B] dark:text-[#CBD5E1]"><%= @membership_plan.description.presence || "No description provided." %></p>
    </div>
  </section>
</div>
