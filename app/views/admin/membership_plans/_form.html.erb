<%= form_with model: [ :admin, membership_plan ], class: "rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-6" do |form| %>
  <%= render "devise/shared/error_messages", resource: membership_plan %>

  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <%= form.label :name, class: "block text-sm font-black text-[#0F172A] dark:text-white" do %>Plan Name <span class="text-red-600 dark:text-red-400">*</span><% end %>
      <%= form.text_field :name, required: true, placeholder: "e.g. Annual Membership Fee", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    </div>

    <div>
      <%= form.label :amount, class: "block text-sm font-black text-[#0F172A] dark:text-white" do %>Amount (JPY) <span class="text-red-600 dark:text-red-400">*</span><% end %>
      <%= form.number_field :amount, step: 1, min: 0, inputmode: "numeric", required: true, value: yen_input_value(membership_plan.amount), placeholder: "e.g. 5000", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    </div>

    <div>
      <%= form.label :membership_plan_type_id, "Plan Type", class: "block text-sm font-black text-[#0F172A] dark:text-white" do %>Plan Type <span class="text-red-600 dark:text-red-400">*</span><% end %>
      <%= form.select :membership_plan_type_id, @plan_type_options.map { |type| [ type.name, type.id ] }, {}, class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
      <p class="mt-2 text-xs leading-5 text-[#64748B] dark:text-[#CBD5E1]">Membership plans create member dues. Other plans support donations, fundraising, and society fees.</p>
    </div>

    <div>
      <%= form.label :billing_cycle, class: "block text-sm font-black text-[#0F172A] dark:text-white" do %>Billing Cycle <span class="text-red-600 dark:text-red-400">*</span><% end %>
      <%= form.select :billing_cycle, MembershipPlan.billing_cycles.keys.map { |cycle| [ cycle.humanize, cycle ] }, {}, class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    </div>

    <label class="flex items-center gap-3 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] px-3 py-3 dark:border-[#334155] dark:bg-[#0F172A]">
      <%= form.check_box :active, class: "h-5 w-5 rounded border-gray-300 text-red-700 focus:ring-red-600" %>
      <span class="text-sm font-black text-[#0F172A] dark:text-white">Active plan</span>
    </label>

    <label class="flex items-start gap-3 rounded-xl border border-red-100 bg-red-50/60 px-3 py-3 dark:border-red-500/20 dark:bg-red-500/10">
      <%= form.check_box :required_for_members, class: "mt-0.5 h-5 w-5 rounded border-red-200 text-red-700 focus:ring-red-600 dark:border-red-500/40" %>
      <span>
        <span class="block text-sm font-black text-[#0F172A] dark:text-white">Required for all members</span>
        <span class="mt-1 block text-xs font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1]">Auto-create unpaid records in member Current Payments. Leave off for voluntary donations and fundraisers.</span>
      </span>
    </label>

    <div class="md:col-span-2">
      <%= form.label :description, class: "block text-sm font-black text-[#0F172A] dark:text-white" %>
      <%= form.text_area :description, rows: 4, placeholder: "Add a short description for this payment plan.", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold leading-6 text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    </div>
  </div>

  <div class="mt-6 flex flex-col-reverse gap-2 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A] sm:flex-row sm:justify-end">
    <%= link_to admin_membership_plans_path, class: action_button_classes(:secondary, full_width: true, extra: "sm:w-auto") do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Cancel</span>
    <% end %>
    <%= form.button type: :submit, class: action_button_classes(:primary, full_width: true, extra: "sm:w-auto") do %>
      <%= icon_svg(:save, classes: "h-4 w-4") %>
      <span><%= membership_plan.persisted? ? "Update Plan" : "Create Plan" %></span>
    <% end %>
  </div>
<% end %>
