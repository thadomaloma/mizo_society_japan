<% content_for :page_title, "Payment Plans" %>

<div class="space-y-5 sm:space-y-6">
  <% header_actions = capture do %>
    <div class="grid w-full grid-cols-2 gap-2 sm:flex sm:w-auto">
      <%= link_to admin_membership_plan_types_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:settings, classes: "h-4 w-4") %>
        <span>Plan Types</span>
      <% end %>
      <% if policy(MembershipPlan).create? %>
        <%= link_to new_admin_membership_plan_path, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
          <%= icon_svg(:plus, classes: "h-4 w-4") %>
          <span>New Plan</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Finance",
    title: "Payment Plans",
    subtitle: "Create membership fees, donation options, fundraiser plans, and other society fees.",
    actions: header_actions %>

  <%= render "overview_panel", plan_summary: @plan_summary %>

  <% if @plan_type_options.many? %>
    <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]") do %>
      <%= form_with url: admin_membership_plans_path, method: :get, class: "flex items-center gap-2 sm:gap-3" do |form| %>
        <div class="min-w-0 flex-1 sm:max-w-sm">
          <%= form.select :plan_type_id,
            options_for_select([[ "All plan types", "" ]] + @plan_type_options.map { |type| [ type.name, type.id ] }, @plan_type_id),
            {},
            aria: { label: "Payment plan type" },
            class: "block w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
        </div>
        <% if @plan_type_id.present? %>
          <%= link_to admin_membership_plans_path, class: action_button_classes(:secondary, size: :sm, extra: "shrink-0 px-2.5"), aria: { label: "Reset plan filter" }, title: "Reset filter" do %>
            <%= icon_svg(:x_mark, classes: "h-4 w-4") %>
            <span class="hidden sm:inline">Reset</span>
          <% end %>
        <% end %>
        <%= form.button type: :submit, class: action_button_classes(:dark, size: :sm, extra: "shrink-0 px-3") do %>
          <%= icon_svg(:filter, classes: "h-4 w-4") %>
          <span>Filter</span>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <% if @membership_plans.any? %>
    <div class="grid gap-2.5 lg:hidden">
      <%= render partial: "plan_card", collection: @membership_plans, as: :plan %>
    </div>

    <%= render ::RubyUI::Card.new(class: "hidden overflow-hidden rounded-xl border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B] lg:block") do %>
      <%= render ::RubyUI::Table.new(class: "min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-[#334155]") do %>
        <thead class="bg-slate-50 text-xs font-black uppercase tracking-wide text-slate-500 dark:bg-[#0F172A] dark:text-slate-300">
          <tr>
            <th class="px-5 py-3">Plan</th>
            <th class="px-5 py-3">Amount</th>
            <th class="px-5 py-3">Billing</th>
            <th class="px-5 py-3">Member billing</th>
            <th class="px-5 py-3">Usage</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white dark:divide-[#334155] dark:bg-[#1E293B]">
          <%= render partial: "plan_row", collection: @membership_plans, as: :plan %>
        </tbody>
      <% end %>
    <% end %>
  <% else %>
    <%= render "shared/empty_state",
      title: "No payment plans yet",
      message: "Create a membership fee, donation option, fundraiser plan, or other society fee.",
      action: (policy(MembershipPlan).create? ? link_to(new_admin_membership_plan_path, class: action_button_classes(:primary)) do
        safe_join([ icon_svg(:plus, classes: "h-4 w-4"), tag.span("Add Plan") ])
      end : nil) %>
  <% end %>
</div>
