<% content_for :page_title, "Payment Plans" %>

<div class="space-y-6">
  <% header_actions = capture do %>
    <div class="grid w-full grid-cols-2 gap-2 sm:flex sm:w-auto">
    <%= link_to admin_membership_plan_types_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
      <%= icon_svg(:settings, classes: "h-4 w-4") %>
      <span>Plan Types</span>
    <% end %>
    <% if policy(MembershipPlan).create? %>
      <%= link_to new_admin_membership_plan_path, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:plus, classes: "h-4 w-4") %>
        <span>New Plan</span>
      <% end %>
    <% end %>
    </div>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Finance",
    title: "Payment Plans",
    subtitle: "Create membership fees, donation options, fundraiser plans, and other society fees.",
    actions: header_actions %>

  <%= form_with url: admin_membership_plans_path, method: :get, class: "flex flex-row items-end gap-2 rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:gap-3 sm:p-4" do |form| %>
    <div class="min-w-0 flex-1 sm:max-w-xs">
      <%= form.select :plan_type_id, options_for_select([[ "All plan types", "" ]] + @plan_type_options.map { |type| [ type.name, type.id ] }, @plan_type_id), {}, class: "block w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
    </div>
    <%= form.button type: :submit, class: action_button_classes(:dark, size: :sm, extra: "px-3") do %>
      <%= icon_svg(:filter, classes: "h-4 w-4") %>
      <span class="hidden sm:inline">Filter</span>
    <% end %>
  <% end %>

  <% if @membership_plans.any? %>
    <div class="grid gap-2 sm:gap-4 md:grid-cols-2 xl:grid-cols-3">
      <% @membership_plans.each do |plan| %>
        <% plan_in_use = plan.membership_payments.any? %>
        <article class="rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm transition hover:border-slate-300 hover:shadow-md dark:border-[#334155] dark:bg-[#1E293B] dark:hover:border-[#475569] sm:p-4">
          <div class="flex items-start justify-between gap-2 sm:gap-3">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300 sm:h-9 sm:w-9"><%= icon_svg(:tag, classes: "h-4 w-4") %></span>
                <h3 class="truncate text-[15px] font-black leading-5 text-[#0F172A] dark:text-white sm:text-base"><%= link_to plan.name, admin_membership_plan_path(plan), class: "transition hover:text-red-700 dark:hover:text-red-400" %></h3>
              </div>
              <div class="mt-1.5 flex flex-wrap items-center gap-2 sm:mt-2">
                <span class="text-xs font-semibold capitalize text-[#64748B] dark:text-[#CBD5E1] sm:text-sm"><%= plan.billing_cycle.humanize %></span>
                <span class="sm:hidden"><%= render "shared/status_badge", status: plan.active? ? "active" : "inactive", compact: true %></span>
                <% if plan.required_for_members? %>
                  <span class="rounded-md bg-red-50 px-2 py-0.5 text-[10px] font-black uppercase tracking-wide text-red-700 ring-1 ring-red-100 dark:bg-red-500/10 dark:text-red-300 dark:ring-red-500/20">Required</span>
                <% end %>
              </div>
            </div>
            <div class="hidden shrink-0 items-center gap-1.5 sm:flex">
              <%= render "shared/status_badge", status: plan.active? ? "active" : "inactive" %>
              <% if policy(plan).update? %>
                <%= link_to edit_admin_membership_plan_path(plan), class: action_button_classes(:secondary, size: :xs, extra: "h-8 w-8 px-0"), title: "Edit #{plan.name}", aria: { label: "Edit #{plan.name}" } do %>
                  <%= icon_svg(:edit, classes: "h-3.5 w-3.5") %>
                <% end %>
              <% end %>
              <% if policy(plan).destroy? %>
                <% if plan_in_use %>
                  <span class="inline-flex h-8 w-8 shrink-0 cursor-not-allowed items-center justify-center rounded-md border border-slate-200 bg-slate-50 text-slate-400 dark:border-[#334155] dark:bg-[#0F172A] dark:text-slate-500" title="This plan has payment records. Deactivate it instead of deleting." aria-label="Cannot delete <%= plan.name %> because payment records exist">
                    <%= icon_svg(:trash, classes: "h-3.5 w-3.5") %>
                  </span>
                <% else %>
                  <%= button_to admin_membership_plan_path(plan), method: :delete, data: { turbo_confirm: "Delete #{plan.name}? This cannot be undone." }, class: action_button_classes(:outline_danger, size: :xs, extra: "h-8 w-8 px-0"), form: { class: "inline-flex" }, title: "Delete #{plan.name}", aria: { label: "Delete #{plan.name}" } do %>
                    <%= icon_svg(:trash, classes: "h-3.5 w-3.5") %>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
          <p class="mt-3 text-2xl font-black text-[#0F172A] dark:text-white sm:mt-5 sm:text-3xl"><%= yen(plan.amount) %></p>
          <p class="mt-2 line-clamp-2 text-xs leading-5 text-[#64748B] dark:text-[#CBD5E1] sm:mt-3 sm:min-h-12 sm:text-sm sm:leading-6"><%= plan.description.presence || "No description provided." %></p>

          <div class="mt-2.5 grid min-w-0 gap-2 <%= policy(plan).update? || policy(plan).destroy? ? "grid-cols-3" : "grid-cols-1" %> sm:hidden">
            <%= link_to admin_membership_plan_path(plan), class: "inline-flex min-w-0 items-center justify-center gap-1.5 rounded-md border border-[#E2E8F0] bg-white px-2 py-1.5 text-xs font-black text-[#0F172A] shadow-sm dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" do %>
              <%= icon_svg(:eye, classes: "h-3.5 w-3.5 shrink-0") %>
              <span>View</span>
            <% end %>
            <% if policy(plan).update? %>
              <%= link_to edit_admin_membership_plan_path(plan), class: "inline-flex min-w-0 items-center justify-center gap-1.5 rounded-md bg-[#0F172A] px-2 py-1.5 text-xs font-black text-white shadow-sm dark:bg-[#334155]" do %>
                <%= icon_svg(:edit, classes: "h-3.5 w-3.5 shrink-0") %>
                <span>Edit</span>
              <% end %>
            <% end %>
            <% if policy(plan).destroy? %>
              <% if plan_in_use %>
                <span class="inline-flex min-w-0 cursor-not-allowed items-center justify-center gap-1.5 rounded-md border border-slate-200 bg-slate-50 px-2 py-1.5 text-xs font-black text-slate-400 dark:border-[#334155] dark:bg-[#0F172A] dark:text-slate-500">
                  <%= icon_svg(:lock, classes: "h-3.5 w-3.5 shrink-0") %>
                  <span>Lock</span>
                </span>
              <% else %>
                <%= button_to admin_membership_plan_path(plan), method: :delete, data: { turbo_confirm: "Delete #{plan.name}? This cannot be undone." }, form: { class: "min-w-0" }, class: "inline-flex w-full min-w-0 items-center justify-center gap-1.5 rounded-md border border-red-200 bg-white px-2 py-1.5 text-xs font-black text-red-700 shadow-sm dark:border-red-500/40 dark:bg-[#0F172A] dark:text-red-300" do %>
                  <%= icon_svg(:trash, classes: "h-3.5 w-3.5 shrink-0") %>
                  <span>Delete</span>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <div class="mt-3 hidden items-center justify-between gap-3 border-t border-[#E2E8F0] pt-2.5 text-[11px] font-bold text-[#64748B] dark:border-[#334155] dark:text-[#CBD5E1] sm:mt-4 sm:flex sm:pt-3 sm:text-xs">
            <span class="truncate"><%= plan.required_for_members? ? "Shown in member payments" : (plan_in_use ? "In use" : "Ready to use") %></span>
            <%= link_to admin_membership_plan_path(plan), class: "font-black text-red-700 transition hover:text-red-800 dark:text-red-400 dark:hover:text-red-300" do %>View details<% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state",
      title: "No payment plans yet",
      message: "Create a membership fee, donation option, fundraiser plan, or other society fee.",
      action: (policy(MembershipPlan).create? ? link_to(new_admin_membership_plan_path, class: action_button_classes(:primary)) do
        safe_join([ icon_svg(:plus, classes: "h-4 w-4"), tag.span("Add Plan") ])
      end : nil) %>
  <% end %>
</div>
