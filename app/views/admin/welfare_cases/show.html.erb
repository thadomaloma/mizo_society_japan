<% content_for :page_title, "Welfare Case" %>
<% admin_welfare_actions = capture do %>
  <% if policy(@welfare_case).edit? %>
    <%= link_to edit_admin_welfare_case_path(@welfare_case), class: action_button_classes(:dark) do %>
      <%= icon_svg(:edit, classes: "h-4 w-4") %>
      <span>Edit</span>
    <% end %>
  <% end %>
<% end %>

<div class="space-y-4 sm:space-y-6">
  <%= render "shared/page_header",
    eyebrow: "Confidential welfare",
    title: @welfare_case.title,
    subtitle: "Case ##{@welfare_case.id} · #{user_label(@welfare_case.user)}",
    actions: admin_welfare_actions %>

  <section class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:p-5">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <div class="flex flex-wrap items-center gap-2">
            <span class="rounded-full bg-red-50 px-2.5 py-1 text-xs font-black uppercase tracking-wide text-red-700 dark:bg-red-500/15 dark:text-red-200"><%= @welfare_case.welfare_category.name %></span>
            <span class="text-xs font-black text-slate-400 dark:text-slate-500">Case #<%= @welfare_case.id %></span>
          </div>
          <h2 class="mt-3 text-xl font-black leading-7 text-slate-950 dark:text-white"><%= @welfare_case.title %></h2>
        </div>
        <%= render "shared/status_badge", status: @welfare_case.status %>
      </div>

      <dl class="mt-4 grid gap-2 text-sm sm:grid-cols-3">
        <div class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 dark:border-slate-700 dark:bg-slate-900">
          <dt class="text-xs font-black uppercase tracking-wide text-slate-400">Priority</dt>
          <dd class="mt-1 font-black text-slate-950 dark:text-white"><%= @welfare_case.priority.humanize %></dd>
        </div>
        <div class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 dark:border-slate-700 dark:bg-slate-900">
          <dt class="text-xs font-black uppercase tracking-wide text-slate-400">Submitted</dt>
          <dd class="mt-1 font-black text-slate-950 dark:text-white"><%= @welfare_case.submitted_at.strftime("%b %d, %Y") %></dd>
        </div>
        <div class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 dark:border-slate-700 dark:bg-slate-900">
          <dt class="text-xs font-black uppercase tracking-wide text-slate-400">Office Bearer</dt>
          <dd class="mt-1 truncate font-black text-slate-950 dark:text-white"><%= @welfare_case.assigned_to&.display_name || "Unassigned" %></dd>
        </div>
      </dl>

      <div class="mt-4 rounded-2xl border border-slate-100 bg-slate-50 p-4 whitespace-pre-line text-sm font-semibold leading-6 text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200"><%= @welfare_case.description %></div>
    </article>

    <aside class="space-y-3">
      <% if @welfare_case.user.member_profile.present? %>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
          <h3 class="text-base font-black text-slate-950 dark:text-white">Member Contact</h3>
          <p class="mt-2 font-black text-slate-950 dark:text-white"><%= @welfare_case.user.display_name %></p>
          <p class="mt-1 text-sm font-semibold text-slate-500 dark:text-slate-400"><%= @welfare_case.user.member_profile.mobile_number %></p>
          <div class="mt-3">
            <%= render "admin/shared/member_contact_actions", user: @welfare_case.user %>
          </div>
        </div>
      <% end %>

      <% if policy(@welfare_case).assign? %>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
          <h3 class="text-base font-black text-slate-950 dark:text-white">Assign Office Bearer</h3>
          <%= form_with model: [ :admin, @welfare_case ], url: assign_admin_welfare_case_path(@welfare_case), method: :patch, class: "mt-4 space-y-3" do |form| %>
            <%= form.collection_select :assigned_to_id, @assignable_users, :id, :display_name, { include_blank: "Choose Office Bearer" }, class: "block w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-900 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-slate-600 dark:bg-slate-900 dark:text-white" %>
            <%= form.button type: :submit, class: action_button_classes(:dark, full_width: true) do %>
              <%= icon_svg(:user_plus, classes: "h-4 w-4") %>
              <span>Assign</span>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="text-base font-black text-slate-950 dark:text-white">Actions</h3>
        <div class="mt-4 grid gap-2">
          <% if policy(@welfare_case).resolve? %>
            <%= button_to resolve_admin_welfare_case_path(@welfare_case), method: :patch, class: action_button_classes(:success, full_width: true) do %>
              <%= icon_svg(:check, classes: "h-4 w-4") %>
              <span>Resolve</span>
            <% end %>
          <% end %>
          <% if policy(@welfare_case).reject? %>
            <%= button_to reject_admin_welfare_case_path(@welfare_case), method: :patch, class: action_button_classes(:danger, full_width: true) do %>
              <%= icon_svg(:x_mark, classes: "h-4 w-4") %>
              <span>Reject</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </aside>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:p-5">
    <h3 class="text-base font-black text-slate-950 dark:text-white sm:text-lg">Attachments</h3>
    <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
      <% @welfare_case.welfare_attachments.each do |attachment| %>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-900">
          <%= link_to rails_blob_path(attachment.file, disposition: "attachment"), class: "block text-sm font-bold text-slate-700 hover:text-red-700 dark:text-slate-200 dark:hover:text-red-300" do %>
            <span class="flex items-center gap-2 font-black text-slate-950 dark:text-white"><%= icon_svg(:paperclip, classes: "h-4 w-4 text-red-700 dark:text-red-300") %><span class="truncate"><%= attachment.file.filename %></span></span>
            <span class="mt-1 block text-slate-500 dark:text-slate-400"><%= attachment.file_extension.upcase %> · <%= formatted_file_size(attachment) %></span>
          <% end %>
          <% if policy(attachment).destroy? %>
            <%= button_to admin_welfare_attachment_path(attachment), method: :delete, class: "#{action_button_classes(:outline_danger, size: :xs)} mt-3" do %>
              <%= icon_svg(:trash, classes: "h-3.5 w-3.5") %>
              <span>Delete</span>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% if @welfare_case.welfare_attachments.empty? %>
        <div class="rounded-xl border border-dashed border-slate-200 bg-slate-50 p-4 text-sm font-semibold text-slate-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-400">
          No attachments uploaded.
        </div>
      <% end %>
    </div>
  </section>

  <% if policy(@welfare_case).view_internal_notes? %>
    <%= render "notes", welfare_case: @welfare_case, welfare_note: @welfare_note, welfare_notes: @welfare_notes %>
  <% end %>
</div>
