<% content_for :page_title, "Welfare Case" %>
<% case_policy = policy(@welfare_case) %>
<% admin_welfare_actions = capture do %>
  <div class="grid w-full grid-cols-2 gap-2 sm:flex sm:w-auto">
    <%= link_to admin_welfare_cases_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %><%= icon_svg(:arrow_left, classes: "h-4 w-4") %><span>All Cases</span><% end %>
    <% if case_policy.edit? %><%= link_to edit_admin_welfare_case_path(@welfare_case), class: action_button_classes(:dark, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %><%= icon_svg(:edit, classes: "h-4 w-4") %><span>Edit Case</span><% end %><% end %>
  </div>
<% end %>

<div class="space-y-5 sm:space-y-6">
  <%= render "shared/page_header", eyebrow: "Confidential welfare", title: @welfare_case.title, subtitle: "Case ##{@welfare_case.id} · #{user_label(@welfare_case.user)}", actions: admin_welfare_actions %>

  <section class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <div class="space-y-4">
      <%= render ::RubyUI::Card.new(class: "overflow-hidden rounded-xl border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]") do %>
        <div class="border-b border-[#E2E8F0] p-4 dark:border-[#334155] sm:p-5">
          <div class="flex items-start justify-between gap-3"><div class="min-w-0"><p class="text-[10px] font-black uppercase tracking-wide text-red-700 dark:text-red-300"><%= @welfare_case.welfare_category.name %> · Case #<%= @welfare_case.id %></p><h2 class="mt-1.5 text-xl font-black leading-7 text-[#0F172A] dark:text-white"><%= @welfare_case.title %></h2></div><%= render "shared/status_badge", status: @welfare_case.status %></div>
        </div>
        <dl class="grid grid-cols-2 border-b border-[#E2E8F0] dark:border-[#334155] sm:grid-cols-4">
          <% [ [ "Priority", @welfare_case.priority.humanize ], [ "Submitted", @welfare_case.submitted_at.strftime("%d %b %Y") ], [ "Office Bearer", @welfare_case.assigned_to&.display_name || "Unassigned" ], [ "Outcome", @welfare_case.closed? ? @welfare_case.status.humanize : "Open" ] ].each_with_index do |(label, value), index| %>
            <div class="min-w-0 border-[#E2E8F0] p-3 dark:border-[#334155] <%= 'border-l' if index.odd? %> <%= 'border-t sm:border-t-0' if index >= 2 %> <%= 'sm:border-l' if index.positive? %>"><dt class="text-[10px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= label %></dt><dd class="mt-1 truncate text-sm font-black text-[#0F172A] dark:text-white"><%= value %></dd></div>
          <% end %>
        </dl>
        <div class="p-4 sm:p-5"><h3 class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Request details</h3><p class="mt-3 whitespace-pre-line text-sm font-semibold leading-6 text-[#334155] dark:text-[#CBD5E1]"><%= @welfare_case.description %></p></div>
      <% end %>

      <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5") do %>
        <div class="flex items-center justify-between gap-3"><div><h3 class="font-black text-[#0F172A] dark:text-white">Attachments</h3><p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Supporting files shared with this case</p></div><span class="text-xs font-black text-[#64748B] dark:text-[#CBD5E1]"><%= @welfare_case.welfare_attachments.size %></span></div>
        <% if @welfare_case.welfare_attachments.any? %>
          <div class="mt-4 grid gap-2 md:grid-cols-2">
            <% @welfare_case.welfare_attachments.each do |attachment| %>
              <div class="flex min-w-0 items-center gap-3 rounded-lg border border-[#E2E8F0] bg-slate-50 p-3 dark:border-[#334155] dark:bg-[#0F172A]">
                <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300"><%= icon_svg(:paperclip, classes: "h-4 w-4") %></span>
                <%= link_to rails_blob_path(attachment.file, disposition: "attachment"), class: "min-w-0 flex-1" do %><p class="truncate text-sm font-black text-[#0F172A] hover:text-red-700 dark:text-white dark:hover:text-red-300"><%= attachment.file.filename %></p><p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= attachment.file_extension.upcase %> · <%= formatted_file_size(attachment) %></p><% end %>
                <% if policy(attachment).destroy? %><%= button_to admin_welfare_attachment_path(attachment), method: :delete, data: { turbo_confirm: "Delete this attachment?" }, class: action_button_classes(:outline_danger, size: :xs, extra: "h-8 w-8 px-0"), title: "Delete attachment", aria: { label: "Delete attachment" } do %><%= icon_svg(:trash, classes: "h-3.5 w-3.5") %><% end %><% end %>
              </div>
            <% end %>
          </div>
        <% else %><p class="mt-4 rounded-lg border border-dashed border-[#E2E8F0] bg-slate-50 p-4 text-sm font-semibold text-[#64748B] dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1]">No attachments uploaded.</p><% end %>
      <% end %>
    </div>

    <aside class="space-y-3">
      <% if @welfare_case.user.member_profile.present? %>
        <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]") do %>
          <div class="flex items-center gap-3"><%= user_avatar(@welfare_case.user, classes: "h-10 w-10", text_classes: "text-sm") %><div class="min-w-0"><h3 class="truncate text-sm font-black text-[#0F172A] dark:text-white"><%= @welfare_case.user.display_name %></h3><p class="mt-0.5 truncate text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= @welfare_case.user.member_profile.membership_number %></p></div></div>
          <p class="mt-3 text-sm font-black text-[#0F172A] dark:text-white"><%= @welfare_case.user.member_profile.mobile_number %></p>
          <div class="mt-3"><%= render "admin/shared/member_contact_actions", user: @welfare_case.user %></div>
        <% end %>
      <% end %>

      <% if case_policy.assign? %>
        <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]") do %>
          <h3 class="text-sm font-black text-[#0F172A] dark:text-white">Assigned Office Bearer</h3><p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Choose who will follow up this case.</p>
          <%= form_with model: [ :admin, @welfare_case ], url: assign_admin_welfare_case_path(@welfare_case), method: :patch, class: "mt-3 space-y-2" do |form| %>
            <%= form.collection_select :assigned_to_id, @assignable_users, :id, :display_name, { include_blank: "Unassigned" }, class: "block w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
            <%= form.button type: :submit, class: action_button_classes(:dark, size: :sm, full_width: true) do %><%= icon_svg(:user_plus, classes: "h-4 w-4") %><span>Update Assignment</span><% end %>
          <% end %>
        <% end %>
      <% end %>

      <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]") do %>
        <% if @welfare_case.closed? %>
          <div class="flex items-start gap-3"><span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg <%= @welfare_case.resolved? ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300' : 'bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300' %>"><%= icon_svg(@welfare_case.resolved? ? :check : :x_mark, classes: "h-4 w-4") %></span><div><h3 class="text-sm font-black text-[#0F172A] dark:text-white">Case <%= @welfare_case.status.humanize.downcase %></h3><p class="mt-1 text-xs font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1]"><%= @welfare_case.resolved? ? "Closed on #{@welfare_case.resolved_at&.strftime('%d %b %Y') || 'the recorded resolution date'}. Details are now read-only." : "This request was closed without resolution. Details are now read-only." %></p></div></div>
        <% elsif case_policy.resolve? || case_policy.reject? %>
          <h3 class="text-sm font-black text-[#0F172A] dark:text-white">Review outcome</h3><p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Close this case only after the follow-up is complete.</p>
          <div class="mt-3 grid grid-cols-2 gap-2">
            <% if case_policy.resolve? %><%= button_to resolve_admin_welfare_case_path(@welfare_case), method: :patch, data: { turbo_confirm: "Mark this welfare case as resolved?" }, class: action_button_classes(:success, size: :sm, full_width: true) do %><%= icon_svg(:check, classes: "h-4 w-4") %><span>Resolve</span><% end %><% end %>
            <% if case_policy.reject? %><%= button_to reject_admin_welfare_case_path(@welfare_case), method: :patch, data: { turbo_confirm: "Reject and close this welfare case?" }, class: action_button_classes(:outline_danger, size: :sm, full_width: true) do %><%= icon_svg(:x_mark, classes: "h-4 w-4") %><span>Reject</span><% end %><% end %>
          </div>
        <% else %>
          <div class="flex items-start gap-3"><span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-slate-100 text-slate-600 dark:bg-[#0F172A] dark:text-slate-300"><%= icon_svg(:eye, classes: "h-4 w-4") %></span><div><h3 class="text-sm font-black text-[#0F172A] dark:text-white">View only</h3><p class="mt-1 text-xs font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1]">Only authorized Office Bearers can manage this case.</p></div></div>
        <% end %>
      <% end %>
    </aside>
  </section>

  <% if case_policy.view_internal_notes? %><%= render "notes", welfare_case: @welfare_case, welfare_note: @welfare_note, welfare_notes: @welfare_notes %><% end %>
</div>
