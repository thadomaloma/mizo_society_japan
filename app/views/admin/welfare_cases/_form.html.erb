<%= form_with model: [ :admin, welfare_case ], class: "space-y-5 rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]" do |form| %>
  <% if welfare_case.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-700">
      <%= welfare_case.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <% if welfare_case.persisted? %>
    <div class="rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm dark:border-white/10 dark:bg-white/5">
      <p class="font-bold text-gray-500 dark:text-gray-400">Member</p>
      <p class="mt-1 font-black text-gray-950 dark:text-white"><%= user_label(welfare_case.user) %></p>
      <p class="mt-1 text-xs font-semibold text-gray-500 dark:text-gray-400"><%= welfare_case.user.email %></p>
    </div>
  <% else %>
    <div>
      <%= form.label :user_id, "Member", class: "block text-sm font-bold text-gray-700 dark:text-gray-200" %>
      <%= form.collection_select :user_id, @members, :id, :display_name, { prompt: "Choose member" }, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-white/10 dark:bg-gray-950 dark:text-white" %>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-bold text-gray-700 dark:text-gray-200" %>
    <%= form.text_field :title, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-white/10 dark:bg-gray-950 dark:text-white" %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :welfare_category_id, "Category", class: "block text-sm font-bold text-gray-700 dark:text-gray-200" %>
      <%= form.collection_select :welfare_category_id, @welfare_categories, :id, :name, { prompt: "Choose category" }, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-white/10 dark:bg-gray-950 dark:text-white" %>
    </div>

    <div>
      <%= form.label :assigned_to_id, "Assigned to", class: "block text-sm font-bold text-gray-700 dark:text-gray-200" %>
      <%= form.collection_select :assigned_to_id, @assignable_users, :id, :display_name, { include_blank: "Unassigned" }, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-white/10 dark:bg-gray-950 dark:text-white" %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :priority, class: "block text-sm font-bold text-gray-700 dark:text-gray-200" %>
      <%= form.select :priority, WelfareCase.priorities.keys.map { |priority| [ priority.humanize, priority ] }, {}, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-white/10 dark:bg-gray-950 dark:text-white" %>
    </div>

    <div>
      <%= form.label :status, class: "block text-sm font-bold text-gray-700 dark:text-gray-200" %>
      <%= form.select :status, WelfareCase.statuses.keys.map { |status| [ status.humanize, status ] }, {}, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-white/10 dark:bg-gray-950 dark:text-white" %>
    </div>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-bold text-gray-700 dark:text-gray-200" %>
    <%= form.text_area :description, rows: 7, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 shadow-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-white/10 dark:bg-gray-950 dark:text-white" %>
  </div>

  <div>
    <%= form.label :files, "Attachments", class: "block text-sm font-bold text-gray-700 dark:text-gray-200" %>
    <%= form.file_field :files, multiple: true, direct_upload: false, accept: ".pdf,.jpg,.jpeg,.png", class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-700 shadow-sm file:mr-4 file:rounded-lg file:border-0 file:bg-gray-950 file:px-3 file:py-2 file:text-sm file:font-black file:text-white dark:border-white/10 dark:bg-gray-950 dark:text-gray-200" %>
    <p class="mt-2 text-xs font-semibold text-gray-500 dark:text-gray-400">PDF, JPG, and PNG only.</p>
  </div>

  <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm font-bold text-gray-700 dark:border-white/10 dark:bg-white/5 dark:text-gray-200">
    <%= form.check_box :confidential, class: "h-4 w-4 rounded border-gray-300 text-red-700 focus:ring-red-600" %>
    Confidential case
  </label>

  <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
    <%= link_to(welfare_case.persisted? ? admin_welfare_case_path(welfare_case) : admin_welfare_cases_path, class: action_button_classes(:secondary)) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Cancel</span>
    <% end %>
    <%= form.button type: :submit, class: action_button_classes(:primary) do %>
      <%= icon_svg(:save, classes: "h-4 w-4") %>
      <span><%= welfare_case.persisted? ? "Update Case" : "Create Case" %></span>
    <% end %>
  </div>
<% end %>
