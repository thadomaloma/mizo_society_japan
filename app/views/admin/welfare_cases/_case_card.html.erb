<article class="rounded-2xl border border-gray-200 bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5">
  <div class="flex items-start justify-between gap-2 sm:gap-3">
    <div class="min-w-0">
      <p class="text-xs font-bold uppercase tracking-wide text-red-700">Case #<%= welfare_case.id %></p>
      <h3 class="mt-1 line-clamp-1 text-[15px] font-black leading-5 text-gray-950 dark:text-white sm:mt-2 sm:text-base"><%= welfare_case.title %></h3>
      <div class="mt-1 flex flex-wrap items-center gap-1.5">
        <p class="min-w-0 truncate text-xs text-gray-500 dark:text-gray-300 sm:text-sm"><%= user_label(welfare_case.user) %></p>
        <span class="sm:hidden"><%= render "shared/status_badge", status: welfare_case.status, compact: true %></span>
      </div>
    </div>
    <span class="hidden sm:inline-flex"><%= render "shared/status_badge", status: welfare_case.status %></span>
  </div>

  <dl class="mt-3 grid grid-cols-2 gap-2 text-xs sm:mt-5 sm:gap-3 sm:text-sm">
    <div>
      <dt class="font-bold text-gray-400">Category</dt>
      <dd class="mt-0.5 truncate font-black text-gray-950 dark:text-white sm:mt-1"><%= welfare_case.welfare_category.name %></dd>
    </div>
    <div>
      <dt class="font-bold text-gray-400">Priority</dt>
      <dd class="mt-0.5 font-black text-gray-950 dark:text-white sm:mt-1"><%= welfare_case.priority.humanize %></dd>
    </div>
    <div>
      <dt class="font-bold text-gray-400">Assigned</dt>
      <dd class="mt-0.5 truncate font-black text-gray-950 dark:text-white sm:mt-1"><%= welfare_case.assigned_to&.display_name || "Unassigned" %></dd>
    </div>
    <div>
      <dt class="font-bold text-gray-400">Submitted</dt>
      <dd class="mt-0.5 font-black text-gray-950 dark:text-white sm:mt-1"><%= welfare_case.submitted_at.strftime("%b %d, %Y") %></dd>
    </div>
  </dl>

  <div class="mt-3 grid grid-cols-2 gap-2 sm:mt-5">
    <%= link_to admin_welfare_case_path(welfare_case), class: "inline-flex min-w-0 items-center justify-center gap-1.5 rounded-md border border-[#E2E8F0] bg-white px-2 py-1.5 text-xs font-black text-[#0F172A] shadow-sm dark:border-[#334155] dark:bg-[#0F172A] dark:text-white sm:rounded-lg sm:px-3 sm:py-2 sm:text-sm" do %>
      <%= icon_svg(:eye, classes: "h-3.5 w-3.5 shrink-0 sm:h-4 sm:w-4") %>
      <span>View</span>
    <% end %>
    <% if policy(welfare_case).edit? %>
      <%= link_to edit_admin_welfare_case_path(welfare_case), class: "inline-flex min-w-0 items-center justify-center gap-1.5 rounded-md bg-[#0F172A] px-2 py-1.5 text-xs font-black text-white shadow-sm dark:bg-[#334155] sm:rounded-lg sm:px-3 sm:py-2 sm:text-sm" do %>
        <%= icon_svg(:edit, classes: "h-3.5 w-3.5 shrink-0 sm:h-4 sm:w-4") %>
        <span>Edit</span>
      <% end %>
    <% end %>
  </div>
</article>
