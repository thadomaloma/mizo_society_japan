<%= render ::RubyUI::Card.new(class: "overflow-hidden rounded-xl border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]") do %>
  <div class="p-3.5 sm:p-4">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0"><p class="text-[10px] font-black uppercase tracking-wide text-red-700 dark:text-red-300">Case #<%= welfare_case.id %> · <%= welfare_case.welfare_category.name %></p><h2 class="mt-1.5 line-clamp-2 text-[15px] font-black leading-5 text-[#0F172A] dark:text-white"><%= welfare_case.title %></h2><p class="mt-1 truncate text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= user_label(welfare_case.user) %></p></div>
      <%= render "shared/status_badge", status: welfare_case.status, compact: true %>
    </div>

    <dl class="mt-3 grid grid-cols-2 gap-x-3 gap-y-2 border-t border-[#E2E8F0] pt-3 text-xs dark:border-[#334155]">
      <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Priority</dt><dd class="mt-0.5 font-black <%= welfare_case.urgent? ? 'text-red-700 dark:text-red-300' : 'text-[#0F172A] dark:text-white' %>"><%= welfare_case.priority.humanize %></dd></div>
      <div><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Submitted</dt><dd class="mt-0.5 font-black text-[#0F172A] dark:text-white"><%= welfare_case.submitted_at.strftime("%d %b %Y") %></dd></div>
      <div class="col-span-2"><dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Office Bearer</dt><dd class="mt-0.5 truncate font-black text-[#0F172A] dark:text-white"><%= welfare_case.assigned_to&.display_name || "Unassigned" %></dd></div>
    </dl>
  </div>

  <div class="grid gap-2 border-t border-[#E2E8F0] bg-slate-50/70 p-2.5 dark:border-[#334155] dark:bg-[#0F172A]/60 <%= policy(welfare_case).edit? ? 'grid-cols-2' : 'grid-cols-1' %>">
    <%= link_to admin_welfare_case_path(welfare_case), class: action_button_classes(:secondary, size: :xs, full_width: true) do %><%= icon_svg(:eye, classes: "h-3.5 w-3.5") %><span>View Case</span><% end %>
    <% if policy(welfare_case).edit? %><%= link_to edit_admin_welfare_case_path(welfare_case), class: action_button_classes(:dark, size: :xs, full_width: true) do %><%= icon_svg(:edit, classes: "h-3.5 w-3.5") %><span>Edit</span><% end %><% end %>
  </div>
<% end %>
