<% content_for :page_title, "Welfare Cases" %>

<div class="space-y-6">
  <% header_actions = capture do %>
    <div class="grid w-full grid-cols-2 gap-2 sm:flex sm:w-auto">
    <% if policy(WelfareCategory).index? %>
      <%= link_to admin_welfare_categories_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:tag, classes: "h-4 w-4") %>
        <span>Categories</span>
      <% end %>
    <% end %>
    <% if policy(WelfareCase).admin_create? %>
      <%= link_to new_admin_welfare_case_path, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:plus, classes: "h-4 w-4") %>
        <span>New Case</span>
      <% end %>
    <% end %>
    </div>
  <% end %>
  <%= render "shared/page_header",
    eyebrow: "Confidential welfare",
    title: "Welfare Cases",
    subtitle: "Confidential support cases managed by MSJ's President and Secretary.",
    actions: header_actions %>

  <%= form_with url: admin_welfare_cases_path, method: :get, class: "grid gap-3 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm lg:grid-cols-[1fr_11rem_11rem_13rem_13rem_auto]" do |form| %>
    <%= form.search_field :query, value: @query, placeholder: "Search case, member, email...", class: "rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    <%= form.select :status, options_for_select([ [ "All statuses", "" ] ] + WelfareCase.statuses.keys.map { |status| [ status.humanize, status ] }, @status), {}, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    <%= form.select :priority, options_for_select([ [ "All priorities", "" ] ] + WelfareCase.priorities.keys.map { |priority| [ priority.humanize, priority ] }, @priority), {}, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    <%= form.collection_select :category_id, @welfare_categories, :id, :name, { include_blank: "All categories", selected: @category_id }, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    <%= form.collection_select :assigned_to_id, @assignable_users, :id, :display_name, { include_blank: "All officers", selected: @assigned_to_id }, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    <%= form.button type: :submit, class: action_button_classes(:dark) do %>
      <%= icon_svg(:filter, classes: "h-4 w-4") %>
      <span>Filter</span>
    <% end %>
  <% end %>

  <% if @welfare_cases.any? %>
    <div class="hidden overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm lg:block">
      <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
        <thead class="bg-gray-50 text-xs font-black uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-5 py-3">Case ID</th>
            <th class="px-5 py-3">Member</th>
            <th class="px-5 py-3">Category</th>
            <th class="px-5 py-3">Priority</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Assigned To</th>
            <th class="px-5 py-3">Submitted</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 bg-white">
          <%= render partial: "case_row", collection: @welfare_cases, as: :welfare_case %>
        </tbody>
      </table>
    </div>

    <div class="grid gap-2 lg:hidden">
      <%= render partial: "case_card", collection: @welfare_cases, as: :welfare_case %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No welfare cases found", message: "Try changing the filters." %>
  <% end %>
</div>
