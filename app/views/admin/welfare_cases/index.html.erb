<% content_for :page_title, "Welfare Cases" %>

<div class="space-y-5 sm:space-y-6">
  <% header_actions = capture do %>
    <div class="grid w-full grid-cols-2 gap-2 sm:flex sm:w-auto">
      <% if policy(WelfareCategory).index? %>
        <%= link_to admin_welfare_categories_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
          <%= icon_svg(:tag, classes: "h-4 w-4") %><span>Categories</span>
        <% end %>
      <% end %>
      <% if policy(WelfareCase).admin_create? %>
        <%= link_to new_admin_welfare_case_path, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
          <%= icon_svg(:plus, classes: "h-4 w-4") %><span>New Case</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Confidential welfare",
    title: "Welfare Cases",
    subtitle: "Review support requests, assign Office Bearers, and track each case to a clear outcome.",
    actions: header_actions %>

  <%= render "overview_panel", welfare_summary: @welfare_summary %>

  <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]") do %>
    <%= form_with url: admin_welfare_cases_path, method: :get, class: "grid grid-cols-2 gap-2 lg:grid-cols-[minmax(16rem,1fr)_11rem_11rem_auto]" do |form| %>
      <div class="relative col-span-2 lg:col-span-1">
        <span class="pointer-events-none absolute inset-y-0 left-0 grid w-10 place-items-center text-slate-400"><%= icon_svg(:search, classes: "h-4 w-4") %></span>
        <%= form.search_field :query, value: @query, placeholder: "Search case, member, or member number...", aria: { label: "Search welfare cases" }, class: "w-full rounded-lg border border-[#E2E8F0] bg-white py-2.5 pl-10 pr-3 text-sm font-semibold text-[#0F172A] outline-none placeholder:text-slate-400 focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white dark:placeholder:text-slate-400" %>
      </div>
      <%= form.select :status, options_for_select([[ "All statuses", "" ]] + WelfareCase.statuses.keys.map { |status| [ status.humanize, status ] }, @status), {}, aria: { label: "Case status" }, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
      <%= form.select :priority, options_for_select([[ "All priorities", "" ]] + WelfareCase.priorities.keys.map { |priority| [ priority.humanize, priority ] }, @priority), {}, aria: { label: "Case priority" }, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
      <div class="col-span-2 flex justify-end gap-2 lg:col-span-1">
        <% if @query.present? || @status.present? || @priority.present? %>
          <%= link_to admin_welfare_cases_path, class: action_button_classes(:secondary, size: :sm) do %><%= icon_svg(:x_mark, classes: "h-4 w-4") %><span>Reset</span><% end %>
        <% end %>
        <%= form.button type: :submit, class: action_button_classes(:dark, size: :sm) do %><%= icon_svg(:filter, classes: "h-4 w-4") %><span>Filter</span><% end %>
      </div>
    <% end %>
  <% end %>

  <% if @welfare_cases.any? %>
    <%= render ::RubyUI::Card.new(class: "hidden overflow-hidden rounded-xl border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B] lg:block") do %>
      <%= render ::RubyUI::Table.new(class: "min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-[#334155]") do %>
        <thead class="bg-slate-50 text-xs font-black uppercase tracking-wide text-slate-500 dark:bg-[#0F172A] dark:text-slate-300">
          <tr><th class="px-5 py-3">Case</th><th class="px-5 py-3">Member</th><th class="px-5 py-3">Priority</th><th class="px-5 py-3">Status</th><th class="px-5 py-3">Office Bearer</th><th class="px-5 py-3">Submitted</th><th class="px-5 py-3 text-right">Actions</th></tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white dark:divide-[#334155] dark:bg-[#1E293B]">
          <%= render partial: "case_row", collection: @welfare_cases, as: :welfare_case %>
        </tbody>
      <% end %>
    <% end %>

    <div class="grid gap-2.5 md:grid-cols-2 lg:hidden">
      <%= render partial: "case_card", collection: @welfare_cases, as: :welfare_case %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No welfare cases found", message: "Try changing the filters or create a new welfare case." %>
  <% end %>
</div>
