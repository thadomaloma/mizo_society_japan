<%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5") do %>
  <div><h3 class="font-black text-[#0F172A] dark:text-white">Internal notes</h3><p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Private working notes visible only to authorized Office Bearers.</p></div>
  <%= form_with model: [ :admin, welfare_case, welfare_note ], class: "mt-4" do |form| %>
    <%= form.hidden_field :internal, value: true %>
    <%= form.text_area :body, rows: 3, placeholder: "Add a private follow-up note...", class: "block w-full rounded-lg border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold leading-6 text-[#0F172A] outline-none placeholder:text-slate-400 focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
    <div class="mt-2 flex justify-end"><%= form.button type: :submit, class: action_button_classes(:primary, size: :sm) do %><%= icon_svg(:plus, classes: "h-4 w-4") %><span>Add Note</span><% end %></div>
  <% end %>
  <div class="mt-4 divide-y divide-[#E2E8F0] border-t border-[#E2E8F0] dark:divide-[#334155] dark:border-[#334155]">
    <% welfare_notes.each do |note| %>
      <article class="py-3.5"><div class="flex items-start justify-between gap-3"><div><p class="text-sm font-black text-[#0F172A] dark:text-white"><%= note.user.display_name %></p><p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= note.created_at.strftime("%d %b %Y, %H:%M") %></p></div><div class="flex gap-1.5"><%= link_to edit_admin_welfare_case_welfare_note_path(welfare_case, note), class: action_button_classes(:secondary, size: :xs, extra: "h-8 w-8 px-0"), title: "Edit note", aria: { label: "Edit note" } do %><%= icon_svg(:edit, classes: "h-3.5 w-3.5") %><% end %><%= button_to admin_welfare_case_welfare_note_path(welfare_case, note), method: :delete, data: { turbo_confirm: "Delete this internal note?" }, class: action_button_classes(:outline_danger, size: :xs, extra: "h-8 w-8 px-0"), title: "Delete note", aria: { label: "Delete note" } do %><%= icon_svg(:trash, classes: "h-3.5 w-3.5") %><% end %></div></div><p class="mt-2 whitespace-pre-line text-sm font-semibold leading-6 text-[#334155] dark:text-[#CBD5E1]"><%= note.body %></p></article>
    <% end %>
    <% if welfare_notes.empty? %><p class="py-4 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">No internal notes yet.</p><% end %>
  </div>
<% end %>
