<% input_classes = "mt-2 block w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm font-semibold text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-50 dark:focus:border-red-500 dark:focus:ring-red-500/20" %>
<% label_classes = "block text-sm font-black text-slate-800 dark:text-slate-100" %>
<% hint_classes = "mt-1 text-xs font-semibold leading-5 text-slate-500 dark:text-slate-400" %>
<% section_classes = "rounded-xl border border-slate-200 bg-white p-3 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:rounded-2xl sm:p-5" %>
<% user_options = @users.map { |user| { id: user.id, label: user_label(user) } } %>
<% plan_billing_cycles = @membership_plans.index_with(&:billing_cycle).transform_keys(&:id) %>
<% plan_amounts = @membership_plans.index_with { |plan| yen_input_value(plan.amount) }.transform_keys(&:id) %>

<%= form_with(
  model: [ :admin, membership_payment ],
  class: "space-y-3 sm:space-y-4",
  data: {
    controller: "payment-member-filter",
    payment_member_filter_users_value: user_options.to_json,
    payment_member_filter_blocked_value: @blocked_payment_memberships.to_json,
    payment_member_filter_plan_cycles_value: plan_billing_cycles.to_json,
    payment_member_filter_plan_amounts_value: plan_amounts.to_json,
    payment_member_filter_current_user_id_value: membership_payment.user_id
  }
) do |form| %>
  <%= render "devise/shared/error_messages", resource: membership_payment %>

  <div class="grid gap-3 sm:gap-4 xl:grid-cols-[minmax(0,1fr)_20rem]">
    <div class="space-y-3 sm:space-y-4">
      <section class="<%= section_classes %>">
        <div class="mb-3 flex items-center gap-2.5 sm:mb-4 sm:items-start sm:gap-3">
          <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-slate-100 text-xs font-black text-slate-700 dark:bg-slate-700 dark:text-slate-100 sm:h-8 sm:w-8 sm:rounded-xl sm:text-sm">1</span>
          <div>
            <h2 class="text-sm font-black text-slate-950 dark:text-slate-50 sm:text-base">Member and payment plan</h2>
            <p class="mt-1 hidden text-xs font-semibold text-slate-500 dark:text-slate-400 sm:block">Select the person and the fee, donation, or fund this record belongs to.</p>
          </div>
        </div>

        <div class="grid gap-3 sm:gap-4 md:grid-cols-2">
          <div>
            <%= form.label :user_id, "Member", class: label_classes %>
            <%= form.select :user_id,
              user_options.map { |user| [ user[:label], user[:id] ] },
              { prompt: "Select member" },
              class: input_classes,
              required: true,
              data: { payment_member_filter_target: "userSelect" } %>
            <p class="<%= hint_classes %>" data-payment-member-filter-target="hint">Choose the member who paid or needs this record.</p>
          </div>

          <div>
            <%= form.label :membership_plan_id, "Payment Plan", class: label_classes %>
            <%= form.select :membership_plan_id,
              @membership_plans.map { |plan| [ "#{plan.name} - #{plan.plan_type_label} (#{yen(plan.amount)})", plan.id ] },
              { prompt: "Select payment plan" },
              class: input_classes,
              required: true,
              data: {
                payment_member_filter_target: "planSelect",
                action: "payment-member-filter#filter payment-member-filter#fillAmount"
              } %>
            <p class="<%= hint_classes %>">The plan controls the default amount and payment type.</p>
          </div>
        </div>
      </section>

      <section class="<%= section_classes %>">
        <div class="mb-3 flex items-center gap-2.5 sm:mb-4 sm:items-start sm:gap-3">
          <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-slate-100 text-xs font-black text-slate-700 dark:bg-slate-700 dark:text-slate-100 sm:h-8 sm:w-8 sm:rounded-xl sm:text-sm">2</span>
          <div>
            <h2 class="text-sm font-black text-slate-950 dark:text-slate-50 sm:text-base">Amount and period</h2>
            <p class="mt-1 hidden text-xs font-semibold text-slate-500 dark:text-slate-400 sm:block">Most MSJ payments are yearly or one-time records.</p>
          </div>
        </div>

        <div class="grid gap-3 sm:gap-4 md:grid-cols-2">
          <div>
            <%= form.label :amount, "Amount (JPY)", class: label_classes %>
            <%= form.number_field :amount,
              step: 1,
              min: 0,
              inputmode: "numeric",
              value: yen_input_value(membership_payment.amount),
              placeholder: "Select a payment plan",
              class: input_classes,
              data: { payment_member_filter_target: "amountInput" } %>
            <p class="<%= hint_classes %>">Auto-filled from the selected payment plan.</p>
          </div>

          <div>
            <%= form.label :payment_year, "Year", class: label_classes %>
            <%= form.number_field :payment_year,
              min: 2000,
              class: input_classes,
              data: {
                payment_member_filter_target: "yearInput",
                action: "input->payment-member-filter#filter change->payment-member-filter#filter"
              } %>
            <p class="<%= hint_classes %>">Use the payment year. Monthly records are handled automatically when needed.</p>
          </div>
        </div>
      </section>

      <section class="<%= section_classes %>">
        <div class="mb-3 flex items-center gap-2.5 sm:mb-4 sm:items-start sm:gap-3">
          <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-slate-100 text-xs font-black text-slate-700 dark:bg-slate-700 dark:text-slate-100 sm:h-8 sm:w-8 sm:rounded-xl sm:text-sm">3</span>
          <div>
            <h2 class="text-sm font-black text-slate-950 dark:text-slate-50 sm:text-base">Payment status</h2>
            <p class="mt-1 hidden text-xs font-semibold text-slate-500 dark:text-slate-400 sm:block">Only mark as paid after cash or bank transfer has been confirmed.</p>
          </div>
        </div>

        <div class="grid gap-3 sm:gap-4 md:grid-cols-3">
          <div>
            <%= form.label :payment_method, "Payment Method", class: label_classes %>
            <%= form.select :payment_method, [
              [ "Cash", "cash" ],
              [ "Bank transfer", "bank_transfer" ]
            ], {}, class: input_classes %>
            <p class="<%= hint_classes %>">Bank transfer is the normal MSJ method.</p>
          </div>

          <% if current_user.finance_approver? && membership_payment.persisted? %>
            <div>
              <%= form.label :status, class: label_classes %>
              <%= form.select :status, MembershipPayment.statuses.keys.map { |status| [ status.humanize, status ] }, {}, class: input_classes %>
              <p class="<%= hint_classes %>">Use Paid only for verified payments.</p>
            </div>
          <% else %>
            <div class="rounded-xl border border-amber-200 bg-amber-50 px-3 py-3 text-sm font-bold text-amber-800 dark:border-amber-400/40 dark:bg-amber-400/10 dark:text-amber-100">
              <p class="text-xs font-black uppercase tracking-wide">Status</p>
              <p class="mt-1 text-sm font-black">Waiting Transfer</p>
            </div>
          <% end %>

          <div class="<%= membership_payment.persisted? ? "" : "hidden md:block md:invisible" %>">
            <%= form.label :paid_on, "Paid Date", class: label_classes %>
            <%= form.date_field :paid_on, class: input_classes %>
            <p class="<%= hint_classes %>">Fill when status is paid.</p>
          </div>
        </div>
      </section>

      <section class="<%= section_classes %>">
        <div class="mb-3 flex items-center gap-2.5 sm:mb-4 sm:items-start sm:gap-3">
          <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-slate-100 text-xs font-black text-slate-700 dark:bg-slate-700 dark:text-slate-100 sm:h-8 sm:w-8 sm:rounded-xl sm:text-sm">4</span>
          <div>
            <h2 class="text-sm font-black text-slate-950 dark:text-slate-50 sm:text-base">Reference and notes</h2>
            <p class="mt-1 hidden text-xs font-semibold text-slate-500 dark:text-slate-400 sm:block">Optional details help treasurers trace this record later.</p>
          </div>
        </div>

        <div class="grid gap-3 sm:gap-4">
          <div>
            <%= form.label :reference_number, "Reference Number", class: label_classes %>
            <%= form.text_field :reference_number, placeholder: "Bank reference, receipt number, or payer name", class: input_classes %>
          </div>

          <div>
            <%= form.label :notes, class: label_classes %>
            <%= form.text_area :notes, rows: 3, placeholder: "Add a short internal note if needed.", class: input_classes %>
          </div>
        </div>
      </section>
    </div>

    <aside class="hidden space-y-4 xl:block">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h2 class="text-sm font-black uppercase tracking-wide text-slate-500 dark:text-slate-400">Quick guide</h2>
        <div class="mt-4 space-y-3 text-sm font-semibold text-slate-700 dark:text-slate-200">
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 dark:border-slate-700 dark:bg-slate-900/70">
            <div class="flex gap-3">
              <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-red-100 text-red-700 dark:bg-red-500/15 dark:text-red-200">
                <%= icon_svg(:user, classes: "h-4 w-4") %>
              </span>
              <div>
                <p class="font-black text-slate-900 dark:text-slate-50">Select member</p>
                <p class="mt-1 text-xs leading-5 text-slate-500 dark:text-slate-400">Members with an active or paid record for this plan/year are hidden.</p>
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 dark:border-slate-700 dark:bg-slate-900/70">
            <div class="flex gap-3">
              <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200">
                <%= icon_svg(:tag, classes: "h-4 w-4") %>
              </span>
              <div>
                <p class="font-black text-slate-900 dark:text-slate-50">Choose payment plan</p>
                <p class="mt-1 text-xs leading-5 text-slate-500 dark:text-slate-400">The amount fills automatically from the selected plan.</p>
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 dark:border-slate-700 dark:bg-slate-900/70">
            <div class="flex gap-3">
              <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-amber-100 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200">
                <%= icon_svg(:clock, classes: "h-4 w-4") %>
              </span>
              <div>
                <p class="font-black text-slate-900 dark:text-slate-50">Save as waiting transfer</p>
                <p class="mt-1 text-xs leading-5 text-slate-500 dark:text-slate-400">Mark Paid only after cash or bank transfer is verified.</p>
              </div>
            </div>
          </div>
          <div class="flex gap-3 rounded-xl border border-red-100 bg-red-50 p-3 text-xs leading-5 text-red-800 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-100">
            <%= icon_svg(:shield_check, classes: "mt-0.5 h-4 w-4 shrink-0") %>
            <p>Use this page to create a payment request. Use the review page to approve real payments.</p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
        <p class="font-black text-slate-900 dark:text-slate-50">Use this page for</p>
        <div class="mt-3 space-y-2">
          <div class="flex items-center gap-2 rounded-xl bg-white px-3 py-2 dark:bg-slate-800">
            <%= icon_svg(:banknotes, classes: "h-4 w-4 shrink-0 text-emerald-600 dark:text-emerald-300") %>
            <span>Manual cash records</span>
          </div>
          <div class="flex items-center gap-2 rounded-xl bg-white px-3 py-2 dark:bg-slate-800">
            <%= icon_svg(:arrow_path, classes: "h-4 w-4 shrink-0 text-blue-600 dark:text-blue-300") %>
            <span>Older transfer entries</span>
          </div>
          <div class="flex items-center gap-2 rounded-xl bg-white px-3 py-2 dark:bg-slate-800">
            <%= icon_svg(:pencil_square, classes: "h-4 w-4 shrink-0 text-amber-600 dark:text-amber-300") %>
            <span>Treasurer corrections</span>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <div class="sticky bottom-[calc(env(safe-area-inset-bottom)+4.85rem)] z-20 -mx-4 border-t border-slate-200 bg-slate-50/95 px-4 py-3 shadow-[0_-12px_30px_rgba(15,23,42,0.08)] backdrop-blur dark:border-slate-700 dark:bg-slate-950/95 sm:-mx-6 sm:px-6 lg:bottom-0 lg:rounded-2xl lg:border lg:bg-white/95 lg:shadow-lg lg:dark:bg-slate-900/95">
    <div class="grid grid-cols-2 gap-2 sm:flex sm:justify-end">
      <%= link_to admin_membership_payments_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
        <span>Cancel</span>
      <% end %>
      <%= form.button type: :submit, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:save, classes: "h-4 w-4") %>
        <span><%= membership_payment.persisted? ? "Update Payment" : "Create Payment" %></span>
      <% end %>
    </div>
  </div>
<% end %>
