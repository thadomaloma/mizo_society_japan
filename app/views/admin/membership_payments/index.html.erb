<% content_for :page_title, "Payments" %>

<div class="space-y-6">
  <% header_actions = capture do %>
    <% if policy(MembershipPayment).create? %>
      <%= link_to new_admin_membership_payment_path, class: action_button_classes(:primary) do %>
        <%= icon_svg(:plus, classes: "h-4 w-4") %>
        <span>Add Payment</span>
      <% end %>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Finance",
    title: "Payments",
    subtitle: "Record, review, approve, and reconcile membership, donation, fundraiser, and society fund payments.",
    actions: header_actions %>

  <%= form_with url: admin_membership_payments_path, method: :get, class: "grid grid-cols-2 gap-3 rounded-2xl border border-slate-200 bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] xl:grid-cols-[1fr_11rem_11rem_10rem_auto] xl:p-4" do |form| %>
    <%= form.search_field :query, value: @query, placeholder: "Search member, email, reference...", class: "col-span-2 rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none placeholder:text-slate-400 focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white dark:placeholder:text-slate-400 md:col-span-1 md:rounded-lg md:py-2" %>
    <%= form.select :status, options_for_select([ [ "All statuses", "" ] ] + MembershipPayment.statuses.keys.map { |status| [ status.humanize, status ] }, @status), {}, class: "rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
    <%= form.select :year, options_for_select([ [ "All years", "" ] ] + @years.map { |year| [ year, year ] }, @year), {}, class: "rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
    <%= form.select :plan_type_id, options_for_select([ [ "All plan types", "" ] ] + @plan_type_options.map { |type| [ type.name, type.id ] }, @plan_type_id), {}, class: "rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
    <%= form.button type: :submit, class: action_button_classes(:dark, full_width: true, extra: "col-span-2 xl:col-span-1 xl:w-auto") do %>
      <%= icon_svg(:filter, classes: "h-4 w-4") %>
      <span>Filter</span>
    <% end %>
  <% end %>

  <% if @membership_payments.any? %>
    <div class="hidden overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B] lg:block">
      <table class="min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-[#334155]">
        <thead class="bg-slate-50 text-xs font-black uppercase tracking-wide text-slate-500 dark:bg-[#0F172A] dark:text-slate-300">
          <tr>
            <th class="px-5 py-3">Member</th>
            <th class="px-5 py-3">Plan</th>
            <th class="px-5 py-3">Period</th>
            <th class="px-5 py-3">Amount</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Submitted / Paid</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white dark:divide-[#334155] dark:bg-[#1E293B]">
          <%= render partial: "payment_row", collection: @membership_payments, as: :payment %>
        </tbody>
      </table>
    </div>

    <div class="grid gap-4 lg:hidden">
      <%= render partial: "payment_card", collection: @membership_payments, as: :payment %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No payments found", message: "Try changing the filters or record a new payment." %>
  <% end %>
</div>
