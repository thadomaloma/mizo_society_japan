<% content_for :page_title, "Payment Records" %>

<div class="space-y-6">
  <% header_actions = capture do %>
    <% if policy(MembershipPayment).create? %>
      <%= link_to new_admin_membership_payment_path, class: action_button_classes(:primary) do %>
        <%= icon_svg(:plus, classes: "h-4 w-4") %>
        <span>Add Payment</span>
      <% end %>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Finance",
    title: "Payment Records",
    subtitle: "Record, review, approve, and reconcile membership, donation, fundraiser, and society fund payments.",
    actions: header_actions %>

  <%= render "overview_panel", payment_summary: @payment_summary %>

  <%= render ::RubyUI::Card.new(class: "rounded-xl border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]") do %>
  <%= form_with url: admin_membership_payments_path, method: :get, class: "grid grid-cols-2 gap-2 xl:grid-cols-[minmax(16rem,1fr)_11rem_11rem_11rem_auto]" do |form| %>
    <div class="relative col-span-2 md:col-span-1">
      <span class="pointer-events-none absolute inset-y-0 left-0 grid w-10 place-items-center text-slate-400"><%= icon_svg(:search, classes: "h-4 w-4") %></span>
      <%= form.search_field :query, value: @query, placeholder: "Search member, email, reference...", aria: { label: "Search payment records" }, class: "w-full rounded-xl border border-slate-300 bg-white py-2.5 pl-10 pr-3 text-sm text-slate-900 outline-none placeholder:text-slate-400 focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white dark:placeholder:text-slate-400 md:rounded-lg md:py-2" %>
    </div>
    <% status_options = [
      [ "All records", "all" ],
      [ "To verify", "pending_verification" ],
      [ "Waiting transfer", "pending" ],
      [ "Paid", "paid" ],
      [ "Needs correction", "failed" ],
      [ "Refunded", "refunded" ]
    ] %>
    <%= form.select :status, options_for_select(status_options, @status), {}, aria: { label: "Payment status" }, class: "rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
    <% if @years.many? %><%= form.select :year, options_for_select([ [ "All years", "" ] ] + @years.map { |year| [ year, year ] }, @year), {}, aria: { label: "Payment year" }, class: "rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %><% end %>
    <% if @plan_type_options.many? %><%= form.select :plan_type_id, options_for_select([ [ "All plan types", "" ] ] + @plan_type_options.map { |type| [ type.name, type.id ] }, @plan_type_id), {}, aria: { label: "Payment plan type" }, class: "rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %><% end %>
    <div class="col-span-2 flex justify-end gap-2 xl:col-span-1">
      <% if @query.present? || @status != "all" || @year.present? || @plan_type_id.present? %>
        <%= link_to admin_membership_payments_path, class: action_button_classes(:secondary, size: :sm) do %>
          <%= icon_svg(:x_mark, classes: "h-4 w-4") %><span>Reset</span>
        <% end %>
      <% end %>
    <%= form.button type: :submit, class: action_button_classes(:dark, extra: "px-3") do %>
      <%= icon_svg(:filter, classes: "h-4 w-4") %>
      <span class="sm:inline">Filter</span>
    <% end %>
    </div>
  <% end %>
  <% end %>

  <% if @payment_batches.any? %>
    <%= render ::RubyUI::Card.new(class: "rounded-xl border-amber-200 bg-amber-50/40 p-3 shadow-sm dark:border-amber-500/30 dark:bg-amber-500/10 sm:p-4") do %>
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-black uppercase tracking-wide text-amber-700 dark:text-amber-300">Combined transfers</p>
          <h2 class="mt-0.5 text-base font-black text-slate-950 dark:text-white">Pending batch review</h2>
          <p class="mt-1 text-xs font-semibold text-amber-800 dark:text-amber-100/80">One bank transfer can include multiple member payments.</p>
        </div>
        <span class="rounded-full bg-white px-2.5 py-1 text-xs font-black text-amber-700 shadow-sm dark:bg-slate-900 dark:text-amber-300"><%= @payment_batches.count %></span>
      </div>
      <div class="mt-3 grid gap-2 lg:grid-cols-2 xl:grid-cols-3">
        <%= render partial: "payment_batch_card", collection: @payment_batches, as: :payment_batch %>
      </div>
    <% end %>
  <% end %>

  <% if @membership_payments.any? %>
    <%= render ::RubyUI::Card.new(class: "hidden overflow-hidden rounded-xl border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B] lg:block") do %>
      <%= render ::RubyUI::Table.new(class: "min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-[#334155]") do %>
        <thead class="bg-slate-50 text-xs font-black uppercase tracking-wide text-slate-500 dark:bg-[#0F172A] dark:text-slate-300">
          <tr>
            <th class="px-5 py-3">Member</th>
            <th class="px-5 py-3">Plan</th>
            <th class="px-5 py-3">Period</th>
            <th class="px-5 py-3">Amount</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Submitted / Paid</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white dark:divide-[#334155] dark:bg-[#1E293B]">
          <%= render partial: "payment_row", collection: @membership_payments, as: :payment %>
        </tbody>
      <% end %>
      <%= render "shared/data_table_footer", pagination: @pagination, label: "payment records" %>
    <% end %>

    <div class="grid gap-2 lg:hidden">
      <%= render partial: "payment_card", collection: @membership_payments, as: :payment %>
      <div class="mt-1 overflow-hidden rounded-lg border border-[#E2E8F0] dark:border-[#334155]">
        <%= render "shared/data_table_footer", pagination: @pagination, label: "payment records" %>
      </div>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No payments found", message: "Try changing the filters or record a new payment." %>
  <% end %>
</div>
