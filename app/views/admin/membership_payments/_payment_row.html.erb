<% table_button_base = "inline-flex h-8 min-w-[4.5rem] items-center justify-center gap-1.5 rounded-lg px-2.5 text-xs font-black transition focus:outline-none focus:ring-2 focus:ring-red-500/30" %>
<% table_button_neutral = "#{table_button_base} border border-slate-200 bg-white text-slate-700 shadow-sm hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800" %>
<% table_button_success = "#{table_button_base} bg-emerald-600 text-white shadow-sm shadow-emerald-950/10 hover:bg-emerald-700" %>
<% table_button_receipt = "#{table_button_base} bg-emerald-600 text-white shadow-sm shadow-emerald-950/10 hover:bg-emerald-700" %>

<tr class="transition-colors hover:bg-slate-50/80 dark:hover:bg-[#334155]/45">
  <td class="px-5 py-4">
    <p class="font-black text-gray-950 dark:text-white"><%= user_label(payment.user) %></p>
    <p class="mt-1 text-xs font-semibold text-gray-500 dark:text-gray-300"><%= payment.user.email %></p>
    <% if payment.for_family_member? %><p class="mt-1 text-xs font-black text-red-700 dark:text-red-300"><%= payment.payment_for_label %></p><% end %>
  </td>
  <td class="px-5 py-4 text-gray-700 dark:text-gray-200"><p class="font-bold"><%= payment.membership_plan.name %></p><p class="mt-1 text-xs font-semibold text-gray-500 dark:text-gray-300"><%= payment.plan_type_label %></p></td>
  <td class="px-5 py-4 font-semibold text-gray-700 dark:text-gray-200"><%= payment.period_label %></td>
  <td class="px-5 py-4"><%= render "shared/amount", amount: payment.amount %></td>
  <td class="px-5 py-4">
    <%= render "admin/membership_payments/review_badge", payment: payment %>
    <p class="mt-1 max-w-44 text-xs font-semibold leading-4 text-slate-500 dark:text-slate-400"><%= payment_review_description(payment) %></p>
  </td>
  <td class="px-5 py-4 text-gray-600 dark:text-gray-300">
    <% if payment.pending_verification? %>
      <p class="font-black text-amber-700 dark:text-amber-300"><%= payment.transferred_on&.strftime("%b %d, %Y") || "Submitted" %></p>
      <p class="mt-1 text-xs font-semibold text-gray-500 dark:text-gray-300"><%= payment.transfer_reference_name.presence || "Awaiting review" %></p>
    <% else %>
      <%= payment.paid_on&.strftime("%b %d, %Y") || "Not recorded" %>
    <% end %>
    <span class="mt-2 inline-flex rounded-full px-2 py-0.5 text-[11px] font-black ring-1 ring-inset <%= payment_receipt_badge_classes(payment) %>"><%= payment_receipt_label(payment) %></span>
  </td>
  <td class="px-5 py-4">
    <div class="flex min-w-[12rem] flex-col items-end gap-2">
      <%= link_to admin_membership_payment_path(payment), class: table_button_neutral do %>
        <%= icon_svg(:eye, classes: "h-3.5 w-3.5") %>
        <span>View</span>
      <% end %>

      <% if policy(payment).approve? %>
        <%= button_to approve_admin_membership_payment_path(payment), method: :patch, form: { class: "min-w-0" }, class: table_button_success do %>
          <%= icon_svg(:check, classes: "h-3.5 w-3.5") %>
          <span>Approve</span>
        <% end %>
      <% end %>

      <% if payment.receipt_sendable? && !payment.receipt_sent? %>
        <%= render "admin/membership_payments/receipt_delivery_actions",
          payment: payment,
          compact: true,
          wrapper_classes: "flex justify-end",
          send_classes: table_button_receipt,
          confirm_classes: table_button_success %>
      <% end %>
    </div>
  </td>
</tr>
