<article class="rounded-2xl border border-amber-200 bg-amber-50/80 p-3 shadow-sm dark:border-amber-500/30 dark:bg-amber-500/10 sm:p-4">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <p class="text-xs font-black uppercase tracking-wide text-amber-700 dark:text-amber-300">Combined payment</p>
      <h3 class="mt-1 truncate text-base font-black text-slate-950 dark:text-white"><%= user_label(payment_batch.user) %></h3>
      <p class="mt-1 text-xs font-semibold text-slate-600 dark:text-slate-300"><%= pluralize(payment_batch.membership_payments.count, "item") %> · <%= payment_batch.transferred_on&.strftime("%b %d, %Y") || "Submitted" %></p>
    </div>
    <%= render "shared/status_badge", status: payment_batch.status, compact: true %>
  </div>

  <div class="mt-3 flex items-end justify-between gap-3 rounded-xl bg-white px-3 py-2 dark:bg-slate-900">
    <div>
      <p class="text-xs font-black uppercase tracking-wide text-slate-400">Total</p>
      <p class="mt-0.5 text-xl font-black text-slate-950 dark:text-white"><%= yen(payment_batch.total_amount) %></p>
    </div>
    <p class="truncate text-right text-xs font-semibold text-slate-500 dark:text-slate-400"><%= payment_batch.transfer_reference_name.presence || "No reference" %></p>
  </div>

  <div class="mt-3 grid grid-cols-2 gap-2">
    <%= link_to admin_payment_batch_path(payment_batch), class: action_button_classes(:secondary, size: :xs, full_width: true) do %>
      <%= icon_svg(:eye, classes: "h-4 w-4") %>
      <span>Review</span>
    <% end %>
    <% if policy(payment_batch).approve? %>
      <%= button_to approve_admin_payment_batch_path(payment_batch), method: :patch, class: action_button_classes(:success, size: :xs, full_width: true) do %>
        <%= icon_svg(:check, classes: "h-4 w-4") %>
        <span>Approve All</span>
      <% end %>
    <% end %>
  </div>
</article>
