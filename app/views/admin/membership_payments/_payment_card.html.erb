<article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h3 class="break-words font-black text-gray-950 dark:text-white"><%= user_label(payment.user) %></h3>
      <p class="mt-1 text-sm font-semibold text-gray-500 dark:text-gray-300"><%= payment.membership_plan.name %> · <%= payment.period_label %></p>
      <p class="mt-1 text-xs font-black text-red-700 dark:text-red-300"><%= payment.plan_type_label %></p>
    </div>
    <%= render "shared/status_badge", status: payment.status %>
  </div>
  <div class="mt-5 flex items-end justify-between gap-4">
    <div>
      <p class="text-xs font-bold uppercase tracking-wide text-gray-400 dark:text-gray-300">Amount</p>
      <p class="mt-1 text-2xl font-black text-gray-950 dark:text-white"><%= yen(payment.amount) %></p>
    </div>
    <div class="text-right">
      <p class="text-sm font-semibold text-gray-500 dark:text-gray-300"><%= payment.paid_on&.strftime("%b %d, %Y") || "Not paid" %></p>
      <% if payment.pending_verification? %>
        <p class="mt-1 text-xs font-black text-amber-700 dark:text-amber-300">Submitted <%= payment.transferred_on&.strftime("%b %d") || "for review" %></p>
      <% end %>
    </div>
  </div>
  <div class="mt-5 grid gap-2 <%= policy(payment).approve? || policy(payment).update? ? "grid-cols-2" : "grid-cols-1" %>">
    <%= link_to admin_membership_payment_path(payment), class: action_button_classes(:secondary, full_width: true) do %>
      <%= icon_svg(:eye, classes: "h-4 w-4") %>
      <span>View</span>
    <% end %>
    <% if policy(payment).approve? %>
      <%= button_to approve_admin_membership_payment_path(payment), method: :patch, class: action_button_classes(:success, full_width: true) do %>
        <%= icon_svg(:check, classes: "h-4 w-4") %>
        <span>Approve</span>
      <% end %>
    <% elsif policy(payment).update? %>
      <%= link_to edit_admin_membership_payment_path(payment), class: action_button_classes(:dark, full_width: true) do %>
        <%= icon_svg(:edit, classes: "h-4 w-4") %>
        <span>Edit</span>
      <% end %>
    <% end %>
  </div>
</article>
