<article class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5">
  <% mobile_button_base = "inline-flex min-w-0 items-center justify-center gap-1.5 rounded-xl px-2.5 py-2 text-xs font-black shadow-sm transition" %>
  <% mobile_button_neutral = "#{mobile_button_base} border border-[#E2E8F0] bg-white text-[#0F172A] hover:bg-slate-50 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white dark:hover:bg-slate-800" %>
  <% mobile_button_success = "#{mobile_button_base} bg-emerald-600 text-white shadow-emerald-950/10 hover:bg-emerald-700" %>

  <div class="flex items-start justify-between gap-2 sm:gap-3">
    <div class="min-w-0">
      <h3 class="truncate text-[15px] font-black leading-5 text-gray-950 dark:text-white sm:text-base"><%= user_label(payment.user) %></h3>
      <p class="mt-0.5 line-clamp-1 text-xs font-semibold leading-5 text-gray-500 dark:text-gray-300 sm:mt-1 sm:text-sm"><%= payment.membership_plan.name %> · <%= payment.period_label %></p>
      <% if payment.for_family_member? %><p class="mt-0.5 truncate text-[11px] font-black text-red-700 dark:text-red-300"><%= payment.payment_for_label %></p><% end %>
      <div class="mt-1 flex min-w-0 flex-wrap items-center gap-1.5 sm:mt-1">
        <p class="truncate text-[11px] font-black text-red-700 dark:text-red-300 sm:text-xs"><%= payment.plan_type_label %></p>
        <span class="sm:hidden"><%= render "admin/membership_payments/review_badge", payment: payment %></span>
      </div>
    </div>
    <span class="hidden sm:inline-flex"><%= render "admin/membership_payments/review_badge", payment: payment %></span>
  </div>
  <div class="mt-2.5 flex items-end justify-between gap-3 sm:mt-5 sm:gap-4">
    <div class="min-w-0">
      <p class="text-[10px] font-bold uppercase tracking-wide text-gray-400 dark:text-gray-300 sm:text-xs">Amount</p>
      <p class="mt-0.5 truncate text-lg font-black text-gray-950 dark:text-white sm:mt-1 sm:text-2xl"><%= yen(payment.amount) %></p>
    </div>
    <div class="min-w-0 text-right">
      <p class="text-xs font-semibold text-gray-500 dark:text-gray-300 sm:text-sm"><%= payment.paid_on&.strftime("%b %d, %Y") || "Not paid" %></p>
      <% if payment.pending_verification? %>
        <p class="mt-0.5 truncate text-[11px] font-black text-amber-700 dark:text-amber-300 sm:mt-1 sm:text-xs">Submitted <%= payment.transferred_on&.strftime("%b %d") || "for review" %></p>
      <% end %>
    </div>
  </div>
  <div class="mt-2 rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 text-[11px] font-bold leading-4 text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 sm:mt-3 sm:text-xs">
    <%= payment_review_description(payment) %>
  </div>
  <div class="mt-2 flex items-center justify-between gap-2 rounded-xl border border-slate-100 bg-white px-3 py-2 dark:border-slate-700 dark:bg-slate-900 sm:mt-3">
    <span class="text-[10px] font-black uppercase tracking-wide text-slate-400 dark:text-slate-500">Receipt</span>
    <span class="inline-flex rounded-full px-2 py-0.5 text-[11px] font-black ring-1 ring-inset <%= payment_receipt_badge_classes(payment) %>"><%= payment_receipt_label(payment) %></span>
  </div>

  <div class="mt-3 grid min-w-0 gap-2 sm:hidden <%= policy(payment).approve? ? 'grid-cols-2' : 'grid-cols-1' %>">
    <%= link_to admin_membership_payment_path(payment), class: mobile_button_neutral do %>
      <%= icon_svg(:eye, classes: "h-4 w-4 shrink-0") %>
      <span>View</span>
    <% end %>
    <% if policy(payment).approve? %>
      <%= button_to approve_admin_membership_payment_path(payment), method: :patch, form: { class: "min-w-0" }, class: "#{mobile_button_success} w-full" do %>
        <%= icon_svg(:check, classes: "h-4 w-4 shrink-0") %>
        <span>Approve</span>
      <% end %>
    <% end %>
  </div>

  <% if payment.receipt_sendable? && !payment.receipt_sent? %>
    <div class="mt-2 sm:hidden">
      <%= render "admin/membership_payments/receipt_delivery_actions",
        payment: payment,
        compact: true,
        send_classes: "#{mobile_button_success} w-full",
        confirm_classes: "#{mobile_button_success} w-full" %>
    </div>
  <% end %>

  <div class="mt-5 hidden gap-2 sm:grid <%= policy(payment).approve? ? 'sm:grid-cols-2' : 'sm:grid-cols-1' %>">
    <%= link_to admin_membership_payment_path(payment), class: action_button_classes(:secondary, size: :xs, full_width: true, extra: "rounded-xl") do %>
      <%= icon_svg(:eye, classes: "h-4 w-4") %>
      <span>View</span>
    <% end %>
    <% if policy(payment).approve? %>
      <%= button_to approve_admin_membership_payment_path(payment), method: :patch, class: action_button_classes(:success, size: :xs, full_width: true, extra: "rounded-xl") do %>
        <%= icon_svg(:check, classes: "h-4 w-4") %>
        <span>Approve</span>
      <% end %>
    <% end %>
    <% if payment.receipt_sendable? && !payment.receipt_sent? %>
      <%= render "admin/membership_payments/receipt_delivery_actions",
        payment: payment,
        compact: true,
        wrapper_classes: "sm:col-span-2",
        send_classes: action_button_classes(:success, size: :xs, full_width: true, extra: "rounded-xl"),
        confirm_classes: action_button_classes(:success, size: :xs, full_width: true, extra: "rounded-xl w-full") %>
    <% end %>
  </div>
</article>
