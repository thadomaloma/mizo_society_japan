<% content_for :page_title, "Payment" %>

<div class="space-y-6">
  <%= render "shared/page_header",
    eyebrow: "Payment",
    title: user_label(@membership_payment.user),
    subtitle: "#{@membership_payment.membership_plan.name} · #{@membership_payment.period_label}",
    actions: safe_join([
      link_to(admin_membership_payments_path, class: action_button_classes(:secondary)) do
        safe_join([ icon_svg(:arrow_left, classes: "h-4 w-4"), tag.span("Back") ])
      end,
      (link_to(edit_admin_membership_payment_path(@membership_payment), class: action_button_classes(:dark)) do
        safe_join([ icon_svg(:edit, classes: "h-4 w-4"), tag.span("Edit") ])
      end if policy(@membership_payment).update?)
    ].compact, " ") %>

  <section class="grid gap-5 lg:grid-cols-[1fr_22rem]">
    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <% if @membership_payment.user.member_profile.present? %>
        <div class="mb-5 rounded-2xl border border-[#E2E8F0] bg-slate-50 p-4 dark:border-[#334155] dark:bg-[#0F172A]">
          <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-400">Member Contact</p>
          <p class="mt-1 font-black text-gray-950 dark:text-white"><%= @membership_payment.user.display_name %></p>
          <p class="mt-1 text-sm font-semibold text-gray-500 dark:text-gray-300"><%= @membership_payment.user.member_profile.mobile_number %></p>
          <div class="mt-3">
            <%= render "admin/shared/member_contact_actions", user: @membership_payment.user %>
          </div>
        </div>
      <% end %>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <p class="text-sm font-bold text-gray-500">Amount</p>
          <p class="mt-2 text-3xl font-black text-gray-950"><%= yen(@membership_payment.amount) %></p>
        </div>
        <div>
          <p class="text-sm font-bold text-gray-500">Status</p>
          <p class="mt-2"><%= render "shared/status_badge", status: @membership_payment.status %></p>
        </div>
        <div>
          <p class="text-sm font-bold text-gray-500">Payment method</p>
          <p class="mt-2 font-black capitalize text-gray-950"><%= @membership_payment.payment_method.humanize %></p>
        </div>
        <div>
          <p class="text-sm font-bold text-gray-500">Reference</p>
          <p class="mt-2 font-black text-gray-950"><%= @membership_payment.reference_number.presence || "Not recorded" %></p>
        </div>
        <div>
          <p class="text-sm font-bold text-gray-500">Paid on</p>
          <p class="mt-2 font-black text-gray-950"><%= @membership_payment.paid_on&.strftime("%b %d, %Y") || "Not recorded" %></p>
        </div>
        <div>
          <p class="text-sm font-bold text-gray-500">Approved by</p>
          <p class="mt-2 font-black text-gray-950"><%= @membership_payment.approved_by&.display_name || "Not approved" %></p>
        </div>
      </div>

      <% if @membership_payment.transferred_on.present? || @membership_payment.transfer_reference_name.present? || @membership_payment.transfer_screenshot.attached? %>
        <div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 p-4 dark:border-amber-500/30 dark:bg-amber-500/10">
          <p class="text-xs font-black uppercase tracking-wide text-amber-700 dark:text-amber-300">Member transfer submission</p>
          <div class="mt-4 grid gap-4 sm:grid-cols-3">
            <div>
              <p class="text-xs font-bold text-amber-700 dark:text-amber-200">Transfer date</p>
              <p class="mt-1 font-black text-gray-950 dark:text-white"><%= @membership_payment.transferred_on&.strftime("%b %d, %Y") || "Not submitted" %></p>
            </div>
            <div>
              <p class="text-xs font-bold text-amber-700 dark:text-amber-200">Submitted amount</p>
              <p class="mt-1 font-black text-gray-950 dark:text-white"><%= yen(@membership_payment.transfer_amount || @membership_payment.amount) %></p>
            </div>
            <div>
              <p class="text-xs font-bold text-amber-700 dark:text-amber-200">Reference name</p>
              <p class="mt-1 font-black text-gray-950 dark:text-white"><%= @membership_payment.transfer_reference_name.presence || "Not submitted" %></p>
            </div>
          </div>
          <% if @membership_payment.transfer_screenshot.attached? %>
            <%= link_to rails_blob_path(@membership_payment.transfer_screenshot, disposition: "attachment"), class: "#{action_button_classes(:secondary, size: :sm)} mt-4", target: "_blank", rel: "noopener" do %>
              <%= icon_svg(:download, classes: "h-4 w-4") %>
              <span>Download screenshot</span>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="mt-6 border-t border-gray-200 pt-6">
        <p class="text-sm font-bold text-gray-500">Notes</p>
        <p class="mt-2 text-sm leading-6 text-gray-700"><%= @membership_payment.notes.presence || "No notes." %></p>
      </div>
    </div>

    <aside class="space-y-3 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
      <h3 class="text-lg font-black text-gray-950">Review actions</h3>
      <% if policy(@membership_payment).approve? %>
        <%= button_to approve_admin_membership_payment_path(@membership_payment), method: :patch, class: action_button_classes(:success, full_width: true) do %>
          <%= icon_svg(:check, classes: "h-4 w-4") %>
          <span>Approve</span>
        <% end %>
        <%= button_to reject_admin_membership_payment_path(@membership_payment), method: :patch, class: action_button_classes(:danger, full_width: true) do %>
          <%= icon_svg(:x_mark, classes: "h-4 w-4") %>
          <span>Reject</span>
        <% end %>
      <% end %>
      <% if policy(@membership_payment).destroy? %>
        <%= button_to admin_membership_payment_path(@membership_payment), method: :delete, data: { turbo_confirm: "Delete this payment?" }, class: action_button_classes(:outline_danger, full_width: true) do %>
          <%= icon_svg(:trash, classes: "h-4 w-4") %>
          <span>Delete</span>
        <% end %>
      <% end %>
    </aside>
  </section>
</div>
