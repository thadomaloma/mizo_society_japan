<% content_for :page_title, "Audit Logs" %>

<div class="space-y-6">
  <%= render "shared/page_header",
    eyebrow: "Settings",
    title: "Audit Logs",
    subtitle: "Security and accountability records for important portal actions." %>

  <% filter_input_classes = "rounded-lg border border-[#CBD5E1] bg-white px-3 py-2 text-sm text-[#0F172A] outline-none placeholder:text-[#64748B] focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
  <%= form_with url: admin_audit_logs_path, method: :get, class: "grid gap-2 rounded-lg border border-[#E2E8F0] bg-white p-3 shadow-sm md:grid-cols-2 xl:grid-cols-[minmax(13rem,1fr)_minmax(13rem,1fr)_10rem_10rem_auto] dark:border-[#334155] dark:bg-[#1E293B]" do |form| %>
    <%= form.search_field :action_query, value: @action_query, placeholder: "Search action...", class: filter_input_classes %>
    <%= form.search_field :user_query, value: @user_query, placeholder: "Search user or email...", class: filter_input_classes %>
    <%= form.date_field :start_date, value: @start_date, aria: { label: "Start date" }, class: filter_input_classes %>
    <%= form.date_field :end_date, value: @end_date, aria: { label: "End date" }, class: filter_input_classes %>
    <div class="flex justify-end gap-2 md:col-span-2 xl:col-span-1">
      <% if @action_query.present? || @user_query.present? || @start_date.present? || @end_date.present? %>
        <%= link_to admin_audit_logs_path, class: action_button_classes(:secondary, size: :sm) do %>
          <%= icon_svg(:x_mark, classes: "h-4 w-4") %><span>Reset</span>
        <% end %>
      <% end %>
    <%= form.button type: :submit, class: action_button_classes(:dark) do %>
      <%= icon_svg(:filter, classes: "h-4 w-4") %>
      <span>Filter</span>
    <% end %>
    </div>
  <% end %>

  <% if @audit_logs.any? %>
    <div class="hidden overflow-hidden rounded-lg border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B] lg:block">
      <table class="min-w-full divide-y divide-[#E2E8F0] text-left text-sm dark:divide-[#334155]">
        <thead class="bg-[#F8FAFC] text-xs font-black uppercase tracking-wide text-[#64748B] dark:bg-[#0F172A] dark:text-[#CBD5E1]">
          <tr>
            <th class="px-5 py-3">Date & Time</th>
            <th class="px-5 py-3">User</th>
            <th class="px-5 py-3">Action</th>
            <th class="px-5 py-3">Record Type</th>
            <th class="px-5 py-3">Record ID</th>
            <th class="px-5 py-3">IP Address</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#E2E8F0] bg-white dark:divide-[#334155] dark:bg-[#1E293B]">
          <% @audit_logs.each do |log| %>
            <tr class="transition-colors hover:bg-slate-50/80 dark:hover:bg-[#334155]/45">
              <td class="px-5 py-4 font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= log.created_at.strftime("%b %d, %Y %H:%M") %></td>
              <td class="px-5 py-4 font-black text-[#0F172A] dark:text-white"><%= log.user&.display_name || "System" %></td>
              <td class="px-5 py-4"><span class="font-black text-red-700 dark:text-red-300"><%= log.action_label %></span></td>
              <td class="px-5 py-4 font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= log.auditable_type.presence || "System" %></td>
              <td class="px-5 py-4 font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= log.auditable_id.presence || "-" %></td>
              <td class="px-5 py-4 font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= log.ip_address.presence || "-" %></td>
              <td class="px-5 py-4">
                <div class="flex justify-end">
                  <%= link_to admin_audit_log_path(log), class: action_button_classes(:secondary, size: :xs) do %>
                    <%= icon_svg(:eye, classes: "h-3.5 w-3.5") %>
                    <span>View</span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <%= render "shared/data_table_footer", pagination: @pagination, label: "audit records" %>
    </div>

    <div class="grid gap-2 lg:hidden">
      <% @audit_logs.each do |log| %>
        <article class="rounded-lg border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300"><%= log.action_label %></p>
              <h3 class="mt-2 font-black text-[#0F172A] dark:text-white"><%= log.user&.display_name || "System" %></h3>
              <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= log.created_at.strftime("%b %d, %Y %H:%M") %></p>
            </div>
            <%= link_to admin_audit_log_path(log), class: action_button_classes(:secondary, size: :xs) do %>
              <%= icon_svg(:eye, classes: "h-3.5 w-3.5") %>
              <span>View</span>
            <% end %>
          </div>

          <dl class="mt-4 grid grid-cols-2 gap-3 text-sm">
            <div>
              <dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">Record</dt>
              <dd class="mt-1 font-black text-[#0F172A] dark:text-white"><%= log.record_label %></dd>
            </div>
            <div>
              <dt class="font-bold text-[#64748B] dark:text-[#CBD5E1]">IP Address</dt>
              <dd class="mt-1 font-black text-[#0F172A] dark:text-white"><%= log.ip_address.presence || "-" %></dd>
            </div>
          </dl>
        </article>
      <% end %>
      <div class="mt-1 overflow-hidden rounded-lg border border-[#E2E8F0] dark:border-[#334155]">
        <%= render "shared/data_table_footer", pagination: @pagination, label: "audit records" %>
      </div>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No audit records found.", message: "Important security and workflow actions will appear here." %>
  <% end %>
</div>
