<% content_for :page_title, "Audit Log" %>

<div class="space-y-6">
  <% audit_actions = capture do %>
    <%= link_to admin_audit_logs_path, class: action_button_classes(:secondary) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Back</span>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Settings",
    title: @audit_log.action_label,
    subtitle: @audit_log.created_at.strftime("%B %d, %Y %H:%M"),
    actions: audit_actions %>

  <section class="grid gap-5 lg:grid-cols-[1fr_22rem]">
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-6 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <dl class="grid gap-5 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">User</dt>
          <dd class="mt-2 font-black text-[#0F172A] dark:text-white"><%= @audit_log.user&.display_name || "System" %></dd>
        </div>
        <div>
          <dt class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Action</dt>
          <dd class="mt-2 font-black text-red-700 dark:text-red-300"><%= @audit_log.action %></dd>
        </div>
        <div>
          <dt class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Timestamp</dt>
          <dd class="mt-2 font-black text-[#0F172A] dark:text-white"><%= @audit_log.created_at.strftime("%b %d, %Y %H:%M:%S") %></dd>
        </div>
        <div>
          <dt class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">IP Address</dt>
          <dd class="mt-2 font-black text-[#0F172A] dark:text-white"><%= @audit_log.ip_address.presence || "-" %></dd>
        </div>
        <div>
          <dt class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Affected Record</dt>
          <dd class="mt-2 font-black text-[#0F172A] dark:text-white"><%= @audit_log.record_label %></dd>
        </div>
        <div>
          <dt class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Record ID</dt>
          <dd class="mt-2 font-black text-[#0F172A] dark:text-white"><%= @audit_log.auditable_id.presence || "-" %></dd>
        </div>
      </dl>

      <div class="mt-6 border-t border-[#E2E8F0] pt-6 dark:border-[#334155]">
        <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">User Agent</p>
        <p class="mt-2 break-words text-sm font-semibold leading-6 text-[#0F172A] dark:text-white"><%= @audit_log.user_agent.presence || "-" %></p>
      </div>
    </div>

    <aside class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="flex items-center gap-3">
        <div class="grid h-10 w-10 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300">
          <%= icon_svg(:documents, classes: "h-5 w-5") %>
        </div>
        <div>
          <h3 class="font-black text-[#0F172A] dark:text-white">Metadata JSON</h3>
          <p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Stored context for this action.</p>
        </div>
      </div>

      <pre class="mt-5 max-h-80 overflow-auto rounded-xl bg-[#0F172A] p-4 text-xs font-semibold leading-6 text-[#F8FAFC]"><%= JSON.pretty_generate(@audit_log.metadata.presence || {}) %></pre>
    </aside>
  </section>
</div>
