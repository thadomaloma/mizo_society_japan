<% content_for :page_title, "Letter Categories" %>

<div class="space-y-6">
  <% actions = capture do %>
    <div class="flex w-full gap-2 sm:w-auto">
      <%= link_to documents_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "flex-1 px-2 sm:w-auto sm:flex-none sm:px-3") do %>
        <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
        <span>Letters</span>
      <% end %>
      <%= link_to new_admin_document_category_path, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "flex-1 px-2 sm:w-auto sm:flex-none sm:px-3") do %>
        <%= icon_svg(:plus, classes: "h-4 w-4") %>
        <span>New Category</span>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Letters",
    title: "Letter Categories",
    subtitle: "Manage categories used for organising official letters.",
    actions: actions %>

  <% if @document_categories.any? %>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      <% @document_categories.each do |category| %>
        <% category_in_use = category.documents.any? %>
        <article class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
          <div class="flex items-start justify-between gap-3">
            <div class="flex min-w-0 items-center gap-3">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300">
                <%= icon_svg(:tag, classes: "h-5 w-5") %>
              </span>
              <div class="min-w-0">
                <h2 class="truncate text-base font-black text-[#0F172A] dark:text-white"><%= category.name %></h2>
                <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">
                  <%= category_in_use ? "Used by #{pluralize(category.documents.size, "letter")}" : "Ready to use" %>
                </p>
              </div>
            </div>
            <div class="flex shrink-0 items-center gap-1.5">
              <%= render "shared/status_badge", status: category.active? ? "active" : "inactive" %>
              <%= link_to edit_admin_document_category_path(category), class: action_button_classes(:secondary, size: :xs, extra: "h-8 w-8 px-0"), title: "Edit #{category.name}" do %>
                <%= icon_svg(:edit, classes: "h-3.5 w-3.5") %>
              <% end %>
              <% unless category_in_use %>
                <%= button_to admin_document_category_path(category), method: :delete, data: { turbo_confirm: "Delete #{category.name}? This cannot be undone." }, class: action_button_classes(:outline_danger, size: :xs, extra: "h-8 w-8 px-0"), form: { class: "inline-flex" }, title: "Delete #{category.name}" do %>
                  <%= icon_svg(:trash, classes: "h-3.5 w-3.5") %>
                <% end %>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No letter categories found", message: "Create a category before preparing a letter." %>
  <% end %>
</div>
