<%= form_with model: [ :admin, document_category ], class: "rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-6" do |form| %>
  <%= render "devise/shared/error_messages", resource: document_category %>
  <div class="grid gap-5 sm:grid-cols-[minmax(0,1fr)_8rem]"><div><%= form.label :name, class: "block text-sm font-black text-[#0F172A] dark:text-white" do %>Category Name <span class="text-red-600">*</span><% end %><%= form.text_field :name, required: true, autofocus: true, placeholder: "e.g. Membership Forms", class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %></div><div><%= form.label :position, "Order", class: "block text-sm font-black text-[#0F172A] dark:text-white" %><%= form.number_field :position, min: 0, class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %></div><div class="sm:col-span-2"><%= form.label :description, class: "block text-sm font-black text-[#0F172A] dark:text-white" %><%= form.text_area :description, rows: 3, class: "mt-2 block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2.5 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %></div><label class="flex items-center gap-3 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] px-3 py-3 sm:col-span-2 dark:border-[#334155] dark:bg-[#0F172A]"><%= form.check_box :active, class: "h-5 w-5 rounded border-slate-300 text-red-700 focus:ring-red-600" %><span class="text-sm font-black text-[#0F172A] dark:text-white">Active category</span></label></div>
  <div class="mt-6 grid grid-cols-2 gap-2 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A] sm:flex sm:justify-end">
    <%= link_to admin_document_categories_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %><%= icon_svg(:arrow_left, classes: "h-4 w-4") %><span>Cancel</span><% end %>
    <%= form.button type: :submit, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %><%= icon_svg(:save, classes: "h-4 w-4") %><span><%= document_category.persisted? ? "Update Category" : "Create Category" %></span><% end %>
  </div>
<% end %>
