<tr>
  <td class="px-5 py-4 font-semibold text-gray-700"><%= transaction.transaction_date.strftime("%b %d, %Y") %></td>
  <td class="px-5 py-4">
    <p class="font-black text-gray-950"><%= transaction.finance_category.name %></p>
    <p class="mt-1 text-xs font-semibold text-gray-500"><%= transaction.reference_number.presence || "No reference" %></p>
  </td>
  <td class="px-5 py-4"><%= render "shared/status_badge", status: transaction.transaction_type %></td>
  <td class="px-5 py-4"><%= render "shared/amount", amount: transaction.amount %></td>
  <td class="px-5 py-4"><%= render "shared/status_badge", status: transaction.status %></td>
  <td class="px-5 py-4 text-gray-600"><%= transaction.recorded_by.display_name %></td>
  <td class="px-5 py-4">
    <div class="flex justify-end gap-2">
      <%= link_to admin_finance_transaction_path(transaction), class: action_button_classes(:secondary, size: :xs) do %>
        <%= icon_svg(:eye, classes: "h-3.5 w-3.5") %>
        <span>View</span>
      <% end %>
      <% if policy(transaction).update? %>
        <%= link_to edit_admin_finance_transaction_path(transaction), class: action_button_classes(:dark, size: :xs) do %>
          <%= icon_svg(:edit, classes: "h-3.5 w-3.5") %>
          <span>Edit</span>
        <% end %>
      <% end %>
    </div>
  </td>
</tr>
