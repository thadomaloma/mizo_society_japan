<% content_for :page_title, "Finance Transactions" %>

<div class="space-y-6">
  <% finance_actions = capture do %>
    <div class="flex flex-wrap gap-2">
      <%= link_to admin_finance_categories_path, class: action_button_classes(:secondary, size: :sm) do %>
        <%= icon_svg(:settings, classes: "h-4 w-4") %>
        <span>Categories</span>
      <% end %>
      <% if policy(FinanceTransaction).create? %>
        <%= link_to new_admin_finance_transaction_path, class: action_button_classes(:primary, size: :sm) do %>
          <%= icon_svg(:plus, classes: "h-4 w-4") %>
          <span>New Transaction</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Finance",
    title: "Finance Transactions",
    subtitle: "Track approved and pending income and expenses.",
    actions: finance_actions %>

  <% finance_stats = [
    { label: "Income", value: yen(@finance_summary[:income]), tone: "green", icon: :finance, caption: "Filtered total" },
    { label: "Expense", value: yen(@finance_summary[:expense]), tone: "red", icon: :finance, caption: "Filtered total" },
    { label: "Pending", value: @finance_summary[:pending], tone: "amber", icon: :notifications, caption: "Need review" }
  ] %>

  <%= render "shared/mobile_stats_panel", stats: finance_stats, title: "Finance Overview", subtitle: "Filtered transaction summary" %>

  <%= form_with url: admin_finance_transactions_path, method: :get, class: "grid gap-2 rounded-lg border border-[#E2E8F0] bg-white p-3 shadow-sm md:grid-cols-[minmax(16rem,1fr)_11rem_11rem_auto] dark:border-[#334155] dark:bg-[#1E293B]" do |form| %>
    <%= form.search_field :query, value: @query, placeholder: "Search description, reference, category...", class: "rounded-lg border border-[#CBD5E1] bg-white px-3 py-2 text-sm text-[#0F172A] outline-none placeholder:text-[#64748B] focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
    <%= form.select :transaction_type, options_for_select([ [ "All types", "" ] ] + FinanceTransaction.transaction_types.keys.map { |type| [ type.humanize, type ] }, @transaction_type), {}, class: "rounded-lg border border-[#CBD5E1] bg-white px-3 py-2 text-sm text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
    <%= form.select :status, options_for_select([ [ "All statuses", "" ] ] + FinanceTransaction.statuses.keys.map { |status| [ status.humanize, status ] }, @status), {}, class: "rounded-lg border border-[#CBD5E1] bg-white px-3 py-2 text-sm text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#475569] dark:bg-[#0F172A] dark:text-white" %>
    <div class="flex justify-end gap-2">
      <% if @query.present? || @transaction_type.present? || @status.present? %>
        <%= link_to admin_finance_transactions_path, class: action_button_classes(:secondary, size: :sm) do %>
          <%= icon_svg(:x_mark, classes: "h-4 w-4") %><span>Reset</span>
        <% end %>
      <% end %>
    <%= form.button type: :submit, class: action_button_classes(:dark) do %>
      <%= icon_svg(:filter, classes: "h-4 w-4") %>
      <span>Filter</span>
    <% end %>
    </div>
  <% end %>

  <% if @finance_transactions.any? %>
    <div class="hidden overflow-hidden rounded-lg border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B] lg:block">
      <table class="min-w-full divide-y divide-[#E2E8F0] text-left text-sm dark:divide-[#334155]">
        <thead class="bg-[#F8FAFC] text-xs font-black uppercase tracking-wide text-[#64748B] dark:bg-[#0F172A] dark:text-[#CBD5E1]">
          <tr>
            <th class="px-5 py-3">Date</th>
            <th class="px-5 py-3">Category</th>
            <th class="px-5 py-3">Type</th>
            <th class="px-5 py-3">Amount</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Recorded By</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#E2E8F0] bg-white dark:divide-[#334155] dark:bg-[#1E293B]">
          <%= render partial: "transaction_row", collection: @finance_transactions, as: :transaction %>
        </tbody>
      </table>
      <%= render "shared/data_table_footer", pagination: @pagination, label: "transactions" %>
    </div>

    <div class="grid gap-2 lg:hidden">
      <%= render partial: "transaction_card", collection: @finance_transactions, as: :transaction %>
      <div class="mt-1 overflow-hidden rounded-lg border border-[#E2E8F0] dark:border-[#334155]">
        <%= render "shared/data_table_footer", pagination: @pagination, label: "transactions" %>
      </div>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No finance transactions found", message: "Try changing the filters or add a new income or expense record." %>
  <% end %>
</div>
