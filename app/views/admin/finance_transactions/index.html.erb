<% content_for :page_title, "Finance Transactions" %>

<div class="space-y-6">
  <% finance_actions = capture do %>
    <div class="flex flex-wrap gap-2">
      <%= link_to admin_finance_categories_path, class: action_button_classes(:secondary, size: :sm) do %>
        <%= icon_svg(:settings, classes: "h-4 w-4") %>
        <span>Categories</span>
      <% end %>
      <% if policy(FinanceTransaction).create? %>
        <%= link_to new_admin_finance_transaction_path, class: action_button_classes(:primary, size: :sm) do %>
          <%= icon_svg(:plus, classes: "h-4 w-4") %>
          <span>New Transaction</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Finance",
    title: "Finance Transactions",
    subtitle: "Track approved and pending income and expenses.",
    actions: finance_actions %>

  <%= form_with url: admin_finance_transactions_path, method: :get, class: "grid gap-3 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm md:grid-cols-[1fr_12rem_12rem_auto]" do |form| %>
    <%= form.search_field :query, value: @query, placeholder: "Search description, reference, category...", class: "rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    <%= form.select :transaction_type, options_for_select([ [ "All types", "" ] ] + FinanceTransaction.transaction_types.keys.map { |type| [ type.humanize, type ] }, @transaction_type), {}, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    <%= form.select :status, options_for_select([ [ "All statuses", "" ] ] + FinanceTransaction.statuses.keys.map { |status| [ status.humanize, status ] }, @status), {}, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    <%= form.button type: :submit, class: action_button_classes(:dark) do %>
      <%= icon_svg(:filter, classes: "h-4 w-4") %>
      <span>Filter</span>
    <% end %>
  <% end %>

  <% if @finance_transactions.any? %>
    <div class="hidden overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm lg:block">
      <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
        <thead class="bg-gray-50 text-xs font-black uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-5 py-3">Date</th>
            <th class="px-5 py-3">Category</th>
            <th class="px-5 py-3">Type</th>
            <th class="px-5 py-3">Amount</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Recorded By</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 bg-white">
          <%= render partial: "transaction_row", collection: @finance_transactions, as: :transaction %>
        </tbody>
      </table>
    </div>

    <div class="grid gap-4 lg:hidden">
      <%= render partial: "transaction_card", collection: @finance_transactions, as: :transaction %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No finance transactions found", message: "Try changing the filters or add a new income or expense record." %>
  <% end %>
</div>
