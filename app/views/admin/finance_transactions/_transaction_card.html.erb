<article class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="font-black text-gray-950"><%= transaction.finance_category.name %></h3>
      <p class="mt-1 text-sm font-semibold text-gray-500"><%= transaction.transaction_date.strftime("%b %d, %Y") %></p>
    </div>
    <%= render "shared/status_badge", status: transaction.status %>
  </div>
  <div class="mt-5 flex items-end justify-between gap-4">
    <div>
      <p class="text-xs font-bold uppercase tracking-wide text-gray-400"><%= transaction.transaction_type.humanize %></p>
      <p class="mt-1 text-2xl font-black text-gray-950"><%= yen(transaction.amount) %></p>
    </div>
    <p class="text-sm font-semibold text-gray-500"><%= transaction.reference_number.presence || "No reference" %></p>
  </div>
  <div class="mt-5 grid gap-2 <%= policy(transaction).update? ? "grid-cols-2" : "grid-cols-1" %>">
    <%= link_to admin_finance_transaction_path(transaction), class: action_button_classes(:secondary, full_width: true) do %>
      <%= icon_svg(:eye, classes: "h-4 w-4") %>
      <span>View</span>
    <% end %>
    <% if policy(transaction).update? %>
      <%= link_to edit_admin_finance_transaction_path(transaction), class: action_button_classes(:dark, full_width: true) do %>
        <%= icon_svg(:edit, classes: "h-4 w-4") %>
        <span>Edit</span>
      <% end %>
    <% end %>
  </div>
</article>
