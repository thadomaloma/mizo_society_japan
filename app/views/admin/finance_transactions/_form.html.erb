<%= form_with model: [ :admin, finance_transaction ], class: "rounded-2xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6" do |form| %>
  <%= render "devise/shared/error_messages", resource: finance_transaction %>

  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <%= form.label :finance_category_id, "Category", class: "block text-sm font-bold text-gray-700" %>
      <%= form.select :finance_category_id, @finance_categories.map { |category| [ "#{category.name} (#{category.category_type.humanize})", category.id ] }, { prompt: "Select category" }, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div>
      <%= form.label :transaction_type, class: "block text-sm font-bold text-gray-700" %>
      <%= form.select :transaction_type, FinanceTransaction.transaction_types.keys.map { |type| [ type.humanize, type ] }, { prompt: "Select type" }, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div>
      <%= form.label :amount, class: "block text-sm font-bold text-gray-700" %>
      <%= form.number_field :amount, step: "0.01", min: 0, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div>
      <%= form.label :transaction_date, class: "block text-sm font-bold text-gray-700" %>
      <%= form.date_field :transaction_date, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div>
      <%= form.label :status, class: "block text-sm font-bold text-gray-700" %>
      <%= form.select :status, FinanceTransaction.statuses.keys.map { |status| [ status.humanize, status ] }, {}, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div>
      <%= form.label :reference_number, class: "block text-sm font-bold text-gray-700" %>
      <%= form.text_field :reference_number, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>

    <div class="md:col-span-2">
      <%= form.label :description, class: "block text-sm font-bold text-gray-700" %>
      <%= form.text_area :description, rows: 4, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-950 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100" %>
    </div>
  </div>

  <div class="mt-6 flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
    <%= link_to admin_finance_transactions_path, class: action_button_classes(:secondary) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Cancel</span>
    <% end %>
    <%= form.button type: :submit, class: action_button_classes(:primary) do %>
      <%= icon_svg(:save, classes: "h-4 w-4") %>
      <span><%= finance_transaction.persisted? ? "Update Transaction" : "Create Transaction" %></span>
    <% end %>
  </div>
<% end %>
