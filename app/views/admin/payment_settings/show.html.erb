<% content_for :page_title, "Bank Details" %>

<div class="mx-auto max-w-5xl space-y-6">
  <% header_actions = capture do %>
    <%= link_to admin_dashboard_path, class: action_button_classes(:secondary) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Dashboard</span>
    <% end %>
    <%= link_to admin_membership_payments_path, class: action_button_classes(:dark) do %>
      <%= icon_svg(:credit_card, classes: "h-4 w-4") %>
      <span>Payments</span>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Finance",
    title: "Bank Details",
    subtitle: "These details are shown to members when they pay by bank transfer.",
    actions: header_actions %>

  <% if @settings_errors.present? %>
    <section class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-800 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-100">
      <p class="font-black">Please correct the bank details below.</p>
      <ul class="mt-2 list-disc space-y-1 pl-5"><% @settings_errors.each do |error| %><li><%= error %></li><% end %></ul>
    </section>
  <% end %>

  <section class="grid gap-6 lg:grid-cols-[1fr_20rem]">
    <%= form_with url: admin_payment_settings_path, method: :patch, scope: :settings, class: "rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]" do |form| %>
      <div class="border-b border-[#E2E8F0] px-5 py-4 dark:border-[#334155]">
        <div class="flex items-center gap-3">
          <div class="grid h-10 w-10 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300">
            <%= icon_svg(:credit_card, classes: "h-5 w-5") %>
          </div>
          <div>
            <h3 class="text-base font-black text-[#0F172A] dark:text-[#F8FAFC]">Transfer Account</h3>
            <p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Member-facing bank transfer information.</p>
          </div>
        </div>
      </div>

      <div class="divide-y divide-[#E2E8F0] dark:divide-[#334155]">
        <% @bank_settings.each do |setting| %>
          <div class="grid gap-4 px-5 py-4 md:grid-cols-[1fr_20rem] md:items-center">
            <div>
              <%= form.label setting[:key], setting[:label], class: "text-sm font-black text-[#0F172A] dark:text-[#F8FAFC]" %>
              <p class="mt-1 text-xs font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1]"><%= setting[:description] %></p>
            </div>
            <%= form.text_field setting[:key],
              value: setting[:value],
              type: setting[:type],
              placeholder: setting[:placeholder],
              readonly: !policy(AppSetting).update_payment?,
              class: "block w-full rounded-xl border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none transition placeholder:text-[#64748B] focus:border-red-500 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#F8FAFC] dark:placeholder:text-[#CBD5E1]" %>
          </div>
        <% end %>
      </div>

      <div class="flex flex-col gap-2 border-t border-[#E2E8F0] p-4 dark:border-[#334155] sm:flex-row sm:justify-end">
        <%= link_to admin_dashboard_path, class: action_button_classes(:secondary) do %>
          <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
          <span>Cancel</span>
        <% end %>
        <% if policy(AppSetting).update_payment? %>
          <%= button_tag type: :submit, class: action_button_classes(:primary) do %>
            <%= icon_svg(:save, classes: "h-4 w-4") %>
            <span>Save Bank Details</span>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <aside class="space-y-4">
      <section class="rounded-2xl border border-amber-200 bg-amber-50 p-5 dark:border-amber-500/30 dark:bg-amber-500/10">
        <h3 class="text-sm font-black text-amber-800 dark:text-amber-200">Treasurer Note</h3>
        <p class="mt-2 text-sm font-semibold leading-6 text-amber-700 dark:text-amber-100">
          Members will see these details on their payment page before submitting transfer proof.
        </p>
      </section>

      <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
        <h3 class="text-sm font-black text-[#0F172A] dark:text-white">Member Flow</h3>
        <ol class="mt-4 space-y-3">
          <% [ "Member opens Payments", "Transfers from bank app", "Submits transfer details", "Treasurer verifies and approves" ].each_with_index do |step, index| %>
            <li class="flex gap-3">
              <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full bg-red-600 text-xs font-black text-white"><%= index + 1 %></span>
              <span class="pt-0.5 text-sm font-bold text-[#334155] dark:text-[#CBD5E1]"><%= step %></span>
            </li>
          <% end %>
        </ol>
      </section>
    </aside>
  </section>
</div>
