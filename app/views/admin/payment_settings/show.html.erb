<% content_for :page_title, "Bank Details" %>

<div class="mx-auto max-w-6xl space-y-4 sm:space-y-6">
  <% can_update_payment = policy(AppSetting).update_payment? %>
  <% bank_values = @bank_settings.index_by { |setting| setting[:key] } %>
  <% value_for = ->(key) { bank_values[key]&.dig(:value).presence || "Not set" } %>

  <% header_actions = capture do %>
    <div class="grid w-full grid-cols-2 gap-2 sm:flex sm:w-auto">
      <%= link_to admin_settings_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
        <span>Settings</span>
      <% end %>
      <%= link_to admin_membership_payments_path, class: action_button_classes(:dark, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
        <%= icon_svg(:credit_card, classes: "h-4 w-4") %>
        <span>Payments</span>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Finance",
    title: "Bank Details",
    subtitle: "Control the bank transfer information members see before submitting payment proof.",
    actions: header_actions %>

  <% if @settings_errors.present? %>
    <section class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-800 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-100">
      <p class="font-black">Please correct the bank details below.</p>
      <ul class="mt-2 list-disc space-y-1 pl-5"><% @settings_errors.each do |error| %><li><%= error %></li><% end %></ul>
    </section>
  <% end %>

  <section class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_24rem]">
    <%= form_with url: admin_payment_settings_path, method: :patch, scope: :settings, class: "rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800" do |form| %>
      <div class="border-b border-slate-100 bg-gradient-to-br from-slate-50 to-white px-4 py-4 dark:border-slate-700 dark:from-slate-900 dark:to-slate-800 sm:px-5">
        <div class="flex items-center gap-3">
          <div class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300">
            <%= icon_svg(:credit_card, classes: "h-5 w-5") %>
          </div>
          <div class="min-w-0">
            <h3 class="text-base font-black text-slate-950 dark:text-white">Transfer Account</h3>
            <p class="mt-0.5 text-xs font-semibold text-slate-500 dark:text-slate-400">Use the same wording members see on the payment page.</p>
          </div>
        </div>
      </div>

      <div class="divide-y divide-slate-100 dark:divide-slate-700">
        <% @bank_settings.each do |setting| %>
          <div class="grid gap-3 px-4 py-4 md:grid-cols-[minmax(0,1fr)_22rem] md:items-center sm:px-5">
            <div>
              <%= form.label setting[:key], setting[:label], class: "text-sm font-black text-slate-950 dark:text-white" %>
              <p class="mt-1 text-xs font-semibold leading-5 text-slate-500 dark:text-slate-400"><%= setting[:description] %></p>
            </div>
            <%= form.text_field setting[:key],
              value: setting[:value],
              type: setting[:type],
              placeholder: setting[:placeholder],
              readonly: !can_update_payment,
              class: "block w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm font-semibold text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-red-500 focus:bg-white focus:ring-2 focus:ring-red-100 disabled:cursor-not-allowed disabled:opacity-70 dark:border-slate-600 dark:bg-slate-900 dark:text-white dark:placeholder:text-slate-500 dark:focus:bg-slate-900" %>
          </div>
        <% end %>
      </div>

      <div class="sticky bottom-20 grid <%= can_update_payment ? "grid-cols-2" : "grid-cols-1" %> gap-2 border-t border-slate-100 bg-white/95 p-3 shadow-lg shadow-slate-950/10 backdrop-blur dark:border-slate-700 dark:bg-slate-800/95 sm:flex sm:justify-end lg:bottom-4">
        <%= link_to admin_settings_path, class: action_button_classes(:secondary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
          <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
          <span>Cancel</span>
        <% end %>
        <% if can_update_payment %>
          <%= button_tag type: :submit, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "px-2 sm:w-auto sm:px-3") do %>
            <%= icon_svg(:save, classes: "h-4 w-4") %>
            <span>Save Bank Details</span>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <aside class="space-y-4">
      <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:p-5">
        <div class="flex items-center gap-3">
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300">
            <%= icon_svg(:eye, classes: "h-5 w-5") %>
          </span>
          <div>
            <h3 class="text-base font-black text-slate-950 dark:text-white">Member Preview</h3>
            <p class="mt-0.5 text-xs font-semibold text-slate-500 dark:text-slate-400">This is the structure shown on the payment page.</p>
          </div>
        </div>

        <div class="mt-4 space-y-3">
          <div class="rounded-2xl border border-sky-100 bg-gradient-to-br from-sky-50 to-white p-3 shadow-sm shadow-sky-950/5 dark:border-sky-400/20 dark:from-sky-500/10 dark:to-slate-900">
            <p class="inline-flex rounded-full bg-yellow-100 px-2.5 py-1 text-xs font-black uppercase tracking-wide text-yellow-900 ring-1 ring-yellow-200 dark:bg-yellow-400/15 dark:text-yellow-100 dark:ring-yellow-300/20">From another bank</p>
            <dl class="mt-3 grid gap-2 text-sm">
              <% [
                [ "Bank", value_for.call("bank_name") ],
                [ "Store Name<br><span class=\"text-inherit normal-case tracking-normal\">店名</span>".html_safe, value_for.call("bank_branch_name") ],
                [ "Account Number<br><span class=\"text-inherit normal-case tracking-normal\">口座番号</span>".html_safe, value_for.call("bank_account_number") ],
                [ "Account Name", value_for.call("bank_account_name") ]
              ].each do |label, value| %>
                <% copyable = label.to_s.include?("Store Name") || label.to_s.include?("Account Number") %>
                <% copy_title = strip_tags(label.to_s).squish %>
                <div class="flex items-start justify-between gap-3 rounded-xl bg-white/90 px-3 py-2 ring-1 ring-sky-100/70 dark:bg-slate-800/85 dark:ring-sky-400/10">
                  <dt class="w-24 shrink-0 text-xs font-black uppercase tracking-wide text-slate-400 dark:text-slate-500"><%= label %></dt>
                  <dd class="flex min-w-0 flex-1 items-start justify-end gap-2">
                    <span class="min-w-0 break-all text-right font-black text-slate-950 dark:text-white"><%= value %></span>
                    <% if copyable && value != "Not set" %>
                      <button type="button" class="inline-flex h-8 shrink-0 items-center gap-1 rounded-lg border border-slate-200 bg-white px-2 text-[11px] font-black text-slate-500 transition hover:border-red-200 hover:text-red-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:text-red-300" data-controller="clipboard" data-clipboard-text-value="<%= value %>" data-action="clipboard#copy" title="Copy <%= copy_title %>">
                        <%= icon_svg(:copy, classes: "h-3.5 w-3.5") %>
                        <span data-clipboard-target="label">Copy</span>
                      </button>
                    <% end %>
                  </dd>
                </div>
              <% end %>
            </dl>
          </div>

          <div class="rounded-2xl border border-red-100 bg-gradient-to-br from-red-50 to-white p-3 shadow-sm shadow-red-950/5 dark:border-red-400/20 dark:from-red-500/10 dark:to-slate-900">
            <p class="inline-flex rounded-full bg-yellow-100 px-2.5 py-1 text-xs font-black uppercase tracking-wide text-yellow-900 ring-1 ring-yellow-200 dark:bg-yellow-400/15 dark:text-yellow-100 dark:ring-yellow-300/20">From ゆうちょ銀行</p>
            <div class="mt-3 space-y-2">
              <% [
                [ "Yuucho Symbol<br><span class=\"text-inherit normal-case tracking-normal\">記号</span>".html_safe, value_for.call("yucho_symbol") ],
                [ "Yuucho Number<br><span class=\"text-inherit normal-case tracking-normal\">番号</span>".html_safe, value_for.call("yucho_number") ]
              ].each do |label, value| %>
                <% copy_title = strip_tags(label.to_s).squish %>
                <div class="flex items-start justify-between gap-3 rounded-xl bg-white/90 px-3 py-2 ring-1 ring-red-100/70 dark:bg-slate-800/85 dark:ring-red-400/10">
                  <p class="w-24 shrink-0 text-xs font-black uppercase tracking-wide text-slate-400 dark:text-slate-500"><%= label %></p>
                  <div class="flex min-w-0 flex-1 items-start justify-end gap-2">
                    <p class="min-w-0 break-all text-right text-sm font-black text-slate-950 dark:text-white"><%= value %></p>
                    <% if value != "Not set" %>
                      <button type="button" class="inline-flex h-8 shrink-0 items-center gap-1 rounded-lg border border-slate-200 bg-white px-2 text-[11px] font-black text-slate-500 transition hover:border-red-200 hover:text-red-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:text-red-300" data-controller="clipboard" data-clipboard-text-value="<%= value %>" data-action="clipboard#copy" title="Copy <%= copy_title %>">
                        <%= icon_svg(:copy, classes: "h-3.5 w-3.5") %>
                        <span data-clipboard-target="label">Copy</span>
                      </button>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </section>

    </aside>
  </section>
</div>
