<% content_for :page_title, @finance_category.name %>

<div class="space-y-6">
  <% page_actions = capture do %>
    <%= link_to admin_finance_categories_path, class: action_button_classes(:secondary) do %><%= icon_svg(:arrow_left, classes: "h-4 w-4") %><span>Back</span><% end %>
    <% if policy(@finance_category).update? %>
      <%= link_to edit_admin_finance_category_path(@finance_category), class: action_button_classes(:primary) do %><%= icon_svg(:edit, classes: "h-4 w-4") %><span>Edit</span><% end %>
    <% end %>
    <% if policy(@finance_category).destroy? %>
      <% category_in_use = @finance_category.finance_transactions.exists? %>
      <%= button_to admin_finance_category_path(@finance_category), method: :delete, data: { turbo_confirm: "Delete #{@finance_category.name}? This cannot be undone." }, disabled: category_in_use, class: action_button_classes(:outline_danger), title: (category_in_use ? "This category is used by finance transactions and cannot be deleted" : "Delete category") do %><%= icon_svg(:trash, classes: "h-4 w-4") %><span>Delete</span><% end %>
    <% end %>
  <% end %>
  <%= render "shared/page_header", eyebrow: "Finance category", title: @finance_category.name, subtitle: @finance_category.category_type.humanize, actions: page_actions %>

  <section class="rounded-2xl border border-[#E2E8F0] bg-white p-6 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Type</p>
        <p class="mt-2"><%= render "shared/status_badge", status: @finance_category.category_type %></p>
      </div>
      <div>
        <p class="text-sm font-bold text-[#64748B] dark:text-[#CBD5E1]">Status</p>
        <p class="mt-2"><%= render "shared/status_badge", status: @finance_category.active? ? "active" : "inactive" %></p>
      </div>
    </div>
  </section>
</div>
