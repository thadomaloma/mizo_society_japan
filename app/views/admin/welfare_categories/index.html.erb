<% content_for :page_title, "Welfare Categories" %>

<div class="space-y-6">
  <% page_actions = capture do %>
    <%= link_to admin_welfare_cases_path, class: action_button_classes(:secondary, size: :sm) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Welfare Cases</span>
    <% end %>
    <%= link_to new_admin_welfare_category_path, class: action_button_classes(:primary, size: :sm) do %>
      <%= icon_svg(:plus, classes: "h-4 w-4") %>
      <span>New Category</span>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: "Confidential welfare",
    title: "Welfare Categories",
    subtitle: "Manage the category choices used when creating welfare cases.",
    actions: page_actions %>

  <% if @welfare_categories.any? %>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      <% @welfare_categories.each do |category| %>
        <% category_in_use = category.welfare_cases.any? %>
        <article class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm transition hover:border-slate-300 hover:shadow-md dark:border-[#334155] dark:bg-[#1E293B] dark:hover:border-[#475569]">
          <div class="flex items-start justify-between gap-3">
            <div class="flex min-w-0 items-center gap-3">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300"><%= icon_svg(:welfare, classes: "h-5 w-5") %></span>
              <div class="min-w-0">
                <h2 class="truncate text-base font-black text-[#0F172A] dark:text-white"><%= category.name %></h2>
                <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">
                  <%= category_in_use ? "Used by #{pluralize(category.welfare_cases.size, "case")}" : "Ready to use" %>
                </p>
              </div>
            </div>

            <div class="flex shrink-0 items-center gap-1.5">
              <%= render "shared/status_badge", status: category.active? ? "active" : "inactive" %>
              <%= link_to edit_admin_welfare_category_path(category), class: action_button_classes(:secondary, size: :xs, extra: "h-8 w-8 px-0"), title: "Edit #{category.name}", aria: { label: "Edit #{category.name}" } do %>
                <%= icon_svg(:edit, classes: "h-3.5 w-3.5") %>
              <% end %>
              <% if category_in_use %>
                <span class="inline-flex h-8 w-8 shrink-0 cursor-not-allowed items-center justify-center rounded-md border border-slate-200 bg-slate-50 text-slate-400 dark:border-[#334155] dark:bg-[#0F172A] dark:text-slate-500" title="This category is used by welfare cases and cannot be deleted." aria-label="Cannot delete <%= category.name %> because welfare cases exist">
                  <%= icon_svg(:trash, classes: "h-3.5 w-3.5") %>
                </span>
              <% else %>
                <%= button_to admin_welfare_category_path(category), method: :delete, data: { turbo_confirm: "Delete #{category.name}? This cannot be undone." }, class: action_button_classes(:outline_danger, size: :xs, extra: "h-8 w-8 px-0"), form: { class: "inline-flex" }, title: "Delete #{category.name}", aria: { label: "Delete #{category.name}" } do %>
                  <%= icon_svg(:trash, classes: "h-3.5 w-3.5") %>
                <% end %>
              <% end %>
            </div>
          </div>

          <p class="mt-4 min-h-12 text-sm leading-6 text-[#64748B] dark:text-[#CBD5E1]"><%= category.description.presence || "No description provided." %></p>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state",
      title: "No welfare categories found",
      message: "Create categories before adding welfare cases.",
      action: link_to(new_admin_welfare_category_path, class: action_button_classes(:primary)) do
        safe_join([ icon_svg(:plus, classes: "h-4 w-4"), tag.span("Add Category") ])
      end %>
  <% end %>
</div>
