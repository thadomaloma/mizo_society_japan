<% content_for :page_title, "Payments" %>

<div class="space-y-4 sm:space-y-5">
  <% payable_payments = @current_payments.select { |payment| policy(payment).submit_transfer? } %>
  <% batch_due = @current_payment_batches.select { |batch| batch.pending? || batch.rejected? }.sum(&:total_amount) %>
  <% amount_due = payable_payments.sum(&:amount) + batch_due %>
  <% pending_action_count = payable_payments.count %>
  <% verification_count = @current_payments.count(&:pending_verification?) + @current_payment_batches.count(&:pending_verification?) %>

  <div class="hidden sm:block">
    <%= render "shared/page_header",
      eyebrow: "Member finance",
      title: "Payments",
      subtitle: "Track dues, pay together by bank transfer, and keep your payment history in one place." %>
  </div>

  <section class="sm:hidden">
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="text-[11px] font-black uppercase tracking-wide text-red-700 dark:text-red-300">Member finance</p>
          <h1 class="mt-0.5 text-xl font-black leading-6 text-[#0F172A] dark:text-white">Payments</h1>
          <p class="mt-1 text-xs font-semibold leading-4 text-[#64748B] dark:text-[#CBD5E1]">Check what is due and pay from here.</p>
        </div>
        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300">
          <%= icon_svg(:credit_card, classes: "h-5 w-5") %>
        </span>
      </div>

      <div class="mt-3 grid grid-cols-[1fr_auto] items-center gap-3 rounded-xl border <%= amount_due.positive? ? "border-red-100 bg-red-50 dark:border-red-500/20 dark:bg-red-500/10" : "border-emerald-100 bg-emerald-50 dark:border-emerald-500/20 dark:bg-emerald-500/10" %> px-3 py-2.5">
        <div class="min-w-0">
          <p class="text-[10px] font-black uppercase tracking-wide <%= amount_due.positive? ? "text-red-700 dark:text-red-300" : "text-emerald-700 dark:text-emerald-300" %>">Amount due</p>
          <p class="mt-0.5 truncate text-2xl font-black tabular-nums text-[#0F172A] dark:text-white"><%= yen(amount_due) %></p>
        </div>
        <div class="grid grid-cols-2 overflow-hidden rounded-lg border border-white/70 bg-white/80 text-center shadow-sm dark:border-white/10 dark:bg-[#0F172A]/70">
          <div class="px-2 py-1.5">
            <p class="text-[9px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">To pay</p>
            <p class="text-sm font-black text-[#0F172A] dark:text-white"><%= pending_action_count %></p>
          </div>
          <div class="border-l border-[#E2E8F0] px-2 py-1.5 dark:border-[#334155]">
            <p class="text-[9px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Review</p>
            <p class="text-sm font-black text-[#0F172A] dark:text-white"><%= verification_count %></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="hidden min-w-0 gap-3 sm:grid lg:grid-cols-[1fr_24rem]">
    <article class="overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="border-b border-[#E2E8F0] px-4 py-3 dark:border-[#334155] sm:px-5 sm:py-4">
        <div class="flex items-center justify-between gap-3">
          <div class="min-w-0">
            <h2 class="truncate text-base font-black text-[#0F172A] dark:text-white">Payment Summary</h2>
            <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Your current balance and payment status.</p>
          </div>
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300">
            <%= icon_svg(:credit_card, classes: "h-5 w-5") %>
          </span>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-2 p-3 sm:grid-cols-4 sm:p-5">
        <div class="col-span-2 rounded-xl border border-red-100 bg-red-50 p-3 dark:border-red-500/20 dark:bg-red-500/10 sm:col-span-1">
          <p class="text-[11px] font-black uppercase tracking-wide text-red-700 dark:text-red-300">Amount Due</p>
          <p class="mt-1 truncate text-2xl font-black text-[#0F172A] dark:text-white"><%= yen(amount_due) %></p>
        </div>
        <div class="rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
          <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Due Now</p>
          <p class="mt-1 text-xl font-black text-[#0F172A] dark:text-white"><%= pending_action_count %></p>
        </div>
        <div class="rounded-xl border border-amber-100 bg-amber-50 p-3 dark:border-amber-500/20 dark:bg-amber-500/10">
          <p class="text-[11px] font-black uppercase tracking-wide text-amber-700 dark:text-amber-300">To Verify</p>
          <p class="mt-1 text-xl font-black text-[#0F172A] dark:text-white"><%= verification_count %></p>
        </div>
        <div class="rounded-xl border border-emerald-100 bg-emerald-50 p-3 dark:border-emerald-500/20 dark:bg-emerald-500/10">
          <p class="text-[11px] font-black uppercase tracking-wide text-emerald-700 dark:text-emerald-300">History</p>
          <p class="mt-1 text-xl font-black text-[#0F172A] dark:text-white"><%= @payment_history.count %></p>
        </div>
      </div>
    </article>

    <article class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <h2 class="text-base font-black text-[#0F172A] dark:text-white">How to pay</h2>
      <div class="mt-3 space-y-3">
        <% [
          [ "Pay Together", "Select multiple fees and transfer once to save bank fees." ],
          [ "Submit details", "Send one transfer date, total amount, and reference name." ],
          [ "Verification", "Treasurer confirms the transfer and marks it paid." ]
        ].each_with_index do |(label, text), index| %>
          <div class="flex gap-3">
            <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full bg-[#0F172A] text-xs font-black text-white dark:bg-[#334155]"><%= index + 1 %></span>
            <p class="text-sm font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1]"><span class="font-black text-[#0F172A] dark:text-white"><%= label %>:</span> <%= text %></p>
          </div>
        <% end %>
      </div>
    </article>
  </section>

  <% if payable_payments.any? %>
    <section class="overflow-hidden rounded-2xl border border-red-100 bg-white shadow-sm dark:border-red-500/20 dark:bg-[#1E293B]">
      <div class="border-b border-red-100 bg-red-50/70 px-3 py-3 dark:border-red-500/20 dark:bg-red-500/10 sm:px-4">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div class="min-w-0">
            <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">Recommended</p>
            <h2 class="mt-0.5 text-[17px] font-black leading-6 text-[#0F172A] dark:text-white sm:text-base">Select Payments</h2>
            <p class="mt-1 text-xs font-semibold leading-5 text-red-800 dark:text-red-100/80">Choose one or more fees/funds, then transfer the selected total once.</p>
          </div>
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-white text-red-700 shadow-sm dark:bg-[#1E293B] dark:text-red-300"><%= icon_svg(:credit_card, classes: "h-5 w-5") %></span>
        </div>
      </div>

      <%= form_with url: payment_batches_path, method: :post, class: "space-y-3 p-3 sm:p-4", data: { controller: "payment-selection" } do %>
        <div class="overflow-hidden rounded-xl border border-red-100 bg-white dark:border-red-500/20 dark:bg-[#0F172A]">
          <% payable_payments.each do |payment| %>
            <label data-payment-selection-row class="group flex cursor-pointer items-center gap-3 border-b border-red-50 px-3 py-3 transition last:border-b-0 hover:bg-red-50/60 dark:border-red-500/10 dark:hover:bg-red-500/10 sm:px-4">
              <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 ring-1 ring-red-100 transition group-has-[:checked]:bg-red-600 group-has-[:checked]:text-white dark:bg-red-500/10 dark:text-red-300 dark:ring-red-500/20 dark:group-has-[:checked]:bg-red-600">
                <%= check_box_tag "membership_payment_ids[]", payment.id, false,
                  class: "h-4 w-4 rounded border-red-200 text-red-600 focus:ring-2 focus:ring-red-600 focus:ring-offset-1 dark:border-red-500/40 dark:bg-[#1E293B]",
                  data: { payment_selection_target: "checkbox", action: "change->payment-selection#update input->payment-selection#update", amount: payment.amount.to_i } %>
              </span>
              <span class="min-w-0 flex-1">
                <span class="block truncate text-sm font-black text-[#0F172A] dark:text-white"><%= payment.membership_plan.name %></span>
                <span class="mt-0.5 block truncate text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= payment.plan_type_label %> · <%= payment.period_label %></span>
              </span>
              <span class="shrink-0 text-right">
                <span class="block text-sm font-black text-[#0F172A] dark:text-white"><%= yen(payment.amount) %></span>
                <span class="mt-0.5 block text-[10px] font-black uppercase tracking-wide text-red-700 opacity-0 transition group-has-[:checked]:opacity-100 dark:text-red-300">Selected</span>
              </span>
            </label>
          <% end %>
        </div>

        <div class="hidden flex-col gap-2 rounded-xl border border-red-100 bg-white px-3 py-3 dark:border-red-500/20 dark:bg-[#1E293B] sm:flex sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">
              <span data-payment-selection-target="count">0</span> selected ·
              <span class="font-black text-[#0F172A] dark:text-white" data-payment-selection-target="total"><%= yen(0) %></span>
            </p>
            <p class="mt-1 text-xs font-semibold text-amber-700 dark:text-amber-300" data-payment-selection-target="emptyHint">Select at least one payment.</p>
          </div>
          <%= button_tag type: :submit, class: action_button_classes(:primary, size: :sm, full_width: true, extra: "sm:w-auto"), data: { payment_selection_target: "submit" } do %>
            <%= icon_svg(:credit_card, classes: "h-4 w-4") %>
            <span>Pay Selected Together</span>
          <% end %>
        </div>

        <div class="fixed inset-x-3 bottom-[calc(env(safe-area-inset-bottom)+4.85rem)] z-30 rounded-2xl border border-red-100 bg-white/95 p-2.5 shadow-[0_16px_40px_rgba(15,23,42,0.18)] backdrop-blur-xl dark:border-red-500/20 dark:bg-[#1E293B]/95 sm:hidden">
          <div class="grid grid-cols-[1fr_auto] items-center gap-2">
            <div class="min-w-0">
              <p class="text-[10px] font-black uppercase tracking-wide text-red-700 dark:text-red-300">
                <span data-payment-selection-target="count">0</span> selected
              </p>
              <p class="mt-0.5 truncate text-lg font-black text-[#0F172A] dark:text-white" data-payment-selection-target="total"><%= yen(0) %></p>
              <p class="mt-0.5 text-[10px] font-bold text-amber-700 dark:text-amber-300" data-payment-selection-target="emptyHint">Select payment first.</p>
            </div>
            <%= button_tag type: :submit, class: action_button_classes(:primary, size: :xs, extra: "px-3 py-2"), data: { payment_selection_target: "submit" } do %>
              <%= icon_svg(:credit_card, classes: "h-4 w-4") %>
              <span>Pay Together</span>
            <% end %>
          </div>
        </div>

        <div class="h-20 sm:hidden" aria-hidden="true"></div>
      <% end %>
    </section>
  <% elsif @current_payment_batches.empty? %>
    <section class="rounded-2xl border border-emerald-100 bg-emerald-50 p-4 text-sm font-semibold text-emerald-800 dark:border-emerald-500/20 dark:bg-emerald-500/10 dark:text-emerald-100">
      <div class="flex gap-3">
        <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-white text-emerald-700 shadow-sm dark:bg-[#1E293B] dark:text-emerald-300"><%= icon_svg(:check, classes: "h-4 w-4") %></span>
        <div>
          <p class="font-black">No payment due right now.</p>
          <p class="mt-1 leading-6">New required fees will appear here automatically.</p>
        </div>
      </div>
    </section>
  <% end %>

  <% if @current_payment_batches.any? %>
    <section class="rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="border-b border-[#E2E8F0] px-3 py-2.5 dark:border-[#334155] sm:px-4 sm:py-3">
        <h2 class="text-[17px] font-black leading-6 text-[#0F172A] dark:text-white sm:text-base">Submitted Combined Payments</h2>
        <p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1] sm:mt-1">Payment groups submitted or prepared for one bank transfer.</p>
      </div>
      <div class="grid gap-2 p-2 sm:gap-3 sm:p-4 lg:grid-cols-2">
        <%= render partial: "payment_batch_card", collection: @current_payment_batches, as: :payment_batch %>
      </div>
    </section>
  <% end %>
  <% if @available_payment_plans.any? %>
    <section class="rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="border-b border-[#E2E8F0] px-3 py-2.5 dark:border-[#334155] sm:px-4 sm:py-3">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-[17px] font-black leading-6 text-[#0F172A] dark:text-white sm:text-base">Optional Payment Plans</h2>
          <p class="hidden text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1] sm:block">Voluntary donations, fundraisers, and other active society fees.</p>
        </div>
      </div>

      <div class="grid gap-2 p-2 sm:gap-3 sm:p-4 md:grid-cols-2 xl:grid-cols-3">
        <% @available_payment_plans.each do |plan| %>
          <article class="flex h-full flex-col rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 transition hover:border-red-200 hover:bg-red-50/40 dark:border-[#334155] dark:bg-[#0F172A] dark:hover:bg-[#334155] sm:p-4">
            <div class="flex items-start gap-3">
              <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300 sm:h-9 sm:w-9"><%= icon_svg(:credit_card, classes: "h-4 w-4") %></span>
              <div class="min-w-0 flex-1">
                <h3 class="line-clamp-1 text-[15px] font-black leading-5 text-[#0F172A] dark:text-white sm:line-clamp-2 sm:text-sm"><%= plan.name %></h3>
                <div class="mt-1 flex flex-wrap items-center gap-2 sm:mt-1.5">
                  <span class="rounded-md bg-white px-2 py-0.5 text-[10px] font-black text-red-700 ring-1 ring-red-100 dark:bg-red-500/10 dark:text-red-300 dark:ring-red-500/20"><%= plan.plan_type_label %></span>
                </div>
                <p class="mt-1.5 line-clamp-1 text-[12px] font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1] sm:mt-2 sm:line-clamp-2 sm:text-xs"><%= plan.description.presence || "Support this MSJ payment plan." %></p>
              </div>
            </div>
            <div class="mt-2.5 flex items-center justify-between gap-3 border-t border-[#E2E8F0] pt-2.5 dark:border-[#334155] sm:mt-4 sm:pt-3">
              <p class="text-base font-black text-[#0F172A] dark:text-white sm:text-lg"><%= yen(plan.amount) %></p>
              <%= button_to start_membership_payments_path, method: :post, params: { membership_plan_id: plan.id }, class: action_button_classes(:primary, size: :xs, extra: "px-2.5 py-1.5") do %>
                <%= icon_svg(:plus, classes: "h-3.5 w-3.5") %><span>Add</span>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="border-b border-[#E2E8F0] px-3 py-2.5 dark:border-[#334155] sm:px-4 sm:py-3">
      <h2 class="text-[17px] font-black leading-6 text-[#0F172A] dark:text-white sm:text-base">Payment History</h2>
      <p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1] sm:mt-1">Paid, cancelled, and refunded records.</p>
    </div>

    <div class="p-3 sm:p-4">
      <%= form_with url: membership_payments_path, method: :get, class: "grid gap-2 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-2 dark:border-[#334155] dark:bg-[#0F172A] sm:gap-3 sm:p-3 sm:grid-cols-[1fr_1fr_auto]" do |form| %>
        <%= form.select :status, options_for_select([ [ "All history statuses", "" ] ] + @history_status_options.map { |status| [ status.humanize, status ] }, @status), {}, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#1E293B] dark:text-white" %>
        <%= form.select :year, options_for_select([ [ "All years", "" ] ] + @years.map { |year| [ year, year ] }, @year), {}, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#1E293B] dark:text-white" %>
        <%= form.button type: :submit, class: action_button_classes(:dark, full_width: true) do %><%= icon_svg(:filter, classes: "h-4 w-4") %><span>Filter</span><% end %>
      <% end %>

      <% if @payment_history.any? %>
        <div class="mt-3 grid gap-3">
          <%= render partial: "payment_card", collection: @payment_history, as: :payment %>
        </div>
      <% elsif @available_payment_plans.empty? && @current_payments.empty? %>
        <div class="mt-3"><%= render "shared/empty_state", title: "No payments available", message: "There are no active payment plans or payment records at the moment." %></div>
      <% else %>
        <div class="mt-3 rounded-xl border border-dashed border-[#CBD5E1] bg-[#F8FAFC] p-4 text-sm font-semibold text-[#64748B] dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1]">
          No payment history yet.
        </div>
      <% end %>
    </div>
  </section>
</div>
