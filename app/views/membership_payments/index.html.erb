<% content_for :page_title, "Payments" %>

<div class="space-y-5">
  <%= render "shared/page_header",
    eyebrow: "Member finance",
    title: "Payments",
    subtitle: "Track dues, pay online or by bank transfer, and keep your payment history in one place." %>

  <section class="grid gap-3 sm:grid-cols-3">
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1] sm:text-xs">Due Now</p>
      <p class="mt-2 text-2xl font-black text-[#0F172A] dark:text-white"><%= @current_payments.count %></p>
    </div>
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1] sm:text-xs">Amount Due</p>
      <p class="mt-2 text-2xl font-black text-[#0F172A] dark:text-white"><%= yen(@current_payments.sum(&:amount)) %></p>
    </div>
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-4 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1] sm:text-xs">History</p>
      <p class="mt-2 text-2xl font-black text-[#0F172A] dark:text-white"><%= @payment_history.count %></p>
    </div>
  </section>

  <section class="rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="border-b border-[#E2E8F0] px-4 py-3 dark:border-[#334155]">
      <div>
        <h2 class="text-[17px] font-black leading-6 text-[#0F172A] dark:text-white sm:text-base">Current Payments</h2>
        <p class="mt-1 text-xs font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1]">Unpaid payments and transfers waiting for verification.</p>
      </div>
    </div>

    <% if @current_payments.any? %>
      <div class="grid gap-0 divide-y divide-[#E2E8F0] p-3 dark:divide-[#334155] sm:gap-3 sm:divide-y-0 sm:p-4">
        <%= render partial: "payment_card", collection: @current_payments, as: :payment, locals: { embedded: true } %>
      </div>
    <% else %>
      <div class="p-4 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">
        No unpaid payments.
      </div>
    <% end %>
  </section>

  <% if @available_payment_plans.any? %>
    <section class="rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
      <div class="border-b border-[#E2E8F0] px-4 py-3 dark:border-[#334155]">
        <div>
          <h2 class="text-[17px] font-black leading-6 text-[#0F172A] dark:text-white sm:text-base">Optional Payment Plans</h2>
          <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Donation, fundraiser, or other active society fund.</p>
        </div>
      </div>

      <div class="grid gap-3 p-3 sm:p-4 md:grid-cols-2 xl:grid-cols-3">
        <% @available_payment_plans.each do |plan| %>
          <article class="flex h-full flex-col rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3.5 transition hover:border-red-200 hover:bg-red-50/40 dark:border-[#334155] dark:bg-[#0F172A] dark:hover:bg-[#334155] sm:p-4">
            <div class="flex items-start gap-3">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300"><%= icon_svg(:credit_card, classes: "h-4 w-4") %></span>
              <div class="min-w-0 flex-1">
                <h3 class="line-clamp-1 text-[15px] font-black leading-5 text-[#0F172A] dark:text-white sm:line-clamp-2 sm:text-sm"><%= plan.name %></h3>
                <div class="mt-1.5 flex flex-wrap items-center gap-2">
                  <span class="rounded-md bg-white px-2 py-0.5 text-[10px] font-black text-red-700 ring-1 ring-red-100 dark:bg-red-500/10 dark:text-red-300 dark:ring-red-500/20"><%= plan.plan_type_label %></span>
                </div>
                <p class="mt-2 line-clamp-1 text-[13px] font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1] sm:line-clamp-2 sm:text-xs"><%= plan.description.presence || "Support this MSJ payment plan." %></p>
              </div>
            </div>
            <div class="mt-3 flex items-center justify-between gap-3 border-t border-[#E2E8F0] pt-3 dark:border-[#334155] sm:mt-4">
              <p class="text-lg font-black text-[#0F172A] dark:text-white"><%= yen(plan.amount) %></p>
              <%= button_to start_membership_payments_path, method: :post, params: { membership_plan_id: plan.id }, class: action_button_classes(:primary, size: :xs) do %>
                <%= icon_svg(:plus, classes: "h-3.5 w-3.5") %><span>Start</span>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="rounded-2xl border border-[#E2E8F0] bg-white shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
    <div class="border-b border-[#E2E8F0] px-4 py-3 dark:border-[#334155]">
      <h2 class="text-[17px] font-black leading-6 text-[#0F172A] dark:text-white sm:text-base">Payment History</h2>
      <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Paid, cancelled, and refunded records.</p>
    </div>

    <div class="p-4">
      <%= form_with url: membership_payments_path, method: :get, class: "grid gap-3 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A] sm:grid-cols-[1fr_1fr_auto]" do |form| %>
        <%= form.select :status, options_for_select([ [ "All history statuses", "" ] ] + @history_status_options.map { |status| [ status.humanize, status ] }, @status), {}, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#1E293B] dark:text-white" %>
        <%= form.select :year, options_for_select([ [ "All years", "" ] ] + @years.map { |year| [ year, year ] }, @year), {}, class: "rounded-lg border border-[#E2E8F0] bg-white px-3 py-2 text-sm font-semibold text-[#0F172A] outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#1E293B] dark:text-white" %>
        <%= form.button type: :submit, class: action_button_classes(:dark, full_width: true) do %><%= icon_svg(:filter, classes: "h-4 w-4") %><span>Filter</span><% end %>
      <% end %>

      <% if @payment_history.any? %>
        <div class="mt-3 grid gap-3">
          <%= render partial: "payment_card", collection: @payment_history, as: :payment %>
        </div>
      <% elsif @available_payment_plans.empty? && @current_payments.empty? %>
        <div class="mt-3"><%= render "shared/empty_state", title: "No payments available", message: "There are no active payment plans or payment records at the moment." %></div>
      <% else %>
        <div class="mt-3 rounded-xl border border-dashed border-[#CBD5E1] bg-[#F8FAFC] p-4 text-sm font-semibold text-[#64748B] dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1]">
          No payment history yet.
        </div>
      <% end %>
    </div>
  </section>
</div>
