<% content_for :page_title, "Payment Submitted" %>

<div class="mx-auto max-w-3xl space-y-6">
  <%= render "shared/page_header",
    eyebrow: "Online payment",
    title: "Payment submitted",
    subtitle: "Stripe is confirming your card or wallet payment. This page updates after the payment webhook is received." %>

  <section class="rounded-2xl border border-emerald-200 bg-emerald-50 p-5 dark:border-emerald-500/30 dark:bg-emerald-500/10">
    <div class="flex items-start gap-3">
      <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-emerald-600 text-white"><%= icon_svg(:check, classes: "h-5 w-5") %></span>
      <div>
        <p class="font-black text-emerald-900 dark:text-emerald-100">Thank you. Your payment is being confirmed.</p>
        <p class="mt-1 text-sm font-semibold leading-6 text-emerald-700 dark:text-emerald-100">
          Card and wallet payments are marked paid automatically after Stripe confirms the payment.
        </p>
      </div>
    </div>
  </section>

  <div class="flex flex-row flex-wrap gap-2">
    <%= link_to membership_payment_path(@membership_payment), class: action_button_classes(:primary, size: :sm, extra: "px-2 sm:px-3") do %>
      <%= icon_svg(:eye, classes: "h-4 w-4") %>
      <span>View Payment</span>
    <% end %>
    <%= link_to membership_payments_path, class: action_button_classes(:secondary, size: :sm, extra: "px-2 sm:px-3") do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Back to Payments</span>
    <% end %>
  </div>
</div>
