<% content_for :page_title, "Payment Detail" %>

<div class="space-y-6">
  <% payment_actions = capture do %>
    <%= link_to membership_payments_path, class: action_button_classes(:secondary) do %>
      <%= icon_svg(:arrow_left, classes: "h-4 w-4") %>
      <span>Back</span>
    <% end %>
  <% end %>

  <%= render "shared/page_header",
    eyebrow: @membership_payment.plan_type_label,
    title: @membership_payment.membership_plan.name,
    actions: payment_actions %>

  <section class="grid gap-5">
    <div class="space-y-5">
      <section class="rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm dark:border-[#334155] dark:bg-[#1E293B] sm:p-5">
        <div class="flex items-center justify-between gap-3">
          <div class="min-w-0">
            <p class="text-[11px] font-black uppercase tracking-wide text-red-700 dark:text-red-400">Payment overview</p>
            <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1">
              <h2 class="text-2xl font-black tabular-nums text-[#0F172A] dark:text-white"><%= yen(@membership_payment.amount) %></h2>
              <span class="text-xs font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= @membership_payment.period_label %></span>
            </div>
          </div>
          <div class="shrink-0">
            <%= render "shared/status_badge", status: @membership_payment.status, compact: true %>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-red-100 bg-white p-4 shadow-sm dark:border-red-500/20 dark:bg-[#1E293B] sm:p-5">
        <div class="flex items-center gap-3">
          <span class="grid h-11 w-11 place-items-center rounded-xl bg-red-600 text-white shadow-sm shadow-red-950/10"><%= icon_svg(:credit_card, classes: "h-5 w-5") %></span>
          <div>
            <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-400">Main payment method</p>
            <h3 class="text-lg font-black text-[#0F172A] dark:text-white">Bank Transfer</h3>
            <p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">Transfer to this account, then submit your transfer details below.</p>
          </div>
        </div>

        <div class="mt-5 grid gap-3 lg:grid-cols-2">
          <section class="rounded-xl border border-sky-100 bg-gradient-to-br from-sky-50 to-white p-3 shadow-sm shadow-sky-950/5 dark:border-sky-400/20 dark:from-sky-500/10 dark:to-[#0F172A]">
            <p class="inline-flex rounded-full bg-yellow-100 px-2.5 py-1 text-xs font-black uppercase tracking-wide text-yellow-900 ring-1 ring-yellow-200 dark:bg-yellow-400/15 dark:text-yellow-100 dark:ring-yellow-300/20">From another bank</p>
            <p class="mt-1 text-[11px] font-semibold leading-4 text-[#64748B] dark:text-[#CBD5E1]">Use these fields when transferring from MUFG, SMBC, Mizuho, or another bank.</p>
            <dl class="mt-3 space-y-2">
              <% [
                [ "Bank", @bank_transfer_details[:bank_name] ],
                [ "Store Name<br><span class=\"text-inherit normal-case tracking-normal\">店名</span>".html_safe, @bank_transfer_details[:branch_name] ],
                [ "Account Number<br><span class=\"text-inherit normal-case tracking-normal\">口座番号</span>".html_safe, @bank_transfer_details[:account_number] ],
                [ "Account Name", @bank_transfer_details[:account_name] ]
              ].each do |label, value| %>
                <% next if value.blank? %>
                <% copyable = label.to_s.include?("Store Name") || label.to_s.include?("Account Number") %>
                <% copy_title = strip_tags(label.to_s).squish %>
                <div class="flex gap-3 rounded-lg bg-white/90 px-3 py-2 ring-1 ring-sky-100/70 dark:bg-[#1E293B]/85 dark:ring-sky-400/10">
                  <dt class="w-28 shrink-0 text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= label %></dt>
                  <dd class="flex min-w-0 flex-1 items-start justify-between gap-2">
                    <span class="min-w-0 break-all text-sm font-black text-[#0F172A] dark:text-white"><%= value %></span>
                    <% if copyable %>
                      <button type="button" class="inline-flex h-8 shrink-0 items-center gap-1 rounded-lg border border-[#E2E8F0] bg-white px-2 text-[11px] font-black text-[#64748B] transition hover:border-red-200 hover:text-red-700 dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1] dark:hover:text-red-300" data-controller="clipboard" data-clipboard-text-value="<%= value %>" data-action="clipboard#copy" title="Copy <%= copy_title %>">
                        <%= icon_svg(:copy, classes: "h-3.5 w-3.5") %>
                        <span data-clipboard-target="label">Copy</span>
                      </button>
                    <% end %>
                  </dd>
                </div>
              <% end %>
            </dl>
          </section>

          <section class="rounded-xl border border-red-100 bg-gradient-to-br from-red-50 to-white p-3 shadow-sm shadow-red-950/5 dark:border-red-400/20 dark:from-red-500/10 dark:to-[#0F172A]">
            <p class="inline-flex rounded-full bg-yellow-100 px-2.5 py-1 text-xs font-black uppercase tracking-wide text-yellow-900 ring-1 ring-yellow-200 dark:bg-yellow-400/15 dark:text-yellow-100 dark:ring-yellow-300/20">From ゆうちょ銀行</p>
            <p class="mt-1 text-[11px] font-semibold leading-4 text-[#64748B] dark:text-[#CBD5E1]">Use these when ゆうちょ app or ATM asks for 記号 and 番号 separately.</p>
            <dl class="mt-3 space-y-2">
              <% [
                [ "Yuucho Symbol<br><span class=\"text-inherit normal-case tracking-normal\">記号</span>".html_safe, @bank_transfer_details[:yucho_symbol] ],
                [ "Yuucho Number<br><span class=\"text-inherit normal-case tracking-normal\">番号</span>".html_safe, @bank_transfer_details[:yucho_number] ],
                [ "Account Name", @bank_transfer_details[:account_name] ]
              ].each do |label, value| %>
                <% display_value = value.presence || "Not set" %>
                <% copyable = label.to_s.include?("Yuucho Symbol") || label.to_s.include?("Yuucho Number") %>
                <% copy_title = strip_tags(label.to_s).squish %>
                <div class="flex gap-3 rounded-lg bg-white/90 px-3 py-2 ring-1 ring-red-100/70 dark:bg-[#1E293B]/85 dark:ring-red-400/10">
                  <dt class="w-28 shrink-0 text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]"><%= label %></dt>
                  <dd class="flex min-w-0 flex-1 items-start justify-between gap-2">
                    <span class="min-w-0 break-all text-sm font-black text-[#0F172A] dark:text-white"><%= display_value %></span>
                    <% if copyable && value.present? %>
                      <button type="button" class="inline-flex h-8 shrink-0 items-center gap-1 rounded-lg border border-[#E2E8F0] bg-white px-2 text-[11px] font-black text-[#64748B] transition hover:border-red-200 hover:text-red-700 dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1] dark:hover:text-red-300" data-controller="clipboard" data-clipboard-text-value="<%= value %>" data-action="clipboard#copy" title="Copy <%= copy_title %>">
                        <%= icon_svg(:copy, classes: "h-3.5 w-3.5") %>
                        <span data-clipboard-target="label">Copy</span>
                      </button>
                    <% end %>
                  </dd>
                </div>
              <% end %>
            </dl>
          </section>
        </div>

      </section>

      <% if @membership_payment.pending_verification? || @membership_payment.paid? %>
        <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
          <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-400">Submitted transfer</p>
          <div class="mt-4 grid gap-3 sm:grid-cols-3">
            <div>
              <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Transfer Date</p>
              <p class="mt-1 font-black text-[#0F172A] dark:text-white"><%= @membership_payment.transferred_on&.strftime("%b %d, %Y") || "Not submitted" %></p>
            </div>
            <div>
              <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Amount</p>
              <p class="mt-1 font-black text-[#0F172A] dark:text-white"><%= yen(@membership_payment.transfer_amount || @membership_payment.amount) %></p>
            </div>
            <div>
              <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Reference Name</p>
              <p class="mt-1 font-black text-[#0F172A] dark:text-white"><%= @membership_payment.transfer_reference_name.presence || "Not submitted" %></p>
            </div>
          </div>
          <% if @membership_payment.transfer_screenshot.attached? %>
            <%= link_to rails_blob_path(@membership_payment.transfer_screenshot, disposition: "attachment"), class: "#{action_button_classes(:secondary, size: :sm)} mt-4", target: "_blank", rel: "noopener" do %>
              <%= icon_svg(:download, classes: "h-4 w-4") %>
              <span>Download screenshot</span>
            <% end %>
          <% end %>
        </section>
      <% end %>

      <% if policy(@membership_payment).submit_transfer? %>
        <section class="rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm dark:border-[#334155] dark:bg-[#1E293B]">
          <h3 class="text-lg font-black text-[#0F172A] dark:text-white">Submit Bank Transfer Details</h3>
          <p class="mt-1 text-sm font-semibold text-[#64748B] dark:text-[#CBD5E1]">Submit after your bank transfer is complete.</p>

          <%= form_with model: @membership_payment, url: submit_transfer_membership_payment_path(@membership_payment), method: :patch, class: "mt-5 grid gap-4 sm:grid-cols-2" do |form| %>
            <%= render "devise/shared/error_messages", resource: @membership_payment %>
            <div>
              <%= form.label :transferred_on, "Transfer Date", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.date_field :transferred_on, required: true, max: Date.current, class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
            </div>
            <div>
              <%= form.label :transfer_amount, "Amount", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.number_field :transfer_amount, required: true, min: 0, step: 1, value: @membership_payment.amount.to_i, class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
            </div>
            <div class="sm:col-span-2">
              <%= form.label :transfer_reference_name, "Reference Name", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.text_field :transfer_reference_name, required: true, value: @membership_payment.transfer_reference_name.presence || current_user.display_name, class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100 dark:border-[#334155] dark:bg-[#0F172A] dark:text-white" %>
            </div>
            <div class="sm:col-span-2">
              <%= form.label :transfer_screenshot, "Screenshot (optional)", class: "block text-sm font-black text-[#334155] dark:text-[#CBD5E1]" %>
              <%= form.file_field :transfer_screenshot, accept: "image/png,image/jpeg,image/webp,application/pdf", class: "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-sm text-[#334155] file:mr-3 file:rounded-md file:border-0 file:bg-[#0F172A] file:px-3 file:py-1.5 file:text-xs file:font-black file:text-white dark:border-[#334155] dark:bg-[#0F172A] dark:text-[#CBD5E1]" %>
            </div>
            <div class="sm:col-span-2 sm:flex sm:justify-end">
              <%= form.button type: :submit, class: action_button_classes(:primary, size: :sm, extra: "px-2 sm:px-3") do %>
                <%= icon_svg(:check, classes: "h-4 w-4") %>
                <span>Submit Details</span>
              <% end %>
            </div>
          <% end %>
        </section>
      <% elsif @membership_payment.pending_verification? %>
        <section class="rounded-2xl border border-amber-200 bg-amber-50 p-5 dark:border-amber-500/30 dark:bg-amber-500/10">
          <p class="font-black text-amber-800 dark:text-amber-200">Pending Verification</p>
          <p class="mt-1 text-sm font-semibold text-amber-700 dark:text-amber-100">Treasurer will verify the bank account and approve your payment.</p>
        </section>
      <% elsif @membership_payment.paid? %>
        <section class="rounded-2xl border border-emerald-200 bg-emerald-50 p-5 dark:border-emerald-500/30 dark:bg-emerald-500/10">
          <p class="font-black text-emerald-800 dark:text-emerald-200">Payment Paid</p>
          <p class="mt-1 text-sm font-semibold text-emerald-700 dark:text-emerald-100">Your payment has been verified.</p>
        </section>
      <% end %>
    </div>

  </section>
</div>
