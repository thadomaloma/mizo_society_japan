<article class="rounded-2xl border border-red-100 bg-red-50/60 p-3 shadow-sm dark:border-red-500/20 dark:bg-red-500/10 sm:p-4">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <p class="text-xs font-black uppercase tracking-wide text-red-700 dark:text-red-300">Combined payment</p>
      <h3 class="mt-1 text-base font-black text-[#0F172A] dark:text-white"><%= pluralize(payment_batch.membership_payments.count, "item") %></h3>
      <p class="mt-1 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]">One bank transfer for selected payments.</p>
    </div>
    <%= render "shared/status_badge", status: payment_batch.status, compact: true %>
  </div>

  <div class="mt-3 rounded-xl bg-white px-3 py-2 dark:bg-[#0F172A]">
    <div class="flex items-center justify-between gap-3">
      <p class="text-xs font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Total</p>
      <p class="text-lg font-black text-[#0F172A] dark:text-white"><%= yen(payment_batch.total_amount) %></p>
    </div>
    <div class="mt-2 space-y-1">
      <% payment_batch.membership_payments.first(3).each do |payment| %>
        <p class="truncate text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= payment.membership_plan.name %> · <%= yen(payment.amount) %></p>
      <% end %>
      <% if payment_batch.membership_payments.size > 3 %>
        <p class="text-xs font-black text-red-700 dark:text-red-300">+ <%= payment_batch.membership_payments.size - 3 %> more</p>
      <% end %>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to payment_batch_path(payment_batch), class: action_button_classes(payment_batch.pending_verification? ? :secondary : :primary, size: :sm, full_width: true) do %>
      <%= icon_svg(:eye, classes: "h-4 w-4") %>
      <span><%= payment_batch.pending_verification? ? "View Submission" : "Submit Transfer Details" %></span>
    <% end %>
  </div>
</article>
