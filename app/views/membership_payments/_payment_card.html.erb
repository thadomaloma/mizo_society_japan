<% embedded = local_assigns.fetch(:embedded, false) %>
<% card_classes = embedded ? "rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm transition hover:border-red-200 hover:shadow-md dark:border-[#334155] dark:bg-[#1E293B] dark:hover:border-red-400/40 sm:p-4" : "rounded-2xl border border-[#E2E8F0] bg-white p-3 shadow-sm transition hover:border-red-200 hover:bg-red-50/30 dark:border-[#334155] dark:bg-[#1E293B] dark:hover:bg-[#334155]/60 sm:p-4" %>
<% status_note = if payment.pending_verification?
  "Waiting for treasurer verification"
elsif payment.paid?
  "Payment completed"
elsif payment.failed?
  "Please resubmit payment details"
elsif payment.expired?
  "Payment expired. You can pay again"
else
  "Action needed"
end %>
<% action_variant = policy(payment).submit_transfer? ? :primary : :secondary %>
<% action_label = policy(payment).submit_transfer? ? "Pay Now" : "View Details" %>
<% action_icon = policy(payment).submit_transfer? ? :credit_card : :eye %>

<article class="<%= card_classes %>">
  <div class="flex items-start justify-between gap-3">
    <div class="flex min-w-0 items-start gap-3">
      <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl <%= policy(payment).submit_transfer? ? "bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300" : "bg-slate-100 text-[#64748B] dark:bg-[#0F172A] dark:text-[#CBD5E1]" %>">
          <%= icon_svg(payment.paid? ? :check : :credit_card, classes: "h-5 w-5") %>
      </span>
      <div class="min-w-0">
        <p class="truncate text-[11px] font-black uppercase tracking-wide text-red-700 dark:text-red-300"><%= payment.plan_type_label %></p>
        <h3 class="mt-0.5 line-clamp-2 text-[15px] font-black leading-5 text-[#0F172A] dark:text-white sm:text-base"><%= payment.membership_plan.name %></h3>
      </div>
    </div>
    <%= render "shared/status_badge", status: payment.status, compact: true %>
  </div>

  <div class="mt-4 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
    <div class="flex items-end justify-between gap-3">
      <div class="min-w-0">
        <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Amount</p>
        <p class="mt-1 truncate text-2xl font-black tabular-nums text-[#0F172A] dark:text-white"><%= yen(payment.amount) %></p>
      </div>
      <div class="shrink-0 text-right">
        <p class="text-[11px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Period</p>
        <p class="mt-1 text-sm font-black text-[#0F172A] dark:text-white"><%= payment.period_label %></p>
      </div>
    </div>
  </div>

  <p class="mt-3 truncate text-xs font-bold <%= payment.pending_verification? ? "text-amber-700 dark:text-amber-300" : "text-[#64748B] dark:text-[#CBD5E1]" %>"><%= status_note %></p>

  <div class="mt-3 grid">
    <%= link_to membership_payment_path(payment), class: action_button_classes(action_variant, size: :sm, full_width: true, extra: "py-2") do %>
      <%= icon_svg(action_icon, classes: "h-4 w-4") %>
      <span><%= action_label %></span>
    <% end %>
  </div>
</article>
