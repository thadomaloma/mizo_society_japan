<% recorded_date = payment.paid? ? payment.receipt_date : payment.updated_at.to_date %>
<% receipt_available = policy(payment).receipt? %>
<% action_path = receipt_available ? printable_payment_receipt_path(payment) : membership_payment_path(payment) %>

<article class="p-3 sm:p-4">
  <div class="flex min-w-0 items-start justify-between gap-3">
    <div class="flex min-w-0 items-start gap-2.5">
      <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg <%= payment.paid? ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300' : 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300' %>">
        <%= icon_svg(payment.paid? ? :check : :credit_card, classes: "h-4 w-4") %>
      </span>
      <div class="min-w-0">
        <p class="truncate text-sm font-black text-[#0F172A] dark:text-white"><%= payment.membership_plan.name %></p>
        <p class="mt-0.5 truncate text-[11px] font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= payment.payment_for_label %></p>
      </div>
    </div>
    <%= render "shared/status_badge", status: payment.status, compact: true %>
  </div>

  <dl class="mt-3 grid grid-cols-3 gap-2 border-y border-[#E2E8F0] py-2.5 dark:border-[#334155]">
    <div class="min-w-0">
      <dt class="text-[9px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Amount</dt>
      <dd class="mt-0.5 truncate text-sm font-black tabular-nums text-[#0F172A] dark:text-white"><%= yen(payment.amount) %></dd>
    </div>
    <div class="min-w-0">
      <dt class="text-[9px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Period</dt>
      <dd class="mt-0.5 truncate text-xs font-black text-[#0F172A] dark:text-white"><%= payment.one_time_payment? ? "One-time" : payment.period_label %></dd>
    </div>
    <div class="min-w-0 text-right">
      <dt class="text-[9px] font-black uppercase tracking-wide text-[#64748B] dark:text-[#CBD5E1]">Recorded</dt>
      <dd class="mt-0.5 truncate text-xs font-black text-[#0F172A] dark:text-white"><%= recorded_date.strftime("%d %b %Y") %></dd>
    </div>
  </dl>

  <div class="mt-2.5 flex min-w-0 items-center justify-between gap-3">
    <div class="min-w-0">
      <p class="truncate text-[11px] font-bold text-[#64748B] dark:text-[#CBD5E1]"><%= payment.payment_method.humanize %></p>
      <% if payment.payment_batch&.paid? %>
        <p class="mt-0.5 text-[10px] font-black text-red-700 dark:text-red-300">Combined payment receipt</p>
      <% end %>
    </div>
    <%= link_to action_path,
      class: action_button_classes(receipt_available ? :secondary : :ghost, size: :xs, extra: "shrink-0"),
      target: ("_blank" if receipt_available),
      rel: ("noopener" if receipt_available) do %>
      <%= icon_svg(receipt_available ? :printer : :eye, classes: "h-3.5 w-3.5") %>
      <span><%= receipt_available ? "Receipt" : "Details" %></span>
    <% end %>
  </div>
</article>
