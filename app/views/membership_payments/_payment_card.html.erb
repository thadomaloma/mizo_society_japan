<% embedded = local_assigns.fetch(:embedded, false) %>
<% card_classes = embedded ? "bg-transparent py-3 transition hover:bg-red-50/30 dark:hover:bg-[#334155]/30 sm:rounded-xl sm:border sm:border-[#E2E8F0] sm:bg-white sm:p-4 sm:shadow-sm sm:hover:border-red-200 sm:dark:border-[#334155] sm:dark:bg-[#1E293B] sm:dark:hover:bg-[#334155]/60" : "rounded-xl border border-[#E2E8F0] bg-white p-3 shadow-sm transition hover:border-red-200 hover:bg-red-50/30 dark:border-[#334155] dark:bg-[#1E293B] dark:hover:bg-[#334155]/60 sm:p-4" %>

<article class="<%= card_classes %>">
  <div class="flex items-center gap-2.5 sm:gap-3">
    <span class="hidden h-9 w-9 shrink-0 place-items-center rounded-xl bg-red-50 text-red-700 dark:bg-red-500/10 dark:text-red-300 sm:grid sm:h-10 sm:w-10">
        <%= icon_svg(payment.paid? ? :check : :credit_card, classes: "h-4 w-4 sm:h-5 sm:w-5") %>
    </span>

    <div class="min-w-0 flex-1">
      <div class="flex min-w-0 items-center justify-between gap-2">
        <h3 class="min-w-0 truncate text-sm font-black text-[#0F172A] dark:text-white"><%= payment.membership_plan.name %></h3>
        <p class="shrink-0 text-sm font-black tabular-nums text-[#0F172A] dark:text-white sm:text-lg"><%= yen(payment.amount) %></p>
      </div>
      <div class="mt-1 flex min-w-0 items-center justify-between gap-2">
        <p class="min-w-0 truncate text-[11px] font-semibold text-[#64748B] dark:text-[#CBD5E1] sm:text-xs">
          <%= payment.period_label %>
        </p>
        <%= render "shared/status_badge", status: payment.status, compact: true %>
      </div>
    </div>

    <div class="hidden sm:block">
      <%= link_to membership_payment_path(payment), class: action_button_classes(policy(payment).submit_transfer? ? :primary : :secondary, size: :xs, extra: "px-2.5") do %>
        <%= icon_svg(policy(payment).submit_transfer? ? :credit_card : :eye, classes: "h-3.5 w-3.5") %>
        <span><%= policy(payment).submit_transfer? ? "Pay Now" : "Details" %></span>
      <% end %>
    </div>
  </div>

  <div class="mt-2 flex justify-end sm:hidden">
    <%= link_to membership_payment_path(payment), class: action_button_classes(policy(payment).submit_transfer? ? :primary : :secondary, size: :xs, extra: "px-3") do %>
      <%= icon_svg(policy(payment).submit_transfer? ? :credit_card : :eye, classes: "h-3.5 w-3.5") %>
      <span><%= policy(payment).submit_transfer? ? "Pay Now" : "Details" %></span>
    <% end %>
  </div>

  <% if payment.pending_verification? %>
    <div class="mt-3 hidden rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-bold text-amber-700 dark:border-amber-500/30 dark:bg-amber-500/10 dark:text-amber-200 sm:block">
      Submitted. Treasurer verification pending.
    </div>
  <% end %>
</article>
