<% input_class = local_assigns.fetch(:class_name, "mt-2 block w-full rounded-lg border border-[#CBD5E1] px-3 py-2 text-[#0F172A] shadow-sm outline-none transition focus:border-red-600 focus:ring-2 focus:ring-red-100") %>
<% autofocus = local_assigns.fetch(:autofocus, false) %>

<div class="relative mt-2" data-controller="password-visibility">
  <%= form.password_field attribute,
    autofocus: autofocus,
    autocomplete: autocomplete,
    class: "#{input_class} mt-0 pr-12",
    data: { password_visibility_target: "input" } %>

  <button
    type="button"
    class="absolute inset-y-0 right-0 grid w-12 place-items-center rounded-r-lg text-[#64748B] transition hover:text-red-700 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-red-600"
    aria-label="Show password"
    data-password-visibility-target="button"
    data-action="password-visibility#toggle">
    <span data-password-visibility-target="eyeIcon">
      <%= icon_svg(:eye, classes: "h-5 w-5") %>
    </span>
    <span class="hidden" data-password-visibility-target="eyeSlashIcon">
      <%= icon_svg(:eye_slash, classes: "h-5 w-5") %>
    </span>
  </button>
</div>
