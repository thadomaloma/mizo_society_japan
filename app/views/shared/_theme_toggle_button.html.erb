<button type="button" data-action="theme#toggle" class="grid h-9 w-9 place-items-center rounded-xl border border-[#E2E8F0] bg-white text-slate-700 transition hover:border-red-200 hover:text-red-700 active:scale-95 dark:border-[#334155] dark:bg-[#1E293B] dark:text-[#F8FAFC] dark:hover:text-red-400 sm:h-10 sm:w-10" aria-label="Toggle dark mode">
  <span data-theme-target="moonIcon"><%= icon_svg(:moon, classes: "h-5 w-5") %></span>
  <span data-theme-target="sunIcon" class="hidden"><%= icon_svg(:sun, classes: "h-5 w-5") %></span>
</button>
