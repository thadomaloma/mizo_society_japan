<% stats = Array(local_assigns.fetch(:stats, [])) %>
<% title = local_assigns.fetch(:title, "Overview") %>
<% subtitle = local_assigns[:subtitle] %>

<section class="min-w-0 overflow-hidden rounded-lg border border-[#E2E8F0] bg-white p-3 shadow-[0_1px_2px_rgba(15,23,42,0.04)] dark:border-[#334155] dark:bg-[#1E293B] lg:hidden">
  <div class="mb-3 flex items-center justify-between gap-3 px-1">
    <div>
      <p class="msj-kicker"><%= title %></p>
      <% if subtitle.present? %>
        <p class="mt-0.5 text-xs font-semibold text-[#64748B] dark:text-[#CBD5E1]"><%= subtitle %></p>
      <% end %>
    </div>
    <span class="rounded-md bg-red-50 px-2 py-1 text-[10px] font-extrabold text-red-700 dark:bg-red-500/15 dark:text-red-300">
      <%= pluralize(stats.size, "item") %>
    </span>
  </div>

  <div class="grid grid-cols-2 gap-2">
    <% stats.each do |stat| %>
      <% value_text = stat[:value].to_s %>
      <% value_classes = value_text.length >= 8 ? "text-[15px] leading-5" : "text-xl leading-6" %>
      <article class="min-w-0 rounded-lg border border-[#E2E8F0] bg-[#F8FAFC] p-3 dark:border-[#334155] dark:bg-[#0F172A]">
        <div class="flex items-start gap-2.5">
          <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg <%= stat_card_classes(stat[:tone].presence || "red") %>">
            <%= icon_svg(stat[:icon] || :dashboard, classes: "h-4 w-4") %>
          </span>
          <div class="min-w-0 flex-1">
            <p class="truncate text-[11px] font-black leading-4 text-[#64748B] dark:text-[#CBD5E1]"><%= stat[:label] %></p>
            <p class="mt-0.5 whitespace-nowrap font-black tabular-nums text-[#0F172A] dark:text-white <%= value_classes %>"><%= stat[:value] %></p>
          </div>
        </div>
        <% if stat[:caption].present? %>
          <p class="mt-2 truncate text-[11px] font-bold <%= stat[:caption_tone].presence || "text-[#64748B] dark:text-[#CBD5E1]" %>"><%= stat[:caption] %></p>
        <% end %>
      </article>
    <% end %>
  </div>
</section>
