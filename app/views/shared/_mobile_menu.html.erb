<div data-mobile-menu-target="drawer" data-action="click->mobile-menu#closeFromBackdrop" class="fixed inset-0 z-50 hidden bg-slate-950/55 lg:hidden">
  <aside data-mobile-menu-target="panel" class="flex h-full w-[min(17rem,76vw)] -translate-x-full flex-col bg-[#0F172A] text-white shadow-2xl ring-1 ring-white/10 transition-transform duration-150 ease-out dark:bg-[#020617]">
    <div class="flex items-center justify-between border-b border-white/10 px-3.5 pb-3 pt-[max(0.9rem,env(safe-area-inset-top))]">
      <%= link_to(dashboard_home_path, class: "flex min-w-0 items-center gap-2.5", data: { action: "click->mobile-menu#close" }) do %>
        <span class="grid h-9 w-9 shrink-0 place-items-center overflow-hidden rounded-full border border-red-500/50 bg-white shadow-sm shadow-slate-950/20">
          <%= image_tag "/icons/msj-portal-192x192-20260709.png", alt: "MSJ", class: "h-8 w-8 rounded-full object-cover" %>
        </span>
        <span class="min-w-0">
          <span class="block truncate text-[13px] font-black tracking-tight text-[#F8FAFC]">Mizo Society of Japan</span>
          <span class="mt-0.5 block text-[11px] font-semibold tracking-[0.14em] text-slate-300">Tlawmngai Pawl</span>
        </span>
      <% end %>
      <button type="button" data-action="mobile-menu#close" class="grid h-8 w-8 place-items-center rounded-lg bg-white/10 text-slate-100 transition hover:bg-white/15 active:scale-95" aria-label="Close menu">
        <%= icon_svg(:x_mark, classes: "h-4 w-4") %>
      </button>
    </div>

    <% mobile_menu_items = admin_portal_user? ? admin_nav_items + portal_nav_items.select { |item| item[:label] == "Profile" } : portal_nav_items %>
    <nav class="flex-1 space-y-1 overflow-y-auto px-2.5 py-3">
      <% mobile_menu_items.each do |item| %>
        <% next if item[:label] == "Settings" && !current_user.super_admin? %>
        <% accessible = !admin_portal_user? || item[:label] == "Profile" || nav_item_visible?(item) %>
        <% active = nav_active?(item) || (item[:label] == "Settings" && settings_section_active?) %>
        <% if accessible %>
          <%= link_to item[:path], data: { action: "click->mobile-menu#close" }, class: "flex items-center gap-2.5 rounded-xl px-3 py-2.5 text-[13.5px] font-black leading-6 transition #{active ? "bg-red-600 text-white shadow-lg shadow-red-950/20" : "text-slate-300 hover:bg-white/10 hover:text-white"}" do %>
            <%= icon_svg(item[:icon], classes: "h-4 w-4") %>
            <span><%= item[:label] %></span>
          <% end %>
        <% else %>
          <span class="flex cursor-not-allowed items-center gap-2.5 rounded-xl px-3 py-2.5 text-[13.5px] font-black leading-6 text-slate-600">
            <%= icon_svg(item[:icon], classes: "h-4 w-4") %>
            <span class="flex-1"><%= item[:label] %></span>
            <%= icon_svg(:lock, classes: "h-3.5 w-3.5") %>
          </span>
        <% end %>
      <% end %>
    </nav>

    <div class="border-t border-white/10 p-2.5 pb-[calc(env(safe-area-inset-bottom)+0.65rem)]">
      <%= button_to destroy_user_session_path, method: :delete, class: "flex w-full items-center gap-2.5 rounded-xl px-3 py-2.5 text-[13.5px] font-black leading-6 text-red-300 transition hover:bg-red-500/10" do %>
        <%= icon_svg(:logout, classes: "h-4 w-4") %>
        <span>Log out</span>
      <% end %>
    </div>
  </aside>
</div>
