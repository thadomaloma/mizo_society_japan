<article class="group rounded-lg border border-[#E2E8F0] bg-white p-3.5 shadow-[0_1px_2px_rgba(15,23,42,0.04)] transition hover:border-slate-300 hover:shadow-[0_8px_22px_rgba(15,23,42,0.07)] dark:border-[#334155] dark:bg-[#1E293B] dark:hover:border-[#475569] sm:p-4">
  <div class="flex items-start gap-2.5 sm:gap-3">
    <div class="grid h-10 w-10 shrink-0 place-items-center rounded-lg sm:h-11 sm:w-11 <%= stat_card_classes(local_assigns.fetch(:tone, "dark")) %>">
      <%= icon_svg(local_assigns.fetch(:icon, :dashboard), classes: "h-5 w-5") %>
    </div>
    <div class="min-w-0 flex-1">
      <p class="truncate text-[11px] font-extrabold uppercase tracking-[0.05em] text-[#64748B] dark:text-[#CBD5E1]"><%= label %></p>
      <p class="mt-1 truncate text-xl font-black tabular-nums text-[#0F172A] dark:text-[#F8FAFC] sm:text-[1.45rem]"><%= value %></p>
    </div>
  </div>
  <% if local_assigns[:caption].present? %>
    <p class="mt-3 truncate border-t border-slate-100 pt-2.5 text-[11px] font-bold dark:border-[#334155] <%= local_assigns.fetch(:caption_tone, "text-[#64748B] dark:text-[#CBD5E1]") %>"><%= caption %></p>
  <% end %>
</article>
