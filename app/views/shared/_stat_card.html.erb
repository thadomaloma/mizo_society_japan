<article class="rounded-xl border border-[#E2E8F0] bg-white p-3 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-[#334155] dark:bg-[#1E293B] dark:hover:bg-[#334155] sm:p-4">
  <div class="flex items-start gap-2.5 sm:gap-3">
    <div class="grid h-10 w-10 shrink-0 place-items-center rounded-lg shadow-sm sm:h-12 sm:w-12 <%= stat_card_classes(local_assigns.fetch(:tone, "dark")) %>">
      <%= icon_svg(local_assigns.fetch(:icon, :dashboard), classes: "h-5 w-5 sm:h-6 sm:w-6") %>
    </div>
    <div class="min-w-0 flex-1">
      <p class="text-xs font-black text-[#64748B] dark:text-[#CBD5E1]"><%= label %></p>
      <p class="mt-0.5 truncate text-xl font-black tracking-tight text-[#0F172A] dark:text-[#F8FAFC] sm:mt-1 sm:text-2xl"><%= value %></p>
    </div>
  </div>
  <% if local_assigns[:caption].present? %>
    <p class="mt-2 truncate text-xs font-bold sm:mt-4 <%= local_assigns.fetch(:caption_tone, "text-[#64748B] dark:text-[#CBD5E1]") %>"><%= caption %></p>
  <% end %>
</article>
