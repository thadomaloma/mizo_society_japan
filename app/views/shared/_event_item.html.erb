<div class="flex items-center gap-4 rounded-lg border-b border-[#E2E8F0] pb-4 last:border-b-0 last:pb-0 dark:border-[#334155]">
  <div class="w-16 shrink-0 overflow-hidden rounded-lg border border-red-100 bg-white text-center shadow-sm dark:border-[#334155] dark:bg-[#334155]">
    <p class="bg-red-700 py-1 text-xs font-black uppercase tracking-wide text-white"><%= event.start_time.strftime("%b") %></p>
    <p class="py-2 text-2xl font-black text-gray-950 dark:text-white"><%= event.start_time.day %></p>
  </div>
  <div class="min-w-0">
    <p class="truncate text-sm font-black text-gray-950 dark:text-white"><%= event.title %></p>
    <p class="mt-1 text-xs font-semibold text-gray-500 dark:text-gray-400"><%= event.start_time.strftime("%A, %H:%M") %></p>
    <p class="mt-1 truncate text-xs font-semibold text-gray-500 dark:text-gray-400"><%= event.full_location.presence || "Location to be announced" %></p>
  </div>
</div>
