<details class="group relative <%= local_assigns[:class] %>">
  <summary class="cursor-pointer list-none">
    <%= summary %>
  </summary>
  <div class="absolute right-0 z-30 mt-2 rounded-xl border border-[#E2E8F0] bg-white p-2 shadow-xl dark:border-[#334155] dark:bg-[#1E293B]">
    <%= yield %>
  </div>
</details>
