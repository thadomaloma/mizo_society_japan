<article class="group overflow-hidden rounded-2xl border border-[#E2E8F0] bg-white shadow-sm transition hover:-translate-y-0.5 hover:border-red-200 hover:shadow-lg hover:shadow-slate-950/10 dark:border-[#334155] dark:bg-[#1E293B] dark:hover:border-red-400/40">
  <div class="relative h-24 overflow-hidden bg-gradient-to-br from-red-800 via-red-700 to-[#0F172A] dark:from-red-700 dark:via-red-900 dark:to-[#020617] sm:h-28">
    <% if event.cover_image.attached? %>
      <%= image_tag event.cover_image, class: "h-full w-full object-cover transition duration-500 group-hover:scale-105" %>
      <div class="absolute inset-0 bg-gradient-to-t from-[#0F172A]/70 via-[#0F172A]/10 to-transparent"></div>
    <% else %>
      <div class="absolute inset-0 opacity-30">
        <div class="absolute -right-10 -top-10 h-32 w-32 rounded-full border border-white/25"></div>
        <div class="absolute bottom-4 left-4 h-12 w-28 rounded-full border border-white/15"></div>
      </div>
    <% end %>

    <div class="absolute left-3 top-3 w-14 overflow-hidden rounded-xl border border-white/30 bg-white text-center shadow-lg shadow-slate-950/20 dark:bg-[#0F172A] sm:left-4 sm:top-4 sm:w-16">
      <p class="bg-red-700 py-0.5 text-[10px] font-black uppercase tracking-wide text-white dark:bg-red-600 sm:py-1 sm:text-xs"><%= event.start_time.strftime("%b") %></p>
      <p class="py-1.5 text-xl font-black text-[#0F172A] dark:text-white sm:py-2 sm:text-2xl"><%= event.start_time.day %></p>
    </div>

    <% if current_user.event_manager? %>
      <div class="absolute right-4 top-4">
        <%= render "shared/status_badge", status: event.status %>
      </div>
    <% end %>
  </div>

  <div class="p-3.5 sm:p-4">
    <div class="min-w-0">
      <h3 class="line-clamp-2 text-[15px] font-black leading-5 text-[#0F172A] dark:text-white sm:min-h-10 sm:text-base">
        <%= link_to event.title, event, class: "hover:text-red-700 dark:hover:text-red-300" %>
      </h3>
      <p class="mt-1.5 text-[12px] font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1] sm:text-xs"><%= event.start_time.strftime("%A, %H:%M") %></p>
    </div>

    <p class="mt-2 line-clamp-2 text-[13px] font-semibold leading-5 text-[#64748B] dark:text-[#CBD5E1] sm:min-h-10 sm:text-sm"><%= event.description %></p>
    <div class="mt-3 flex flex-wrap items-center gap-1.5 text-[11px] font-black text-[#64748B] dark:text-[#CBD5E1] sm:gap-2 sm:text-xs">
      <span class="inline-flex max-w-full items-center gap-1.5 truncate rounded-lg bg-slate-50 px-2 py-1 dark:bg-[#0F172A] sm:px-2.5 sm:py-1.5">
        <%= icon_svg(:events, classes: "h-3.5 w-3.5 text-red-600 dark:text-red-300") %>
        <span class="truncate"><%= event.full_location.presence || "Location to be announced" %></span>
      </span>
      <% if event.registration_required? %>
        <span class="rounded-lg bg-red-50 px-2 py-1 text-red-700 dark:bg-red-500/10 dark:text-red-300 sm:px-2.5 sm:py-1.5"><%= event.rsvp_count %> RSVP</span>
      <% end %>
      <% if event.event_category.present? %>
        <span class="rounded-lg bg-slate-50 px-2 py-1 dark:bg-[#0F172A] sm:px-2.5 sm:py-1.5"><%= event.event_category.name %></span>
      <% end %>
    </div>

    <div class="mt-3 flex justify-end gap-2 border-t border-[#E2E8F0] pt-3 dark:border-[#334155] sm:mt-4 sm:pt-4">
      <%= link_to event, class: action_button_classes(:secondary, size: :xs) do %>
        <%= icon_svg(:eye, classes: "h-3.5 w-3.5") %>
        <span>View</span>
      <% end %>
      <% if policy(event).update? %>
        <%= link_to edit_event_path(event), class: action_button_classes(:secondary, size: :xs) do %>
          <%= icon_svg(:edit, classes: "h-3.5 w-3.5") %>
          <span>Edit</span>
        <% end %>
      <% end %>
    </div>
  </div>
</article>
