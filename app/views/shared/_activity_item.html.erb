<div class="flex items-start gap-3">
  <div class="mt-0.5 grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-red-50 text-red-700 dark:bg-red-600/15 dark:text-red-300">
    <%= icon_svg(local_assigns.fetch(:icon, :notifications), classes: "h-4 w-4") %>
  </div>
  <div class="min-w-0 flex-1">
    <p class="text-sm font-bold leading-5 text-gray-950 dark:text-white"><%= title %></p>
    <% if local_assigns[:subtitle].present? %>
      <p class="mt-1 text-xs font-semibold text-gray-500 dark:text-gray-400"><%= subtitle %></p>
    <% end %>
  </div>
</div>
