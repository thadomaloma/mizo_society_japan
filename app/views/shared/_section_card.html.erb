<section class="min-w-0 overflow-hidden rounded-lg border border-[#E2E8F0] bg-white shadow-[0_1px_2px_rgba(15,23,42,0.04),0_8px_24px_rgba(15,23,42,0.035)] dark:border-[#334155] dark:bg-[#1E293B] <%= local_assigns[:class] %>">
  <% if local_assigns[:title].present? || local_assigns[:action].present? %>
    <div class="flex min-h-14 items-center justify-between gap-3 border-b border-[#E2E8F0] px-4 py-3.5 dark:border-[#334155] sm:px-5">
      <div class="min-w-0">
        <% if local_assigns[:title].present? %>
          <h3 class="truncate text-[15px] font-black text-[#0F172A] dark:text-[#F8FAFC]"><%= title %></h3>
        <% end %>
        <% if local_assigns[:subtitle].present? %>
          <p class="mt-0.5 text-xs font-medium text-[#64748B] dark:text-[#CBD5E1]"><%= subtitle %></p>
        <% end %>
      </div>
      <% if local_assigns[:action].present? %>
        <div class="shrink-0"><%= action %></div>
      <% end %>
    </div>
  <% end %>
  <div class="<%= local_assigns.fetch(:body_class, "p-5") %>">
    <%= yield %>
  </div>
</section>
