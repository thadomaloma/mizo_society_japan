<div class="rounded-2xl border border-dashed border-gray-300 bg-white p-8 text-center shadow-sm">
  <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-gray-950 text-sm font-black text-white">MSJ</div>
  <h3 class="mt-4 text-lg font-black text-gray-950"><%= title %></h3>
  <% if local_assigns[:message].present? %>
    <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-gray-600"><%= message %></p>
  <% end %>
  <% if local_assigns[:action].present? %>
    <div class="mt-5"><%= action %></div>
  <% end %>
</div>
