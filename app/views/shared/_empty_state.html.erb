<div class="rounded-lg border border-dashed border-[#CBD5E1] bg-[#F8FAFC] p-6 text-center dark:border-[#475569] dark:bg-[#0F172A] sm:p-8">
  <div class="mx-auto grid h-10 w-10 place-items-center rounded-lg bg-[#0F172A] text-xs font-black text-white dark:bg-[#334155]">MSJ</div>
  <h3 class="mt-3 text-base font-black text-[#0F172A] dark:text-white"><%= title %></h3>
  <% if local_assigns[:message].present? %>
    <p class="mx-auto mt-1.5 max-w-md text-sm font-medium leading-6 text-[#64748B] dark:text-[#CBD5E1]"><%= message %></p>
  <% end %>
  <% if local_assigns[:action].present? %>
    <div class="mt-5"><%= action %></div>
  <% end %>
</div>
