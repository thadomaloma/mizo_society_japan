<aside class="fixed inset-y-0 left-0 z-30 hidden w-72 bg-[#1E293B] text-white shadow-2xl dark:bg-[#0F172A] lg:flex lg:flex-col">
  <%= link_to dashboard_home_path, class: "flex h-24 items-center gap-3.5 px-5 transition hover:bg-white/[0.03]", aria: { label: "Go to dashboard" } do %>
    <div class="grid h-12 w-12 shrink-0 place-items-center rounded-full border border-red-500/50 bg-[#334155] shadow-lg shadow-slate-950/25 dark:bg-[#1E293B]">
      <%= image_tag "/icon.png", alt: "MSJ", class: "h-8 w-8 rounded-full" %>
    </div>
    <div class="min-w-0">
      <p class="whitespace-nowrap text-[13px] font-black tracking-[0.035em] text-white dark:text-[#F8FAFC]">MIZO SOCIETY OF JAPAN</p>
      <p class="mt-1 whitespace-nowrap text-[11px] font-bold tracking-[0.04em] text-red-200 dark:text-red-300">Unity <span class="px-0.5 text-slate-400 dark:text-slate-500">•</span> Culture <span class="px-0.5 text-slate-400 dark:text-slate-500">•</span> Welfare</p>
    </div>
  <% end %>

  <nav class="flex-1 space-y-2 overflow-y-auto px-3 py-4">
    <% if admin_portal_user? %>
      <% admin_nav_items.each do |item| %>
        <% next if item[:label] == "Settings" && !current_user.super_admin? %>
        <% accessible = nav_item_visible?(item) %>
        <% active = nav_active?(item) || (item[:label] == "Settings" && settings_section_active?) %>
        <% if accessible %>
          <%= link_to item[:path], class: "group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-black transition #{active ? "bg-red-700 text-white shadow-lg shadow-red-950/25 dark:bg-red-600" : "text-slate-200 hover:bg-[#334155] hover:text-white dark:text-slate-300 dark:hover:bg-[#1E293B]"}" do %>
            <span class="<%= active ? "text-white" : "text-slate-300 group-hover:text-white" %>"><%= icon_svg(item[:icon]) %></span>
            <span><%= item[:label] %></span>
          <% end %>
        <% else %>
          <span class="group flex cursor-not-allowed items-center gap-3 rounded-lg px-3 py-2 text-sm font-black text-slate-500/80 dark:text-slate-600" title="Not available for <%= role_label(current_user.role) %>">
            <span><%= icon_svg(item[:icon]) %></span>
            <span class="flex-1"><%= item[:label] %></span>
            <%= icon_svg(:lock, classes: "h-3.5 w-3.5") %>
          </span>
        <% end %>
      <% end %>

      <div class="my-4 border-t border-white/10"></div>
    <% end %>

    <% secondary_items = admin_portal_user? ? portal_nav_items.select { |item| item[:label] == "Profile" } : portal_nav_items %>
    <% secondary_items.each do |item| %>
      <% active = nav_active?(item) %>
      <%= link_to item[:path], class: "group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-black transition #{active ? "bg-red-700 text-white shadow-lg shadow-red-950/25 dark:bg-red-600" : "text-slate-200 hover:bg-[#334155] hover:text-white dark:text-slate-300 dark:hover:bg-[#1E293B]"}" do %>
        <span class="<%= active ? "text-white" : "text-slate-300 group-hover:text-white" %>"><%= icon_svg(item[:icon]) %></span>
        <span><%= item[:label] %></span>
      <% end %>
    <% end %>
  </nav>

  <div class="space-y-4 p-4">
    <div class="rounded-xl border border-slate-500/30 bg-[#334155] p-4 dark:border-slate-700 dark:bg-[#1E293B]">
      <div class="flex items-center gap-3">
        <div class="grid h-11 w-11 place-items-center rounded-full bg-slate-100 text-sm font-black text-[#0F172A]">
          <%= current_user.display_name.first&.upcase || "M" %>
        </div>
        <div class="min-w-0">
          <p class="truncate text-sm font-black text-white"><%= current_user.display_name %></p>
          <p class="mt-0.5 truncate text-xs font-semibold text-slate-300"><%= role_label(current_user.role) %></p>
        </div>
      </div>
    </div>

    <%= button_to destroy_user_session_path, method: :delete, class: "flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-black text-slate-200 transition hover:bg-[#334155] hover:text-white dark:hover:bg-[#1E293B]" do %>
      <%= icon_svg(:logout) %>
      <span>Log Out</span>
    <% end %>
  </div>
</aside>
