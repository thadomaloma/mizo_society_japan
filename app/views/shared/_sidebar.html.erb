<aside class="fixed inset-y-0 left-0 z-30 hidden w-64 border-r border-white/[0.06] bg-[#172033] text-white shadow-[8px_0_30px_rgba(15,23,42,0.08)] dark:bg-[#020617] lg:flex lg:flex-col">
  <%= link_to dashboard_home_path, class: "flex h-20 items-center gap-3 border-b border-white/[0.07] px-4 transition hover:bg-white/[0.035]", aria: { label: "Go to dashboard" } do %>
    <div class="grid h-10 w-10 shrink-0 place-items-center overflow-hidden rounded-lg bg-white ring-1 ring-white/20">
      <%= image_tag "/icons/msj-portal-192x192-20260709.png", alt: "MSJ", class: "h-10 w-10 object-cover" %>
    </div>
    <div class="min-w-0">
      <p class="truncate text-[14px] font-black text-white">Mizo Society of Japan</p>
      <p class="mt-0.5 text-[10px] font-bold uppercase tracking-[0.12em] text-slate-400">Tlawmngai Pawl</p>
    </div>
  <% end %>

  <nav class="flex-1 space-y-1 overflow-y-auto px-3 py-4" aria-label="Primary navigation">
    <% if admin_portal_user? %>
      <% payment_labels = [ "Payments", "Payment Records", "Payment Plans" ] %>
      <% payment_items = admin_nav_items.select { |item| item[:label].in?(payment_labels) } %>
      <% admin_nav_items.each do |item| %>
        <% if item[:label] == "Payments" %>
          <%= render "shared/payment_nav_group", items: payment_items, mobile: false %>
          <% next %>
        <% end %>
        <% next if item[:label].in?(payment_labels) %>
        <% next if item[:label] == "Settings" && !current_user.super_admin? %>
        <% accessible = nav_item_visible?(item) %>
        <% active = nav_active?(item) || (item[:label] == "Settings" && settings_section_active?) %>
        <% if accessible %>
          <%= link_to item[:path], aria: { current: ("page" if active) }, class: "group relative flex min-h-10 items-center gap-3 rounded-lg px-3 py-2 text-[13px] font-extrabold transition #{active ? "bg-red-600 text-white shadow-sm shadow-red-950/20" : "text-slate-300 hover:bg-white/[0.07] hover:text-white"}" do %>
            <span class="<%= active ? "text-white" : "text-slate-300 group-hover:text-white" %>"><%= icon_svg(item[:icon]) %></span>
            <span><%= item[:label] %></span>
          <% end %>
        <% else %>
          <span class="group flex min-h-10 cursor-not-allowed items-center gap-3 rounded-lg px-3 py-2 text-[13px] font-bold text-slate-600" title="Not available for <%= role_label(current_user.role) %>">
            <span><%= icon_svg(item[:icon]) %></span>
            <span class="flex-1"><%= item[:label] %></span>
            <%= icon_svg(:lock, classes: "h-3.5 w-3.5") %>
          </span>
        <% end %>
      <% end %>

      <div class="my-3 border-t border-white/[0.07]"></div>
    <% end %>

    <% secondary_items = admin_portal_user? ? portal_nav_items.select { |item| item[:label] == "Profile" } : portal_nav_items %>
    <% secondary_items.each do |item| %>
      <% active = nav_active?(item) %>
      <%= link_to item[:path], aria: { current: ("page" if active) }, class: "group flex min-h-10 items-center gap-3 rounded-lg px-3 py-2 text-[13px] font-extrabold transition #{active ? "bg-red-600 text-white shadow-sm shadow-red-950/20" : "text-slate-300 hover:bg-white/[0.07] hover:text-white"}" do %>
        <span class="<%= active ? "text-white" : "text-slate-300 group-hover:text-white" %>"><%= icon_svg(item[:icon]) %></span>
        <span><%= item[:label] %></span>
      <% end %>
    <% end %>
  </nav>

  <div class="space-y-2 border-t border-white/[0.07] p-3">
    <div class="rounded-lg bg-white/[0.06] p-3 ring-1 ring-white/[0.08]">
      <div class="flex items-center gap-3">
        <%= user_avatar(current_user, classes: "h-9 w-9 ring-1 ring-white/20", text_classes: "text-xs") %>
        <div class="min-w-0">
          <p class="truncate text-xs font-black text-white"><%= current_user.display_name %></p>
          <p class="mt-0.5 truncate text-[10px] font-semibold text-slate-400"><%= role_label(current_user.role) %></p>
        </div>
      </div>
    </div>

    <%= button_to destroy_user_session_path, method: :delete, class: "flex min-h-9 w-full items-center gap-3 rounded-lg px-3 py-2 text-xs font-extrabold text-slate-400 transition hover:bg-white/[0.07] hover:text-white" do %>
      <%= icon_svg(:logout) %>
      <span>Log Out</span>
    <% end %>
  </div>
</aside>
