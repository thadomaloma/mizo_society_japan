# Ignore bundler config.
/.bundle

# Ignore local environment files, but keep the shared example.
/.env*
!/.env.example

# Ignore logs and temp files.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids
/tmp/pids/*
!/tmp/pids/.keep
!/tmp/storage
!/tmp/storage/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep

# Ignore local master key.
/config/master.key

# Ignore built assets and local caches.
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep
